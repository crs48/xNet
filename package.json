{
  "name": "xnet",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "build:stories": "storybook build",
    "changeset": "changeset",
    "changeset:from-commits": "changeset-conventional",
    "version-packages": "changeset version && node scripts/changeset/sync-electron-version.mjs",
    "release": "pnpm build && changeset publish",
    "dev:stories": "storybook dev --ci --no-open --host 127.0.0.1 --port 6006",
    "test": "pnpm --filter xnet-desktop run deps:node && vitest run",
    "check:cloud-boundary": "bash scripts/check-cloud-boundary.sh",
    "check:plugin-licenses": "node scripts/check-plugin-licenses.mjs",
    "check:motion-vocab": "node scripts/check-motion-vocab.mjs",
    "check:surface-tokens": "node scripts/check-surface-tokens.mjs",
    "check:humane-patterns": "node scripts/check-humane-patterns.mjs",
    "check:publish-closure": "node scripts/check-publish-closure.mjs",
    "check:electron-parity": "node scripts/check-electron-parity.mjs",
    "check:view-drift": "node scripts/check-view-drift.mjs",
    "check:storybook-shim": "node scripts/check-storybook-shim.mjs",
    "test:editor": "pnpm --filter @xnetjs/editor test",
    "test:stories": "storybook test --url http://127.0.0.1:6006",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "bench:agent-surfaces": "tsx scripts/benchmark-agent-surfaces.ts",
    "bench:core-platform": "tsx scripts/collect-core-platform-baselines.ts",
    "bench:social-import": "tsx scripts/benchmark-social-import-fixtures.ts",
    "bench:social-batch": "tsx scripts/benchmark-social-batch-writes.ts",
    "validate:canvas-v2": "bash scripts/validate-canvas-v2-release-gate.sh",
    "lint": "eslint packages apps --ext .ts,.tsx",
    "format:check": "prettier --check \"packages/**/*.{ts,tsx}\" \"apps/**/*.{ts,tsx}\"",
    "code:audit": "fallow audit --changed-since origin/main --format json --quiet",
    "code:dead": "fallow dead-code --group-by package",
    "code:dead:regression": "fallow dead-code --fail-on-regression --regression-baseline docs/reference/fallow-dead-code-regression-baseline.json --summary --no-cache",
    "code:dupes": "fallow dupes --group-by package",
    "code:fix:preview": "fallow fix --dry-run --format json",
    "code:health": "fallow health --score --hotspots --targets --file-scores",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "test:integration": "pnpm --filter @xnetjs/integration-tests test",
    "test:integration:watch": "pnpm --filter @xnetjs/integration-tests test:watch",
    "test:visuals": "node --test scripts/visuals/lib/*.test.mjs",
    "visuals:capture-set": "node scripts/visuals/changed-capture-set.mjs",
    "visuals:capture": "node scripts/visuals/capture.mjs",
    "visuals:diff": "node scripts/visuals/diff.mjs",
    "prepare": "husky",
    "check:api-report": "node scripts/check-api-report.mjs",
    "check:packaging": "node scripts/check-packaging.mjs",
    "build:blog-preview": "tsx scripts/build-blog-preview.ts",
    "check:blog-preview": "tsx scripts/build-blog-preview.ts --check"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.29.7",
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@github-ui/storybook-addon-performance-panel": "^1.1.4",
    "@microsoft/api-extractor": "^7.58.11",
    "@playwright/test": "1.58.1",
    "@storybook/addon-a11y": "^10.2.16",
    "@storybook/addon-links": "^10.2.16",
    "@storybook/addon-themes": "^10.2.16",
    "@storybook/addon-vitest": "^10.2.16",
    "@storybook/react-vite": "^10.2.16",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-istanbul": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.0",
    "@xnetjs/data": "workspace:*",
    "@xnetjs/publish": "workspace:*",
    "autoprefixer": "^10.4.23",
    "changeset-conventional-commits": "^1.0.4",
    "eslint": "^8.57.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "fallow": "^2.93.0",
    "fast-check": "^4.8.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.2.0",
    "publint": "^0.3.21",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^10.2.16",
    "tailwindcss": "^3.4.19",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.0",
    "yjs": "^13.6.0"
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write",
      "vitest related --run --passWithNoTests"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ],
    "package.json": []
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron"
    ],
    "patchedDependencies": {
      "y-webrtc@10.3.0": "patches/y-webrtc@10.3.0.patch"
    },
    "overrides": {
      "prosemirror-transform": "^1.12.0"
    }
  }
}
