{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "tui": {
    "scroll_speed": 1,
    "scroll_acceleration": {
      "enabled": false
    }
  },
  "permission": {
    "edit": {
      "tmp/*": "allow"
    },
    "read": {
      "tmp/*": "allow"
    }
  },
  "plugin": ["cc-safety-net", "opencode-agent-memory", "@nick-vi/opencode-type-inject"],
  "mcp": {
    "playwright-electron": {
      "type": "local",
      "command": [
        "pnpm",
        "dlx",
        "@playwright/mcp@0.0.52",
        "--cdp-endpoint",
        "http://127.0.0.1:9223",
        "--headless",
        "--output-mode",
        "file",
        "--output-dir",
        "tmp/playwright"
      ],
      "enabled": true
    },
    "playwright-web": {
      "type": "local",
      "command": [
        "pnpm",
        "dlx",
        "@playwright/mcp@0.0.52",
        "--browser",
        "chromium",
        "--headless",
        "--output-mode",
        "file",
        "--output-dir",
        "tmp/playwright"
      ],
      "enabled": true
    }
  },
  "agent": {
    "do-orchestrator": {
      "description": "Loop coordinator that spawns builders until plan is complete",
      "mode": "primary",
      "temperature": 0.2,
      "permission": {
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "task": "allow",
        "edit": "deny",
        "bash": "deny",
        "write": "deny"
      },
      "prompt": "{file:prompts/do-orchestrator.md}"
    },
    "do-builder-TEMPLATE": {
      "description": "TEMPLATE/COPY of the implementation agent in do-orchestr (most models can't actually invoke agents defined in opencode.json, so this is just for devs to get the gist of what's going on in do-orchestrator)",
      "mode": "subagent",
      "temperature": 0.4,
      "prompt": "{file:prompts/do-builder.md}"
    }
  },
  "command": {
    "explore": {
      "temperature": 1,
      "template": "{file:prompts/explore.md}",
      "description": "Write a markdown exploration of $ARGUMENTS.",
      "agent": "build"
    },
    "plan": {
      "temperature": 1,
      "template": "{file:prompts/plan.md}",
      "description": "Write a markdown plan of $ARGUMENTS. Include folder name like '/plan an ERP in plan03ERP/'.",
      "agent": "build"
    },
    "do": {
      "temperature": 0.2,
      "template": "{file:prompts/do.md}",
      "description": "Autonomously implement markdown-based plans/checklists. e.g. /do @docs/plans/plan01MVP/",
      "agent": "do-orchestrator"
    }
  }
}
