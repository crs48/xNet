{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "ignorePatterns": [
    "**/dist/**",
    "**/coverage/**",
    "**/storybook-static/**",
    "**/*.generated.ts",
    "patches/**",
    "examples/**",
    "scripts/changelog/**"
  ],
  "ignoreDependencies": [
    "expo-splash-screen",
    "expo-sqlite",
    "@capacitor/android",
    "@capacitor/ios"
  ],
  "dynamicallyLoaded": [
    "site/src/components/docs/*.astro",
    "site/src/styles/docs.css",
    "tests/e2e/harness/*.tsx",
    "scripts/cloud-*.mjs",
    "scripts/changeset/publishable-pathspec.mjs",
    "scripts/changeset/sync-electron-version.test.mjs",
    "scripts/reliability/hub-load.mjs",
    "packages/native-bridge-extension/host/xnet-bridge-host.mjs"
  ],
  "rules": {
    "unused-files": "warn",
    "unused-exports": "warn",
    "unused-types": "warn",
    "private-type-leaks": "off",
    "unused-dependencies": "warn",
    "unused-dev-dependencies": "warn",
    "unused-optional-dependencies": "warn",
    "unlisted-dependencies": "warn",
    "circular-dependencies": "warn",
    "re-export-cycle": "warn",
    "boundary-violation": "warn",
    "type-only-dependencies": "warn",
    "test-only-dependencies": "warn",
    "stale-suppressions": "error"
  },
  "duplicates": {
    "mode": "mild",
    "minTokens": 80,
    "minLines": 12,
    "threshold": 0,
    "ignore": [
      "apps/electron/src/renderer/components/**",
      "tests/e2e/harness/**",
      "packages/ui/src/composed/comments/**",
      "packages/data/src/index.ts",
      "packages/data/src/store/index.ts",
      "packages/hub/src/storage/memory.ts",
      "packages/hub/src/storage/sqlite.ts"
    ]
  },
  "health": {
    "maxCyclomatic": 20,
    "maxCognitive": 30,
    "maxCrap": 30.0,
    "ignore": [
      "scripts/visuals/**",
      "scripts/check-humane-patterns.mjs",
      "apps/web/src/components/CanvasView.tsx",
      "apps/web/src/components/DatabaseView.tsx",
      "apps/electron/src/renderer/components/DatabaseView.tsx",
      "apps/web/src/components/PageView.tsx",
      "apps/web/src/components/ShareDialog.tsx",
      "apps/web/src/components/TasksView.tsx",
      "apps/web/src/components/MyTasksPanel.tsx",
      "apps/web/src/components/StorageWarningBanner.tsx",
      "apps/web/src/routes/index.tsx",
      "apps/web/src/routes/settings.tsx",
      "apps/web/src/components/ConnectableProfileEditor.tsx",
      "apps/web/src/components/ContentSafetySettings.tsx",
      "apps/web/src/components/MatchCard.tsx",
      "apps/web/src/hooks/useConnect.ts",
      "apps/web/src/comms/ChannelChat.tsx",
      "apps/web/src/components/PersonActions.tsx",
      "apps/web/src/components/PersonView.tsx",
      "apps/web/src/components/PersonHovercard.tsx",
      "apps/web/src/components/SafetyCenterSettings.tsx",
      "apps/web/src/components/ReportDialog.tsx",
      "apps/web/src/components/WorkspaceCommands.tsx",
      "apps/web/src/workbench/Rail.tsx",
      "apps/web/src/routes/welcome.tsx",
      "apps/web/src/comms/InboxTray.tsx",
      "apps/web/src/hooks/useDmOpen.ts",
      "apps/web/src/lib/labeler-subscriptions.ts",
      "packages/ui/src/composed/comments/**",
      "packages/ui/src/composed/CommandPalette.tsx",
      "packages/ui/src/composed/tasks/TaskCard.tsx",
      "packages/ui/src/components/DatePicker.tsx",
      "packages/ui/src/components/SearchInput.tsx",
      "packages/views/src/relations/RelationCell.tsx"
    ]
  },
  "production": {
    "deadCode": false,
    "dupes": false,
    "health": true
  }
}
