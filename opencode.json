{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["pnpm", "dlx", "@playwright/mcp@latest", "--viewport-size=1280x800"],
      "enabled": true
    },
    "electron": {
      "type": "local",
      "command": [
        "pnpm",
        "dlx",
        "@playwright/mcp@latest",
        "--cdp-endpoint",
        "http://127.0.0.1:9222"
      ],
      "enabled": true
    }
  },
  "instructions": ["AGENTS.md"],
  "tui": {
    "scroll_speed": 1,
    "scroll_acceleration": {
      "enabled": false
    }
  }
}
