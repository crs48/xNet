{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "playwright-electron": {
      "type": "local",
      "command": [
        "pnpm",
        "dlx",
        "@playwright/mcp@latest",
        "--cdp-endpoint",
        "http://127.0.0.1:9223",
        "--output-dir",
        "tmp/playwright"
      ],
      "enabled": true
    }
  },
  "instructions": ["AGENTS.md"],
  "tui": {
    "scroll_speed": 1,
    "scroll_acceleration": {
      "enabled": false
    }
  }
}
