{
  "_comment": "Maps changed source globs to capturable app routes and interaction flows. Routes must render without URL params and without bespoke seed data. Tune freely -- the mapping is intentionally conservative; over-matching just captures an extra screen.",
  "routes": [
    {
      "id": "home",
      "label": "Home",
      "path": "/",
      "_comment": "Shell only. Domain surfaces map themselves (crm/finance/data/...); a generic web-UI change that matches no specific route still lands here via the fallback in lib/capture-set.mjs. Do NOT re-add a broad apps/web/src/components/** glob -- it false-matches every domain surface onto home (see 0191).",
      "globs": [
        "apps/web/src/routes/index.tsx",
        "apps/web/src/routes/__root.tsx",
        "apps/web/src/App.tsx",
        "apps/web/src/workbench/**"
      ]
    },
    {
      "id": "discover",
      "label": "Discover",
      "path": "/discover",
      "globs": ["apps/web/src/routes/discover.tsx", "packages/abuse/**", "packages/social/**"]
    },
    {
      "id": "data",
      "label": "Data",
      "path": "/data",
      "globs": ["apps/web/src/routes/data.tsx", "packages/views/**", "packages/data/**"]
    },
    {
      "id": "tasks",
      "label": "Tasks",
      "path": "/tasks",
      "globs": ["apps/web/src/routes/tasks.tsx"]
    },
    {
      "id": "experiments",
      "label": "Experiments",
      "path": "/experiments",
      "globs": ["apps/web/src/routes/experiments.tsx", "packages/experiments/**"]
    },
    {
      "id": "crm",
      "label": "CRM",
      "path": "/crm",
      "globs": ["apps/web/src/routes/crm.tsx", "apps/web/src/components/crm/**", "packages/crm/**"]
    },
    {
      "id": "finance",
      "label": "Finance",
      "path": "/finance",
      "globs": [
        "apps/web/src/routes/finance.tsx",
        "apps/web/src/components/finance/**",
        "packages/ledger/**"
      ]
    },
    {
      "id": "analytics",
      "label": "Analytics",
      "path": "/analytics",
      "globs": ["apps/web/src/routes/analytics.tsx", "apps/web/src/hooks/useTelemetryAnalytics*"]
    },
    {
      "id": "settings",
      "label": "Settings",
      "path": "/settings",
      "globs": [
        "apps/web/src/routes/settings.tsx",
        "packages/ui/src/composed/SettingsView*",
        "packages/ui/src/composed/settings/**"
      ]
    },
    {
      "id": "requests",
      "label": "Requests",
      "path": "/requests",
      "globs": ["apps/web/src/routes/requests.tsx"]
    },
    {
      "id": "social-import",
      "label": "Social import",
      "path": "/social-import",
      "globs": ["apps/web/src/routes/social-import.tsx"]
    }
  ],
  "flows": [
    {
      "id": "create-page",
      "label": "Create a page and use the editor",
      "globs": [
        "packages/editor/**",
        "apps/web/src/routes/index.tsx",
        "apps/web/src/routes/doc.$docId.tsx"
      ]
    },
    {
      "id": "canvas",
      "label": "Open the canvas",
      "globs": [
        "packages/canvas/**",
        "packages/canvas-core/**",
        "apps/web/src/routes/canvas.$canvasId.tsx"
      ]
    },
    {
      "id": "crm-quote",
      "label": "Build a CRM quote (product + line item)",
      "globs": ["apps/web/src/components/crm/**", "packages/crm/**"]
    },
    {
      "id": "chat",
      "label": "Open a channel and post a message",
      "_comment": "Chat only renders at the parameterized /channel/$channelId route (needs a channel id + seed messages), so a static route shot can't reach it -- this flow seeds a channel and drives the redesigned feed into a GIF. Mapping apps/web/src/comms/** here is what keeps a chat-only PR (e.g. #174) from falling through to the silent home fallback (exploration 0200).",
      "globs": ["apps/web/src/comms/**", "apps/web/src/routes/channel.$channelId.tsx"]
    }
  ]
}
