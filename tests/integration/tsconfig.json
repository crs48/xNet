{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "types": ["vitest", "vitest/browser", "@vitest/browser-playwright"],
    "paths": {
      "@xnetjs/*": ["../../packages/*/src"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
