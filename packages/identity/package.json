{
  "name": "@xnetjs/identity",
  "version": "2.5.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/crs48/xNet"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./did": {
      "types": "./dist/did.d.ts",
      "import": "./dist/did.js"
    },
    "./ucan": {
      "types": "./dist/ucan.d.ts",
      "import": "./dist/ucan.js"
    },
    "./key-bundle": {
      "types": "./dist/key-bundle-entry.d.ts",
      "import": "./dist/key-bundle-entry.js"
    },
    "./passkey": {
      "types": "./dist/passkey/index.d.ts",
      "import": "./dist/passkey/index.js"
    },
    "./legacy": {
      "types": "./dist/legacy.d.ts",
      "import": "./dist/legacy.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup src/index.ts src/did.ts src/ucan.ts src/key-bundle-entry.ts src/passkey/index.ts src/legacy.ts --format esm --dts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@noble/curves": "^2.0.1",
    "@noble/post-quantum": "^0.5.4",
    "@xnetjs/core": "workspace:*",
    "@xnetjs/crypto": "workspace:*",
    "multiformats": "^13.4.2"
  },
  "devDependencies": {
    "fake-indexeddb": "^6.0.0",
    "nid-webauthn-emulator": "^0.2.9",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
