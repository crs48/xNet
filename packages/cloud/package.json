{
  "name": "@xnetjs/cloud",
  "version": "0.0.1",
  "description": "xNet Cloud — the server-only managed-hosting control-plane library: provisioner, billing identity, usage billing, AI gateway, object storage, Litestream replication, and the COGS model. Source-available under FSL-1.1.",
  "license": "FSL-1.1-Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./provisioner": {
      "import": "./dist/provisioner/index.js",
      "types": "./dist/provisioner/index.d.ts"
    },
    "./identity": {
      "import": "./dist/identity/index.js",
      "types": "./dist/identity/index.d.ts"
    },
    "./escrow": {
      "import": "./dist/escrow/index.js",
      "types": "./dist/escrow/index.d.ts"
    },
    "./billing": {
      "import": "./dist/billing/index.js",
      "types": "./dist/billing/index.d.ts"
    },
    "./ai": {
      "import": "./dist/ai/index.js",
      "types": "./dist/ai/index.d.ts"
    },
    "./storage": {
      "import": "./dist/storage/index.js",
      "types": "./dist/storage/index.d.ts"
    },
    "./litestream": {
      "import": "./dist/litestream/index.js",
      "types": "./dist/litestream/index.d.ts"
    },
    "./cost": {
      "import": "./dist/cost/index.js",
      "types": "./dist/cost/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@xnetjs/core": "workspace:*",
    "@xnetjs/entitlements": "workspace:*",
    "@xnetjs/identity": "workspace:*",
    "@xnetjs/storage": "workspace:*",
    "stripe": "^17.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "aws-sdk-client-mock": "^4.0.0",
    "msw": "^2.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.0"
  },
  "private": true
}
