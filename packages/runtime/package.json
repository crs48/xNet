{
  "name": "@xnetjs/runtime",
  "version": "0.4.0",
  "description": "Framework-agnostic xNet runtime: createXNetClient() and sync orchestration, usable from any framework, a CLI, a worker, or a Node service",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/crs48/xNet"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@xnetjs/core": "workspace:*",
    "@xnetjs/crypto": "workspace:*",
    "@xnetjs/data": "workspace:*",
    "@xnetjs/data-bridge": "workspace:*",
    "@xnetjs/history": "workspace:*",
    "@xnetjs/identity": "workspace:*",
    "@xnetjs/plugins": "workspace:*",
    "@xnetjs/storage": "workspace:*",
    "@xnetjs/sync": "workspace:*",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.24"
  },
  "devDependencies": {
    "jsdom": "^26.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.0"
  }
}
