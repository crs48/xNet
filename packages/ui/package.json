{
  "name": "@xnetjs/ui",
  "version": "0.0.1",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./tokens.css": "./src/theme/tokens.css",
    "./motion.css": "./src/theme/motion.css",
    "./base-ui-animations.css": "./src/theme/base-ui-animations.css",
