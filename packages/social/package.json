{
  "name": "@xnetjs/social",
  "version": "0.0.1",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./schemas": {
      "import": "./src/schemas/index.ts",
      "types": "./src/schemas/index.ts"
    },
    "./import": {
      "import": "./src/import/index.ts",
      "types": "./src/import/index.ts"
    },
    "./importers": {
      "import": "./src/importers/index.ts",
      "types": "./src/importers/index.ts"
    },
    "./lenses": {
      "import": "./src/lenses/index.ts",
      "types": "./src/lenses/index.ts"
    },
    "./projection": {
      "import": "./src/projection/index.ts",
      "types": "./src/projection/index.ts"
    },
    "./views": {
      "import": "./src/views/index.ts",
      "types": "./src/views/index.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/schemas/index.ts src/import/index.ts src/importers/index.ts src/lenses/index.ts src/projection/index.ts src/views/index.ts --format esm --dts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@xnetjs/data": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.0"
  },
  "private": true
}
