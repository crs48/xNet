{
  "name": "@xnetjs/data",
  "version": "3.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/crs48/xNet"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js"
    },
    "./store": {
      "types": "./dist/store/index.d.ts",
      "import": "./dist/store/index.js"
    },
    "./database": {
      "types": "./dist/database/index.d.ts",
      "import": "./dist/database/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js"
    },
    "./portability": {
      "types": "./dist/portability/index.d.ts",
      "import": "./dist/portability/index.js"
    },
    "./updates": {
      "types": "./dist/updates.d.ts",
      "import": "./dist/updates.js"
    },
    "./awareness": {
      "types": "./dist/sync/awareness.d.ts",
      "import": "./dist/sync/awareness.js"
    },
    "./ts-plugin": {
      "types": "./dist/ts-plugin/index.d.ts",
      "require": "./dist/ts-plugin/index.cjs",
      "import": "./dist/ts-plugin/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup src/index.ts src/schema/index.ts src/store/index.ts src/database/index.ts src/auth/index.ts src/portability/index.ts src/updates.ts src/sync/awareness.ts --format esm --dts && tsup src/ts-plugin/index.ts --format cjs,esm --dts --outDir dist/ts-plugin",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "api:check": "api-extractor run",
    "api:update": "api-extractor run --local"
  },
  "dependencies": {
    "@xnetjs/core": "workspace:*",
    "@xnetjs/crypto": "workspace:*",
    "@xnetjs/identity": "workspace:*",
    "@xnetjs/sqlite": "workspace:*",
    "@xnetjs/storage": "workspace:*",
    "@xnetjs/sync": "workspace:*",
    "nanoid": "^5.1.6",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.24"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
