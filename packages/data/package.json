{
  "name": "@xnetjs/data",
  "version": "0.0.2",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./ts-plugin": {
      "types": "./dist/ts-plugin/index.d.ts",
      "require": "./dist/ts-plugin/index.cjs",
      "import": "./dist/ts-plugin/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts && tsup src/ts-plugin/index.ts --format cjs,esm --dts --outDir dist/ts-plugin",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@xnetjs/core": "workspace:*",
    "@xnetjs/crypto": "workspace:*",
    "@xnetjs/identity": "workspace:*",
    "@xnetjs/sqlite": "workspace:*",
    "@xnetjs/storage": "workspace:*",
    "@xnetjs/sync": "workspace:*",
    "lib0": "^0.2.102",
    "nanoid": "^5.1.6",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.24"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
