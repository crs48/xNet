{
  "name": "@xnetjs/data-bridge",
  "version": "0.0.2",
  "description": "DataBridge abstraction for off-main-thread data access in xNet",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/crs48/xNet"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./native": {
      "import": "./dist/native-bridge.js",
      "types": "./dist/native-bridge.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    },
    "./worker": {
      "import": "./dist/worker/data-worker.js",
      "types": "./dist/worker/data-worker.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup src/index.ts src/native-bridge.ts src/types.ts src/worker/data-worker.ts --format esm --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@xnetjs/core": "workspace:*",
    "@xnetjs/data": "workspace:*",
    "comlink": "^4.4.2",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.24"
  },
  "devDependencies": {
    "@xnetjs/crypto": "workspace:*",
    "@xnetjs/identity": "workspace:*",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.0"
  }
}
