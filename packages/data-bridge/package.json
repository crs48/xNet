{
  "name": "@xnet/data-bridge",
  "version": "0.0.1",
  "description": "DataBridge abstraction for off-main-thread data access in xNet",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@xnet/core": "workspace:*",
    "@xnet/data": "workspace:*",
    "yjs": "^13.6.24",
    "y-protocols": "^1.0.6"
  },
  "devDependencies": {
    "@xnet/crypto": "workspace:*",
    "@xnet/identity": "workspace:*",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.0"
  }
}
