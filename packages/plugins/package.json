{
  "name": "@xnet/plugins",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./node": {
      "import": "./dist/services/node.js",
      "types": "./dist/services/node.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@xnet/core": "workspace:*",
    "@xnet/data": "workspace:*",
    "acorn": "^8.15.0"
  },
  "peerDependencies": {
    "@tiptap/core": "^2.0.0",
    "react": "^18.0.0"
  },
  "devDependencies": {
    "@tiptap/core": "^2.0.0",
    "@types/react": "^18.2.0",
    "jsdom": "^26.0.0",
    "react": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
