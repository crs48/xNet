  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/crs48/xNet"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
