{
  "name": "@xnetjs/devtools",
  "version": "0.1.0",
  "description": "Protocol-level devtools for xNet applications",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "development": "./src/index.dev.ts",
      "import": "./src/index.dev.ts",
      "default": "./src/index.ts"
    },
    "./seed": "./src/seed/index.ts"
  },
  "scripts": {
    "build": "tsup src/index.ts src/index.dev.ts --format esm --dts --external react --external react-dom --external yjs --external @xnetjs/data --external @xnetjs/plugins --external @xnetjs/sync --external @xnetjs/react --external @xnetjs/ui",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@xnetjs/data": "workspace:*",
    "@xnetjs/plugins": "workspace:*",
    "@xnetjs/react": "workspace:*",
    "@xnetjs/sync": "workspace:*",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "yjs": ">=13.0.0"
  },
  "dependencies": {
    "@blocknote/core": "0.51.4",
    "@xnetjs/canvas": "workspace:*",
    "@xnetjs/editor": "workspace:*",
    "@xnetjs/history": "workspace:*",
    "@xnetjs/sqlite": "workspace:*",
    "@xnetjs/ui": "workspace:*",
    "@xnetjs/views": "workspace:*",
    "fflate": "0.8.3",
    "lucide-react": "^0.400.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.0",
    "yjs": "^13.6.24"
  },
  "private": true
}
