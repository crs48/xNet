{
  "name": "@xnetjs/editor",
  "version": "0.0.1",
  "description": "Collaborative editor for xNet with Tiptap",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./react": {
      "import": "./src/react.ts",
      "types": "./src/react.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/react.ts --format esm --dts --external react",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@blocknote/core": "0.51.4",
    "@blocknote/mantine": "0.51.4",
    "@blocknote/react": "0.51.4",
    "@mantine/core": "^8.3.18",
    "@mantine/hooks": "^8.3.18",
    "@xnetjs/canvas": "workspace:*",
    "@xnetjs/data": "workspace:*",
    "@xnetjs/react": "workspace:*",
    "@xnetjs/ui": "workspace:*",
    "katex": "^0.16.28",
    "lucide-react": "^0.563.0",
    "mermaid": "^11.12.2",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.24"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@storybook/react-vite": "^10.2.16",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/react": "^18.2.0",
    "@xnetjs/views": "workspace:*",
    "jsdom": "^25.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "private": true
}
