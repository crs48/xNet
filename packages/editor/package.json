{
  "name": "@xnetjs/editor",
  "version": "0.0.1",
  "description": "Collaborative editor for xNet with Tiptap",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./react": {
      "import": "./src/react.ts",
      "types": "./src/react.ts"
    },
    "./extensions": {
      "import": "./src/extensions.ts",
      "types": "./src/extensions.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/react.ts src/extensions.ts --format esm --dts --external react",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.6.13",
    "@tiptap/core": "^3.15.3",
    "@tiptap/extension-collaboration": "^3.15.3",
    "@tiptap/extension-drag-handle": "3.16.0",
    "@tiptap/extension-drag-handle-react": "3.16.0",
    "@tiptap/extension-emoji": "3.16.0",
    "@tiptap/extension-link": "^3.15.3",
    "@tiptap/extension-mathematics": "3.16.0",
    "@tiptap/extension-node-range": "3.16.0",
    "@tiptap/extension-placeholder": "^3.15.3",
    "@tiptap/extension-task-item": "^3.15.3",
    "@tiptap/extension-task-list": "^3.15.3",
    "@tiptap/extension-typography": "^3.15.3",
    "@tiptap/markdown": "3.16.0",
    "@tiptap/pm": "^3.15.3",
    "@tiptap/react": "^3.15.3",
    "@tiptap/starter-kit": "^3.15.3",
    "@tiptap/suggestion": "^3.15.3",
    "@tiptap/y-tiptap": "^3.0.1",
    "@xnetjs/canvas": "workspace:*",
    "@xnetjs/data": "workspace:*",
    "@xnetjs/react": "workspace:*",
    "@xnetjs/ui": "workspace:*",
    "katex": "^0.16.28",
    "lucide-react": "^0.563.0",
    "mermaid": "^11.12.2",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.24"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@storybook/react-vite": "^10.2.16",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/react": "^18.2.0",
    "@xnetjs/views": "workspace:*",
    "jsdom": "^25.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "private": true
}
