{
  "name": "@xnetjs/unreal",
  "version": "0.0.15",
  "description": "Unreal Engine 6 interop — the governed game connector (durable player data → XNet nodes), the save-file-not-netcode granularity guardrail, and the game-event → node mapping over the @xnetjs/data game-interop schema pack (exploration 0200).",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@xnetjs/data": "workspace:*"
  },
  "devDependencies": {
    "@xnetjs/plugins": "workspace:*",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.0"
  },
  "private": true
}
