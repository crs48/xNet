# Skip hooks for markdown-only changes
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)
NON_MD_FILES=$(echo "$STAGED_FILES" | grep -v '\.md$' | grep -v '^docs/' || true)

if [ -z "$NON_MD_FILES" ]; then
  echo "Skipping pre-commit hooks (only markdown/docs changes)"
  exit 0
fi

pnpm lint-staged
pnpm turbo run typecheck --affected
pnpm vitest run --changed HEAD --passWithNoTests
