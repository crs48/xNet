{
  "name": "xnet-desktop",
  "version": "0.0.1",
  "description": "xNet Desktop - Local-first data platform for macOS/Windows/Linux",
  "author": {
    "name": "xNet",
    "email": "support@xnet.dev"
  },
  "homepage": "https://github.com/crs48/xNet",
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n hub,electron -c blue,green \"pnpm run dev:hub\" \"pnpm run dev:electron\"",
    "dev:electron": "pnpm run deps:electron && electron-vite dev",
    "dev:hub": "HUB_AUTH=false HUB_STORAGE=memory pnpm --filter @xnetjs/hub dev",
    "dev:user2": "cross-env XNET_PROFILE=user2 VITE_PORT=5174 electron-vite dev",
    "dev:both": "concurrently -k -n hub,user1,user2 -c blue,green,yellow \"pnpm run dev:hub\" \"pnpm run dev:electron\" \"sleep 3 && pnpm run dev:user2\"",
    "build": "electron-vite build",
    "deps:electron": "pnpm dlx @electron/rebuild -f -w better-sqlite3,usearch,sharp",
    "deps:node": "pnpm rebuild better-sqlite3 usearch sharp",
    "preview": "electron-vite preview",
    "dist": "npm run build && electron-builder",
    "dist:mac:self-signed": "./scripts/build-macos-self-signed.sh",
    "dist:mac:self-signed:arm64": "./scripts/build-macos-self-signed.sh arm64",
    "test": "pnpm run deps:node && vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.45.0",
    "@xnetjs/canvas": "workspace:*",
    "@xnetjs/core": "workspace:*",
    "@xnetjs/data": "workspace:*",
    "@xnetjs/plugins": "workspace:*",
    "@xnetjs/devtools": "workspace:*",
    "@xnetjs/identity": "workspace:*",
    "@xnetjs/network": "workspace:*",
    "@xnetjs/sqlite": "workspace:*",
    "@xnetjs/storage": "workspace:*",
    "@xnetjs/sync": "workspace:*",
    "@xnetjs/editor": "workspace:*",
    "@xnetjs/react": "workspace:*",
    "@xnetjs/sdk": "workspace:*",
    "@xnetjs/telemetry": "workspace:*",
    "@xnetjs/ui": "workspace:*",
    "@xnetjs/views": "workspace:*",
    "better-sqlite3": "^11.0.0",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.3.0",
    "lucide-react": "^0.400.0",
    "mermaid": "^11.4.0",
    "ws": "^8.18.0",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.24"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.47",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "private": true
}
