{
  "appId": "dev.xnet.app",
  "productName": "xNet",
  "copyright": "Copyright 2024 xNet Contributors",

  "directories": {
    "output": "dist",
    "buildResources": "build"
  },

  "files": ["out/**/*", "package.json"],

  "mac": {
    "category": "public.app-category.productivity",
    "icon": "build/icon.icns",
    "hardenedRuntime": true,
    "gatekeeperAssess": false,
    "entitlements": "build/entitlements.mac.plist",
    "entitlementsInherit": "build/entitlements.mac.plist",
    // Arch is driven by the CI `--mac --<arch>` flag (one arch per matrix job).
    // Hardcoding both here made a single job build both arches in one invocation,
    // where @electron/rebuild cross-contaminates the native modules — landing the
    // wrong-arch better_sqlite3.node in a package (see the Linux x64 boot crash).
    "target": ["dmg", "zip"]
  },

  "dmg": {
    "contents": [
      {
        "x": 130,
        "y": 220
      },
      {
        "x": 410,
        "y": 220,
        "type": "link",
        "path": "/Applications"
      }
    ]
  },

  "win": {
    "icon": "build/icon.ico",
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ]
  },

  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "deleteAppDataOnUninstall": false
  },

  "linux": {
    "icon": "build/icon.png",
    "category": "Office",
    // Arch driven by the CI `--linux --<arch>` flag (one arch per matrix job) so a
    // single invocation never rebuilds native modules for two arches and packs the
    // wrong-arch better_sqlite3.node (root cause of the packaged x64 boot crash).
    "target": ["AppImage", "deb"]
  },

  "publish": {
    "provider": "github",
    "owner": "xnet-dev",
    "repo": "xnet"
  }
}
