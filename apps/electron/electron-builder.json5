{
  "appId": "dev.xnet.app",
  "productName": "xNet",
  "copyright": "Copyright 2024 xNet Contributors",

  "directories": {
    "output": "dist",
    "buildResources": "build"
  },

  "files": ["out/**/*", "package.json"],

  "mac": {
    "category": "public.app-category.productivity",
    "icon": "build/icon.icns",
    "hardenedRuntime": true,
    "gatekeeperAssess": false,
    "entitlements": "build/entitlements.mac.plist",
    "entitlementsInherit": "build/entitlements.mac.plist",
    // Arch is driven by the CI `--mac --<arch>` flag (one arch per matrix job).
    // Hardcoding both here made a single job build both arches in one invocation,
    // where @electron/rebuild cross-contaminates the native modules — landing the
    // wrong-arch better_sqlite3.node in a package (see the Linux x64 boot crash).
    "target": ["dmg", "zip"],
    // Meeting capture (exploration 0279): mic prompt + the audio-capture TCC
    // category the Core Audio tap helper triggers on macOS 14.4+.
    "extendInfo": {
      "NSMicrophoneUsageDescription": "xNet records your microphone during meetings you choose to capture.",
      "NSAudioCaptureUsageDescription": "xNet captures system audio during meetings you choose to capture, so the other side of the call can be transcribed."
    },
    // The Swift tap helper (native/audiotee, built by CI: `swift build -c release`).
    // Missing binary is fine — the app falls back to Chromium loopback.
    "extraResources": [
      {
        "from": "native/audiotee/.build/release/xnet-audiotee",
        "to": "xnet-audiotee"
      }
    ]
  },

  "dmg": {
    "contents": [
      {
        "x": 130,
        "y": 220
      },
      {
        "x": 410,
        "y": 220,
        "type": "link",
        "path": "/Applications"
      }
    ]
  },

  "win": {
    "icon": "build/icon.ico",
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ]
  },

  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "deleteAppDataOnUninstall": false
  },

  "linux": {
    "icon": "build/icon.png",
    "category": "Office",
    // Arch driven by the CI `--linux --<arch>` flag (one arch per matrix job) so a
    // single invocation never rebuilds native modules for two arches and packs the
    // wrong-arch better_sqlite3.node (root cause of the packaged x64 boot crash).
    "target": ["AppImage", "deb"]
  },

  "publish": {
    "provider": "github",
    "owner": "xnet-dev",
    "repo": "xnet"
  }
}
