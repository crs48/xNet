{
  "name": "xnet-mobile-shell",
  "version": "0.0.1",
  "description": "xNet mobile shell — hosts the apps/web SPA in a native webview via Capacitor (exploration 0238).",
  "private": true,
  "scripts": {
    "build:web": "pnpm --filter xnet-web build:mobile",
    "add:ios": "pnpm exec cap add ios",
    "add:android": "pnpm exec cap add android",
    "sync": "pnpm build:web && pnpm exec cap sync",
    "open:ios": "pnpm exec cap open ios",
    "open:android": "pnpm exec cap open android"
  },
  "devDependencies": {
    "@capacitor/android": "8.4.1",
    "@capacitor/cli": "8.4.1",
    "@capacitor/core": "8.4.1",
    "@capacitor/ios": "8.4.1"
  }
}
