{
  "name": "xnet-cloud",
  "version": "0.0.17",
  "description": "xNet Cloud control plane — billing, provisioning, and fleet management (explorations 0174/0175).",
  "license": "FSL-1.1-Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "node --loader tsx src/index.ts",
    "dev:staging": "node --env-file=.env.staging --env-file-if-exists=.env.staging.local --loader tsx src/index.ts",
    "build": "tsup src/index.ts --format esm",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@google-cloud/firestore": "^8.6.0",
    "@google-cloud/run": "^3.3.0",
    "@hono/node-server": "^1.0.0",
    "@xnetjs/cloud": "workspace:*",
    "@xnetjs/core": "workspace:*",
    "@xnetjs/crypto": "workspace:*",
    "@xnetjs/entitlements": "workspace:*",
    "@xnetjs/telemetry": "workspace:*",
    "hono": "^4.0.0",
    "stripe": "^17.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.0"
  },
  "private": true
}
