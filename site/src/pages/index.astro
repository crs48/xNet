---
import Base from '../layouts/Base.astro'
import Nav from '../components/sections/Nav.astro'
import Hero from '../components/sections/Hero.astro'
import ProblemStatement from '../components/sections/ProblemStatement.astro'
import HooksShowcase from '../components/sections/HooksShowcase.astro'
import BeforeAfter from '../components/sections/BeforeAfter.astro'
import WhatYouCanBuild from '../components/sections/WhatYouCanBuild.astro'
import DeveloperExperience from '../components/sections/DeveloperExperience.astro'
import UnderTheHood from '../components/sections/UnderTheHood.astro'
import PluginSystem from '../components/sections/PluginSystem.astro'
import Landscape from '../components/sections/Landscape.astro'
import Community from '../components/sections/Community.astro'
import GetStarted from '../components/sections/GetStarted.astro'
import Footer from '../components/sections/Footer.astro'
---

<Base
  title="xNet — Three hooks. Zero backend. Local-first apps that just work."
  description="Build local-first apps with React hooks. No server, no auth, no vendor lock-in. P2P sync, offline-first, TypeScript all the way down."
>
  <Nav />

  <main>
    <Hero />
    <ProblemStatement />
    <HooksShowcase />
    <BeforeAfter />
    <WhatYouCanBuild />
    <DeveloperExperience />
    <UnderTheHood />
    <PluginSystem />
    <Landscape />
    <Community />
    <GetStarted />
  </main>

  <Footer />
</Base>
