---
import Base from '../layouts/Base.astro'
---

<Base
  title="xNet — The Decentralized Data Layer"
  description="Local-first, P2P-synced, user-owned data infrastructure. From personal notes to planetary-scale indexes."
>
  <!-- Nav -->
  <header class="sticky top-0 z-50 border-b border-border bg-[#0a0a0f]/80 backdrop-blur-md">
    <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
      <a href={import.meta.env.BASE_URL} class="font-mono text-xl font-bold tracking-tight text-white hover:text-indigo-400 transition-colors">
        xNet
      </a>
      <div class="flex items-center gap-6 text-sm">
        <a href="#primitives" class="hidden sm:inline text-gray-400 hover:text-white transition-colors">Primitives</a>
        <a href="#hooks" class="hidden sm:inline text-gray-400 hover:text-white transition-colors">Hooks</a>
        <a href="#features" class="hidden sm:inline text-gray-400 hover:text-white transition-colors">Features</a>
        <a href="#vision" class="hidden sm:inline text-gray-400 hover:text-white transition-colors">Vision</a>
        <a href="#get-started" class="hidden sm:inline text-gray-400 hover:text-white transition-colors">Get Started</a>
        <a
          href="https://github.com/anomalyco/xNet"
          class="rounded-md border border-border px-3 py-1.5 text-gray-200 hover:border-indigo-500/50 hover:bg-surface transition-all"
        >
          GitHub
        </a>
      </div>
    </nav>
  </header>

  <main>
    <!-- Hero -->
    <section class="mx-auto max-w-6xl px-6 py-24 lg:py-32">
      <div class="text-center">
        <h1 class="text-4xl font-extrabold leading-tight tracking-tight sm:text-5xl lg:text-6xl">
          <span class="bg-gradient-to-br from-white via-gray-200 to-indigo-400 bg-clip-text text-transparent">
            The Decentralized Data Layer
          </span>
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-400 sm:text-xl">
          Infrastructure for a new internet. Local-first, P2P-synced, user-owned.
          <span class="text-gray-300">From personal notes to planetary-scale indexes.</span>
        </p>
        <div class="mt-10 flex justify-center gap-4">
          <a
            href="https://github.com/anomalyco/xNet"
            class="rounded-lg bg-indigo-600 px-6 py-3 font-semibold text-white hover:bg-indigo-500 transition-colors"
          >
            View on GitHub
          </a>
          <a
            href="#primitives"
            class="rounded-lg border border-border px-6 py-3 font-semibold text-gray-200 hover:border-indigo-500/50 hover:bg-surface transition-all"
          >
            Explore
          </a>
        </div>
      </div>

      <!-- Hero Diagram: Data Ownership -->
      <div class="mt-20 flex justify-center">
        <svg viewBox="0 0 800 200" class="w-full max-w-3xl" xmlns="http://www.w3.org/2000/svg">
          <!-- Left: Traditional -->
          <g transform="translate(50, 20)">
            <text x="120" y="0" fill="#6b7280" font-size="12" text-anchor="middle" font-weight="600">TODAY'S INTERNET</text>
            <!-- Cloud -->
            <ellipse cx="120" cy="60" rx="80" ry="35" fill="#1e1e2e" stroke="#374151" stroke-width="1.5"/>
            <text x="120" y="65" fill="#9ca3af" font-size="11" text-anchor="middle">Their Servers</text>
            <!-- Users pointing to cloud -->
            <circle cx="40" cy="140" r="15" fill="#1e1e2e" stroke="#4b5563" stroke-width="1.5"/>
            <circle cx="120" cy="150" r="15" fill="#1e1e2e" stroke="#4b5563" stroke-width="1.5"/>
            <circle cx="200" cy="140" r="15" fill="#1e1e2e" stroke="#4b5563" stroke-width="1.5"/>
            <line x1="40" y1="125" x2="80" y2="85" stroke="#4b5563" stroke-width="1" stroke-dasharray="4"/>
            <line x1="120" y1="135" x2="120" y2="95" stroke="#4b5563" stroke-width="1" stroke-dasharray="4"/>
            <line x1="200" y1="125" x2="160" y2="85" stroke="#4b5563" stroke-width="1" stroke-dasharray="4"/>
            <text x="120" y="180" fill="#6b7280" font-size="10" text-anchor="middle">You access their data</text>
          </g>

          <!-- Arrow -->
          <g transform="translate(350, 80)">
            <polygon points="0,20 40,0 40,15 100,15 100,25 40,25 40,40" fill="#4f46e5"/>
            <text x="50" y="60" fill="#818cf8" font-size="11" text-anchor="middle" font-weight="500">xNet</text>
          </g>

          <!-- Right: xNet -->
          <g transform="translate(500, 20)">
            <text x="120" y="0" fill="#818cf8" font-size="12" text-anchor="middle" font-weight="600">xNet</text>
            <!-- Devices with data -->
            <rect x="20" y="40" width="50" height="70" rx="6" fill="#1e1e2e" stroke="#4f46e5" stroke-width="1.5"/>
            <rect x="95" y="30" width="50" height="80" rx="6" fill="#1e1e2e" stroke="#4f46e5" stroke-width="1.5"/>
            <rect x="170" y="40" width="50" height="70" rx="6" fill="#1e1e2e" stroke="#4f46e5" stroke-width="1.5"/>
            <!-- Data dots inside -->
            <circle cx="45" cy="65" r="4" fill="#818cf8"/>
            <circle cx="45" cy="80" r="4" fill="#818cf8"/>
            <circle cx="120" cy="55" r="4" fill="#818cf8"/>
            <circle cx="120" cy="70" r="4" fill="#818cf8"/>
            <circle cx="120" cy="85" r="4" fill="#818cf8"/>
            <circle cx="195" cy="65" r="4" fill="#818cf8"/>
            <circle cx="195" cy="80" r="4" fill="#818cf8"/>
            <!-- P2P connections -->
            <line x1="70" y1="75" x2="95" y2="70" stroke="#4f46e5" stroke-width="1.5"/>
            <line x1="145" y1="70" x2="170" y2="75" stroke="#4f46e5" stroke-width="1.5"/>
            <path d="M45 110 Q120 140 195 110" stroke="#4f46e5" stroke-width="1.5" fill="none" stroke-dasharray="4"/>
            <!-- Labels -->
            <text x="45" y="125" fill="#9ca3af" font-size="9" text-anchor="middle">Desktop</text>
            <text x="120" y="125" fill="#9ca3af" font-size="9" text-anchor="middle">Phone</text>
            <text x="195" y="125" fill="#9ca3af" font-size="9" text-anchor="middle">Web</text>
            <text x="120" y="180" fill="#a5b4fc" font-size="10" text-anchor="middle">Your data, your devices</text>
          </g>
        </svg>
      </div>
    </section>

    <!-- Core Primitives -->
    <section id="primitives" class="border-y border-border bg-surface/30 py-20">
      <div class="mx-auto max-w-6xl px-6">
        <h2 class="text-3xl font-bold tracking-tight">Four Primitives, Infinite Scale</h2>
        <p class="mt-2 text-gray-400">The same building blocks work from a personal note to a planetary index</p>

        <!-- Primitives Diagram -->
        <div class="mt-12 flex justify-center">
          <svg viewBox="0 0 800 320" class="w-full max-w-4xl" xmlns="http://www.w3.org/2000/svg">
            <!-- Node -->
            <g transform="translate(80, 40)">
              <rect x="0" y="0" width="140" height="100" rx="12" fill="#1e1e2e" stroke="#4f46e5" stroke-width="2"/>
              <text x="70" y="35" fill="#a5b4fc" font-size="14" text-anchor="middle" font-weight="600">Node</text>
              <text x="70" y="55" fill="#6b7280" font-size="10" text-anchor="middle">Universal container</text>
              <text x="70" y="75" fill="#4b5563" font-size="9" text-anchor="middle" font-family="monospace">id, schemaId,</text>
              <text x="70" y="87" fill="#4b5563" font-size="9" text-anchor="middle" font-family="monospace">createdAt, createdBy</text>
            </g>

            <!-- Schema -->
            <g transform="translate(280, 40)">
              <rect x="0" y="0" width="140" height="100" rx="12" fill="#1e1e2e" stroke="#10b981" stroke-width="2"/>
              <text x="70" y="35" fill="#6ee7b7" font-size="14" text-anchor="middle" font-weight="600">Schema</text>
              <text x="70" y="55" fill="#6b7280" font-size="10" text-anchor="middle">Type definition</text>
              <text x="70" y="75" fill="#4b5563" font-size="9" text-anchor="middle" font-family="monospace">xnet://xnet.dev/Task</text>
              <text x="70" y="87" fill="#4b5563" font-size="9" text-anchor="middle" font-family="monospace">xnet://you.dev/Recipe</text>
            </g>

            <!-- Sync -->
            <g transform="translate(480, 40)">
              <rect x="0" y="0" width="140" height="100" rx="12" fill="#1e1e2e" stroke="#f59e0b" stroke-width="2"/>
              <text x="70" y="35" fill="#fcd34d" font-size="14" text-anchor="middle" font-weight="600">Sync</text>
              <text x="70" y="55" fill="#6b7280" font-size="10" text-anchor="middle">Conflict-free merge</text>
              <text x="70" y="75" fill="#4b5563" font-size="9" text-anchor="middle" font-family="monospace">Yjs CRDT (text)</text>
              <text x="70" y="87" fill="#4b5563" font-size="9" text-anchor="middle" font-family="monospace">Lamport LWW (data)</text>
            </g>

            <!-- Identity -->
            <g transform="translate(680, 40)">
              <rect x="0" y="0" width="140" height="100" rx="12" fill="#1e1e2e" stroke="#ec4899" stroke-width="2"/>
              <text x="70" y="35" fill="#f9a8d4" font-size="14" text-anchor="middle" font-weight="600">Identity</text>
              <text x="70" y="55" fill="#6b7280" font-size="10" text-anchor="middle">Self-sovereign auth</text>
              <text x="70" y="75" fill="#4b5563" font-size="9" text-anchor="middle" font-family="monospace">DID:key (who)</text>
              <text x="70" y="87" fill="#4b5563" font-size="9" text-anchor="middle" font-family="monospace">UCAN (permissions)</text>
            </g>

            <!-- Connection lines -->
            <line x1="220" y1="90" x2="280" y2="90" stroke="#374151" stroke-width="1.5"/>
            <line x1="420" y1="90" x2="480" y2="90" stroke="#374151" stroke-width="1.5"/>
            <line x1="620" y1="90" x2="680" y2="90" stroke="#374151" stroke-width="1.5"/>

            <!-- Scale layers -->
            <g transform="translate(0, 180)">
              <!-- Personal -->
              <rect x="80" y="0" width="200" height="50" rx="8" fill="#1e1e2e" stroke="#10b981" stroke-width="1.5"/>
              <circle cx="105" cy="25" r="8" fill="#10b981" opacity="0.3"/>
              <text x="125" y="22" fill="#6ee7b7" font-size="11" font-weight="600">Personal</text>
              <text x="125" y="36" fill="#6b7280" font-size="9">Notes, tasks, journals</text>

              <!-- Organization -->
              <rect x="300" y="0" width="200" height="50" rx="8" fill="#1e1e2e" stroke="#f59e0b" stroke-width="1.5"/>
              <circle cx="325" cy="25" r="8" fill="#f59e0b" opacity="0.3"/>
              <text x="345" y="22" fill="#fcd34d" font-size="11" font-weight="600">Organization</text>
              <text x="345" y="36" fill="#6b7280" font-size="9">Teams, workspaces, audit</text>

              <!-- Global -->
              <rect x="520" y="0" width="200" height="50" rx="8" fill="#1e1e2e" stroke="#4f46e5" stroke-width="1.5"/>
              <circle cx="545" cy="25" r="8" fill="#4f46e5" opacity="0.3"/>
              <text x="565" y="22" fill="#a5b4fc" font-size="11" font-weight="600">Global</text>
              <text x="565" y="36" fill="#6b7280" font-size="9">Search, social, datasets</text>

              <!-- Arrows -->
              <path d="M280 25 L300 25" stroke="#374151" stroke-width="1.5" marker-end="url(#arrowhead)"/>
              <path d="M500 25 L520 25" stroke="#374151" stroke-width="1.5" marker-end="url(#arrowhead)"/>
            </g>

            <!-- Arrow marker -->
            <defs>
              <marker id="arrowhead" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
                <polygon points="0 0, 10 3.5, 0 7" fill="#374151"/>
              </marker>
            </defs>

            <!-- Label -->
            <text x="400" y="270" fill="#6b7280" font-size="11" text-anchor="middle">Same primitives at every scale — no architectural changes needed</text>
          </svg>
        </div>

        <!-- Code Example -->
        <div class="mx-auto mt-12 max-w-2xl">
          <pre class="overflow-x-auto rounded-xl border border-border bg-[#0a0a0f] p-5 font-mono text-sm leading-relaxed text-gray-400"><code><span class="text-gray-500">// Define your own schema — types are inferred automatically</span>
<span class="text-indigo-400">import</span> {'{'} defineSchema, text, select, relation {'}'} <span class="text-indigo-400">from</span> <span class="text-emerald-400">'@xnet/data'</span>

<span class="text-indigo-400">const</span> RecipeSchema = <span class="text-yellow-300">defineSchema</span>({'{'}
  name: <span class="text-emerald-400">'Recipe'</span>,
  namespace: <span class="text-emerald-400">'xnet://did:key:z6Mk.../'</span>,  <span class="text-gray-500">// Your namespace</span>
  properties: {'{'}
    title: <span class="text-yellow-300">text</span>({'{'} required: <span class="text-orange-400">true</span> {'}'}),
    difficulty: <span class="text-yellow-300">select</span>({'{'} options: [<span class="text-emerald-400">'easy'</span>, <span class="text-emerald-400">'medium'</span>, <span class="text-emerald-400">'hard'</span>] {'}'}),
    ingredients: <span class="text-yellow-300">relation</span>({'{'} target: IngredientSchema, many: <span class="text-orange-400">true</span> {'}'})
  {'}'}
{'}'})</code></pre>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section id="features" class="mx-auto max-w-6xl px-6 py-20">
      <h2 class="text-3xl font-bold tracking-tight">Built Different</h2>
      <p class="mt-2 text-gray-400">Not another cloud app. Fundamentally new architecture.</p>
      <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-xl border border-border bg-surface p-6 transition-colors hover:border-indigo-500/40">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-emerald-500/10 text-emerald-400">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
          <h3 class="mt-4 text-lg font-semibold">Local-First</h3>
          <p class="mt-2 text-sm text-gray-400">
            Data lives on your device. Works offline, syncs when connected. Network is optional, not required.
          </p>
        </div>
        <div class="rounded-xl border border-border bg-surface p-6 transition-colors hover:border-indigo-500/40">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-blue-500/10 text-blue-400">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/></svg>
          </div>
          <h3 class="mt-4 text-lg font-semibold">True P2P</h3>
          <p class="mt-2 text-sm text-gray-400">
            Devices sync directly via WebRTC. No central server in the critical path. Your data never touches our servers.
          </p>
        </div>
        <div class="rounded-xl border border-border bg-surface p-6 transition-colors hover:border-indigo-500/40">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-pink-500/10 text-pink-400">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          </div>
          <h3 class="mt-4 text-lg font-semibold">Cryptographic Identity</h3>
          <p class="mt-2 text-sm text-gray-400">
            DID:key identities you control. UCAN tokens for delegatable permissions. No passwords, no central auth.
          </p>
        </div>
        <div class="rounded-xl border border-border bg-surface p-6 transition-colors hover:border-indigo-500/40">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-amber-500/10 text-amber-400">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"/></svg>
          </div>
          <h3 class="mt-4 text-lg font-semibold">Schema-First</h3>
          <p class="mt-2 text-sm text-gray-400">
            Define data with TypeScript. Types are inferred, not generated. Extend with your own schemas anytime.
          </p>
        </div>
        <div class="rounded-xl border border-border bg-surface p-6 transition-colors hover:border-indigo-500/40">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-indigo-500/10 text-indigo-400">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <h3 class="mt-4 text-lg font-semibold">Real-Time Collaboration</h3>
          <p class="mt-2 text-sm text-gray-400">
            Yjs CRDTs for rich text (character-level merge). Lamport clocks for structured data (field-level LWW).
          </p>
        </div>
        <div class="rounded-xl border border-border bg-surface p-6 transition-colors hover:border-indigo-500/40">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-purple-500/10 text-purple-400">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z"/></svg>
          </div>
          <h3 class="mt-4 text-lg font-semibold">Plugin Extensible</h3>
          <p class="mt-2 text-sm text-gray-400">
            Extend with custom schemas, views, and integrations. Build ERP modules, AI assistants, anything.
          </p>
        </div>
      </div>
    </section>

    <!-- React Hooks -->
    <section id="hooks" class="border-y border-border bg-surface/30 py-20">
      <div class="mx-auto max-w-6xl px-6">
        <h2 class="text-3xl font-bold tracking-tight">React Hooks</h2>
        <p class="mt-2 text-gray-400">Four hooks to build local-first apps. Real-time sync included.</p>

        <!-- Tabs -->
        <div class="mt-10" x-data="{ tab: 'query' }">
          <!-- Tab buttons -->
          <div class="flex flex-wrap gap-2 border-b border-border pb-4">
            <button
              class="hook-tab rounded-lg px-4 py-2 text-sm font-medium transition-colors"
              :class="tab === 'query' ? 'bg-indigo-600 text-white' : 'text-gray-400 hover:text-white hover:bg-surface'"
              @click="tab = 'query'"
            >
              useQuery
            </button>
            <button
              class="hook-tab rounded-lg px-4 py-2 text-sm font-medium transition-colors"
              :class="tab === 'mutate' ? 'bg-emerald-600 text-white' : 'text-gray-400 hover:text-white hover:bg-surface'"
              @click="tab = 'mutate'"
            >
              useMutate
            </button>
            <button
              class="hook-tab rounded-lg px-4 py-2 text-sm font-medium transition-colors"
              :class="tab === 'document' ? 'bg-amber-600 text-white' : 'text-gray-400 hover:text-white hover:bg-surface'"
              @click="tab = 'document'"
            >
              useDocument
            </button>
            <button
              class="hook-tab rounded-lg px-4 py-2 text-sm font-medium transition-colors"
              :class="tab === 'identity' ? 'bg-pink-600 text-white' : 'text-gray-400 hover:text-white hover:bg-surface'"
              @click="tab = 'identity'"
            >
              useIdentity
            </button>
          </div>

          <!-- Tab content -->
          <div class="mt-8 grid gap-8 lg:grid-cols-2">
            <!-- useQuery -->
            <template x-if="tab === 'query'">
              <div class="space-y-4">
                <div class="rounded-lg border border-indigo-500/30 bg-indigo-500/5 p-4">
                  <h3 class="font-semibold text-indigo-400">useQuery</h3>
                  <p class="mt-1 text-sm text-gray-400">Read nodes with real-time updates. Filter, sort, paginate.</p>
                </div>
                <ul class="space-y-2 text-sm text-gray-400">
                  <li class="flex items-start gap-2">
                    <span class="mt-1 text-indigo-400">&#10003;</span>
                    <span>List all nodes of a schema</span>
                  </li>
                  <li class="flex items-start gap-2">
                    <span class="mt-1 text-indigo-400">&#10003;</span>
                    <span>Get single node by ID</span>
                  </li>
                  <li class="flex items-start gap-2">
                    <span class="mt-1 text-indigo-400">&#10003;</span>
                    <span>Filter with where clauses</span>
                  </li>
                  <li class="flex items-start gap-2">
                    <span class="mt-1 text-indigo-400">&#10003;</span>
                    <span>Auto-updates when data changes</span>
                  </li>
                </ul>
              </div>
            </template>
            <template x-if="tab === 'query'">
              <div>
                <pre class="overflow-x-auto rounded-xl border border-border bg-[#0a0a0f] p-5 font-mono text-sm leading-relaxed text-gray-400"><code><span class="text-indigo-400">import</span> {'{'} useQuery {'}'} <span class="text-indigo-400">from</span> <span class="text-emerald-400">'@xnet/react'</span>

<span class="text-indigo-400">function</span> <span class="text-yellow-300">TaskList</span>() {'{'}
  <span class="text-gray-500">// List all tasks</span>
  <span class="text-indigo-400">const</span> {'{'} data: tasks, loading {'}'} = <span class="text-yellow-300">useQuery</span>(TaskSchema)

  <span class="text-gray-500">// Or filter</span>
  <span class="text-indigo-400">const</span> {'{'} data: done {'}'} = <span class="text-yellow-300">useQuery</span>(TaskSchema, {'{'}
    where: {'{'} status: <span class="text-emerald-400">'done'</span> {'}'},
    orderBy: {'{'} updatedAt: <span class="text-emerald-400">'desc'</span> {'}'},
    limit: <span class="text-orange-400">20</span>
  {'}'})

