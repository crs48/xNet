---
import Base from '../layouts/Base.astro'
import Nav from '../components/sections/Nav.astro'
import Hero from '../components/sections/Hero.astro'
import WhatIsXNet from '../components/sections/WhatIsXNet.astro'
import TheApp from '../components/sections/TheApp.astro'
import ForDevelopers from '../components/sections/ForDevelopers.astro'
import UnderTheHood from '../components/sections/UnderTheHood.astro'
import Hubs from '../components/sections/Hubs.astro'
import TheVision from '../components/sections/TheVision.astro'
import Landscape from '../components/sections/Landscape.astro'
import Roadmap from '../components/sections/Roadmap.astro'
import Community from '../components/sections/Community.astro'
import GetStarted from '../components/sections/GetStarted.astro'
import Footer from '../components/sections/Footer.astro'
---

<Base
  title="xNet — Your data. Your devices. Your rules."
  description="xNet is a local-first platform for apps that work offline, sync peer-to-peer, and keep your data under your control. Build with React hooks or try the productivity app."
>
  <Nav />

  <main>
    <Hero />
    <WhatIsXNet />
    <TheApp />
    <ForDevelopers />
    <UnderTheHood />
    <Hubs />
    <TheVision />
    <Landscape />
    <Roadmap />
    <Community />
    <GetStarted />
  </main>

  <Footer />
</Base>
