---
import Base from '../layouts/Base.astro'
import Nav from '../components/sections/Nav.astro'
import Hero from '../components/sections/Hero.astro'
import TheApp from '../components/sections/TheApp.astro'
import ForDevelopers from '../components/sections/ForDevelopers.astro'
import BuiltForAgents from '../components/sections/BuiltForAgents.astro'
import NoBlackBoxes from '../components/sections/NoBlackBoxes.astro'
import HumaneByDesign from '../components/sections/HumaneByDesign.astro'
import GetStarted from '../components/sections/GetStarted.astro'
import Footer from '../components/sections/Footer.astro'
---

<Base
  title="xNet — Your data. Your devices. Your rules."
  description="xNet is a local-first platform for apps that work offline, sync peer-to-peer, and keep your data under your control. Build from any framework with your own backend, or try the productivity app."
>
  <Nav />

  <main>
    <Hero />
    <TheApp />
    <ForDevelopers />
    <BuiltForAgents />
    <NoBlackBoxes />
    <HumaneByDesign />
    <GetStarted />
  </main>

  <Footer />
</Base>
