---
import Base from '../layouts/Base.astro'
import Nav from '../components/sections/Nav.astro'
import Footer from '../components/sections/Footer.astro'

// GitHub repo for release lookups (build-time fetch)
const REPO = 'crs48/xNet'
let version = '0.0.1'
let assets: { name: string; browser_download_url: string }[] = []

try {
  const res = await fetch(`https://api.github.com/repos/${REPO}/releases/latest`, {
    headers: { Accept: 'application/vnd.github.v3+json' }
  })
  if (res.ok) {
    const release = await res.json()
    version = (release.tag_name ?? 'v0.0.1').replace(/^v/, '')
    assets = release.assets ?? []
  }
} catch {
  // Build continues with defaults if GitHub API is unavailable
}

function downloadUrl(pattern: string): string {
  const asset = assets.find((a) => a.name.includes(pattern))
  return asset?.browser_download_url ?? `https://github.com/${REPO}/releases/latest`
}
---

<Base
  title="Download xNet — Desktop App for macOS, Windows, and Linux"
  description="Download xNet for your platform. Available for macOS (Apple Silicon & Intel), Windows, and Linux."
>
  <Nav />

  <main class="relative min-h-screen pt-32 pb-24">
    <!-- Subtle gradient background -->
    <div class="absolute inset-0 bg-gradient-to-b from-indigo-500/[0.03] via-transparent to-transparent"></div>
    <div class="absolute left-1/2 top-0 -translate-x-1/2 h-[400px] w-[600px] rounded-full bg-indigo-500/[0.05] blur-[100px]"></div>

    <div class="relative mx-auto max-w-5xl px-6">
      <!-- Header -->
      <div class="mb-16 text-center">
        <h1 class="mb-4 text-4xl font-bold tracking-tight sm:text-5xl">
          <span class="bg-gradient-to-br from-gray-900 via-gray-700 to-indigo-600 dark:from-white dark:via-gray-100 dark:to-indigo-400 bg-clip-text text-transparent">
            Download xNet
          </span>
        </h1>
        <p class="text-lg text-gray-500 dark:text-gray-400">
          Version <span class="inline-flex items-center gap-1.5 rounded-full bg-indigo-500/10 px-3 py-0.5 font-mono text-sm text-indigo-600 dark:text-indigo-400">{version}</span>
        </p>
      </div>

      <!-- Platform cards -->
      <div class="mb-16 grid gap-6 sm:grid-cols-3">
        <!-- macOS -->
        <div
          class="platform-card group relative flex flex-col items-center rounded-2xl border border-gray-200 dark:border-gray-800 bg-white/50 dark:bg-gray-900/50 backdrop-blur-sm p-8 text-center transition-all hover:border-gray-300 dark:hover:border-gray-700 hover:shadow-lg hover:shadow-gray-200/50 dark:hover:shadow-black/20"
          data-platform="mac"
        >
          <!-- Platform icon -->
          <div class="mb-5 flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-gray-100 to-gray-200 dark:from-gray-800 dark:to-gray-900 shadow-sm">
            <svg class="h-8 w-8 text-gray-700 dark:text-gray-300" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11" />
            </svg>
          </div>
          <h3 class="mb-5 text-xl font-semibold text-gray-900 dark:text-white">macOS</h3>
          <div class="flex w-full flex-col gap-3">
            <a
              href={downloadUrl('arm64.dmg')}
              class="inline-flex items-center justify-center gap-2 rounded-xl bg-gray-900 dark:bg-white px-5 py-3 text-sm font-medium text-white dark:text-gray-900 transition-all hover:bg-gray-800 dark:hover:bg-gray-100 hover:scale-[1.02] active:scale-[0.98]"
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
              </svg>
              Apple Silicon
            </a>
            <a
              href={downloadUrl('x64.dmg')}
              class="inline-flex items-center justify-center gap-2 rounded-xl border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 px-5 py-3 text-sm font-medium text-gray-700 dark:text-gray-300 transition-all hover:border-gray-400 dark:hover:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-700 hover:scale-[1.02] active:scale-[0.98]"
            >
              Intel
            </a>
          </div>
          <p class="mt-5 text-xs text-gray-500 dark:text-gray-500">macOS 11 Big Sur or later</p>
        </div>

        <!-- Windows -->
        <div
          class="platform-card group relative flex flex-col items-center rounded-2xl border border-gray-200 dark:border-gray-800 bg-white/50 dark:bg-gray-900/50 backdrop-blur-sm p-8 text-center transition-all hover:border-gray-300 dark:hover:border-gray-700 hover:shadow-lg hover:shadow-gray-200/50 dark:hover:shadow-black/20"
          data-platform="windows"
        >
          <!-- Platform icon -->
          <div class="mb-5 flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-blue-100 to-blue-200 dark:from-blue-900/50 dark:to-blue-800/50 shadow-sm">
            <svg class="h-8 w-8 text-blue-600 dark:text-blue-400" viewBox="0 0 24 24" fill="currentColor">
              <path d="M3 12V6.75l6-1.32v6.48L3 12zm17-9v8.75l-10 .08V5.21L20 3zM3 13l6 .09v6.81l-6-1.15V13zm17 .25V22l-10-1.91V13.1l10 .15z" />
            </svg>
          </div>
          <h3 class="mb-5 text-xl font-semibold text-gray-900 dark:text-white">Windows</h3>
          <div class="flex w-full flex-col gap-3">
            <a
              href={downloadUrl('Setup.exe')}
              class="inline-flex items-center justify-center gap-2 rounded-xl bg-blue-600 px-5 py-3 text-sm font-medium text-white transition-all hover:bg-blue-700 hover:scale-[1.02] active:scale-[0.98]"
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
              </svg>
              Download Installer
            </a>
          </div>
          <p class="mt-5 text-xs text-gray-500 dark:text-gray-500">Windows 10 or later (64-bit)</p>
        </div>

        <!-- Linux -->
        <div
          class="platform-card group relative flex flex-col items-center rounded-2xl border border-gray-200 dark:border-gray-800 bg-white/50 dark:bg-gray-900/50 backdrop-blur-sm p-8 text-center transition-all hover:border-gray-300 dark:hover:border-gray-700 hover:shadow-lg hover:shadow-gray-200/50 dark:hover:shadow-black/20"
          data-platform="linux"
        >
          <!-- Platform icon -->
          <div class="mb-5 flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-orange-100 to-orange-200 dark:from-orange-900/50 dark:to-orange-800/50 shadow-sm">
            <svg class="h-8 w-8 text-orange-600 dark:text-orange-400" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12.504 0c-.155 0-.315.008-.48.021-4.226.333-3.105 4.807-3.17 6.298-.076 1.092-.3 1.953-1.05 3.02-.885 1.051-2.127 2.75-2.716 4.521-.278.832-.41 1.684-.287 2.489a11.966 11.966 0 0 0-2.517 2.453c-1.533 2.023-.156 3.472 1.325 3.472.558 0 1.174-.218 1.76-.574a10.648 10.648 0 0 0 3.71 1.112c.17.018.339.028.507.028 2.012 0 3.426-1.236 4.414-1.236.986 0 2.4 1.236 4.414 1.236.168 0 .337-.01.506-.028a10.648 10.648 0 0 0 3.71-1.112c.587.356 1.203.574 1.76.574 1.482 0 2.859-1.449 1.326-3.472a11.966 11.966 0 0 0-2.517-2.453c.123-.805-.009-1.657-.287-2.489-.589-1.771-1.831-3.47-2.716-4.521-.75-1.067-.974-1.928-1.05-3.02-.065-1.491 1.056-5.965-3.17-6.298A5.11 5.11 0 0 0 12.504 0z" />
            </svg>
          </div>
          <h3 class="mb-5 text-xl font-semibold text-gray-900 dark:text-white">Linux</h3>
          <div class="flex w-full flex-col gap-3">
            <a
              href={downloadUrl('.AppImage')}
              class="inline-flex items-center justify-center gap-2 rounded-xl bg-orange-600 px-5 py-3 text-sm font-medium text-white transition-all hover:bg-orange-700 hover:scale-[1.02] active:scale-[0.98]"
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
              </svg>
              AppImage
            </a>
            <a
              href={downloadUrl('.deb')}
              class="inline-flex items-center justify-center gap-2 rounded-xl border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 px-5 py-3 text-sm font-medium text-gray-700 dark:text-gray-300 transition-all hover:border-gray-400 dark:hover:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-700 hover:scale-[1.02] active:scale-[0.98]"
            >
              .deb (Debian/Ubuntu)
            </a>
          </div>
          <p class="mt-5 text-xs text-gray-500 dark:text-gray-500">x64 or ARM64</p>
        </div>
      </div>

      <!-- Other options -->
      <div class="rounded-2xl border border-gray-200 dark:border-gray-800 bg-white/50 dark:bg-gray-900/50 backdrop-blur-sm p-8">
        <div class="flex items-center gap-3 mb-6">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gray-100 dark:bg-gray-800">
            <svg class="h-5 w-5 text-gray-600 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Other Options</h3>
        </div>
        
        <div class="grid gap-4 sm:grid-cols-3">
          <a
            href="/app"
            class="group flex items-start gap-3 rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 p-4 transition-all hover:border-emerald-300 dark:hover:border-emerald-700 hover:shadow-md"
          >
            <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-emerald-100 dark:bg-emerald-900/50 text-emerald-600 dark:text-emerald-400">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9" />
              </svg>
            </div>
            <div>
              <p class="font-medium text-gray-900 dark:text-white group-hover:text-emerald-600 dark:group-hover:text-emerald-400 transition-colors">Use in Browser</p>
              <p class="mt-0.5 text-sm text-gray-500 dark:text-gray-400">No download, passkey auth</p>
            </div>
          </a>

          <a
            href="https://github.com/crs48/xNet"
            class="group flex items-start gap-3 rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 p-4 transition-all hover:border-gray-400 dark:hover:border-gray-600 hover:shadow-md"
          >
            <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400">
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
              </svg>
            </div>
            <div>
              <p class="font-medium text-gray-900 dark:text-white transition-colors">Build from Source</p>
              <p class="mt-0.5 text-sm text-gray-500 dark:text-gray-400">For developers</p>
            </div>
          </a>

          <a
            href="/docs/guides/electron"
            class="group flex items-start gap-3 rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 p-4 transition-all hover:border-indigo-300 dark:hover:border-indigo-700 hover:shadow-md"
          >
            <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-indigo-100 dark:bg-indigo-900/50 text-indigo-600 dark:text-indigo-400">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
              </svg>
            </div>
            <div>
              <p class="font-medium text-gray-900 dark:text-white group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">Documentation</p>
              <p class="mt-0.5 text-sm text-gray-500 dark:text-gray-400">Electron guide</p>
            </div>
          </a>
        </div>
      </div>

      <!-- Security note -->
      <div class="mt-8 flex items-start gap-3 rounded-xl bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 p-4">
        <svg class="h-5 w-5 shrink-0 text-blue-600 dark:text-blue-400 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
        <div>
          <p class="text-sm font-medium text-blue-900 dark:text-blue-100">Secure & Open Source</p>
          <p class="mt-1 text-sm text-blue-700 dark:text-blue-300">
            xNet is open source and all releases are built via GitHub Actions. 
            <a href="https://github.com/crs48/xNet/releases" class="underline hover:no-underline">View release assets and checksums</a>.
          </p>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Base>

<style>
  /* Detected platform highlight */
  .platform-card.detected {
    @apply border-indigo-400 dark:border-indigo-500 ring-2 ring-indigo-400/20 dark:ring-indigo-500/20;
  }
  .platform-card.detected::before {
    content: 'Detected';
    @apply absolute -top-2.5 left-1/2 -translate-x-1/2 rounded-full bg-indigo-500 px-2.5 py-0.5 text-[10px] font-semibold uppercase tracking-wider text-white;
  }
</style>

<script>
  // Auto-detect platform and highlight it
  const ua = navigator.userAgent.toLowerCase()
  let detected = 'mac'
  if (ua.includes('win')) detected = 'windows'
  else if (ua.includes('linux')) detected = 'linux'

  const card = document.querySelector(`[data-platform="${detected}"]`)
  if (card) {
    card.classList.add('detected')
  }
</script>
