---
import { readFileSync } from 'node:fs'
import { Code } from 'astro:components'
import Base from '../layouts/Base.astro'
import Nav from '../components/sections/Nav.astro'
import Footer from '../components/sections/Footer.astro'
import SectionHeader from '../components/ui/SectionHeader.astro'

// Live multiplayer demos (exploration 0314). The demo app itself is deployed
// at /play/ on this same GitHub Pages tree (apps/demos in the repo); this
// page frames it: two iframes share one room so you SEE sync happen without
// opening a second window — the Liveblocks paired-iframe trick.

// The code listing is the REAL starter, read at build time so it can never
// drift from what `npm install` actually gets (examples/minimal-app is
// smoke-tested against the published packages).
const todoSource = readFileSync(
  new URL('../../../examples/minimal-app/src/main.tsx', import.meta.url),
  'utf8'
).trimEnd()

const demos = [
  {
    href: '/play/#/cursors',
    title: 'Cursor party',
    blurb: 'Live cursors and emoji bursts. Ephemeral presence — nothing is ever persisted.',
  },
  {
    href: '/play/#/connect-four',
    title: 'Connect Four',
    blurb:
      'Every move is a signed, hash-chained log entry; the board is a deterministic fold. Cheat-evident game history for free.',
  },
  {
    href: '/play/#/todo',
    title: 'Collab todo',
    blurb: 'The classic — optimistic local-first writes, live everywhere. ~40 lines of app code.',
  },
]
---

<Base
  title="Live demos — xNet"
  description="Multiplayer demos built on xNet: live cursors, a signed-move-log Connect Four, and a collaborative todo. Open a demo, share the URL, play together."
>
  <Nav />
  <main class="mx-auto max-w-6xl px-6">
    <section class="py-16 sm:py-24 text-center">
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-gray-900 dark:text-white">
        Watch it sync
      </h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-600 dark:text-gray-400">
        Two copies of the same app, one shared room, no accounts. What you change on the left
        arrives on the right through a real sync hub — signed, local-first, live. Every demo URL
        is an invitation: copy it and someone else is in your room.
      </p>
    </section>

    <section class="pb-16">
      <div class="grid gap-4 md:grid-cols-2" id="paired-frames">
        <div class="overflow-hidden rounded-xl border border-border bg-surface shadow-sm">
          <div class="border-b border-border px-4 py-2 text-xs text-gray-500">player one</div>
          <iframe
            data-demo-frame
            title="Collab todo — player one"
            class="h-[420px] w-full"
            loading="lazy"></iframe>
        </div>
        <div class="overflow-hidden rounded-xl border border-border bg-surface shadow-sm">
          <div class="border-b border-border px-4 py-2 text-xs text-gray-500">player two</div>
          <iframe
            data-demo-frame
            title="Collab todo — player two"
            class="h-[420px] w-full"
            loading="lazy"></iframe>
        </div>
      </div>
      <p class="mt-3 text-center text-sm text-gray-500">
        Both frames run <a class="text-indigo-600 dark:text-indigo-400 hover:underline" href="/play/">the same app</a>
        in a room minted just for you. Rooms live on the public demo hub — a quota'd sandbox,
        periodically evicted.
      </p>
      <p class="mt-1 text-center text-sm text-gray-500">
        Spot the wrench in each frame's corner — that's the real
        <a class="text-indigo-600 dark:text-indigo-400 hover:underline" href="/docs/guides/devtools/">xNet DevTools</a>.
        Open it (or press <kbd class="rounded border border-border bg-surface px-1 text-xs">Ctrl/⌘⇧D</kbd>)
        to watch the data, change log, and sync frames live while you play.
      </p>
    </section>

    <section class="pb-16">
      <SectionHeader
        title="This is the whole app"
        subtitle="One file: two schemas with one-line authorization, an instant identity, a provider, a live query, optimistic writes, and ephemeral cursors. No backend code, no API routes, no cache to invalidate."
        align="center"
      />
      <div class="mt-8 overflow-hidden rounded-xl border border-border bg-code-bg shadow-sm">
        <div class="flex items-center justify-between gap-4 border-b border-border bg-surface/50 px-4 py-2">
          <span class="flex items-center gap-3 truncate">
            <span class="flex items-center gap-1.5" aria-hidden="true">
              <span class="h-2.5 w-2.5 rounded-full bg-[#ff5f57]"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-[#febc2e]"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-[#28c840]"></span>
            </span>
            <span class="truncate font-mono text-xs text-gray-500">examples/minimal-app/src/main.tsx</span>
          </span>
          <a
            class="shrink-0 text-xs font-medium text-indigo-600 dark:text-indigo-400 hover:underline"
            href="https://github.com/crs48/xNet/tree/main/examples/minimal-app"
          >
            Copy the starter →
          </a>
        </div>
        <div class="demo-code text-[13px] leading-relaxed">
          <Code
            code={todoSource}
            lang="tsx"
            themes={{ light: 'one-light', dark: 'one-dark-pro' }}
          />
        </div>
      </div>
      <p class="mt-3 text-center text-sm text-gray-500">
        The frames above run this app with a coat of paint — same schemas, same hooks. Cursors ride
        the ephemeral presence lane (never persisted); todos are signed, local-first writes that
        sync through the hub.
      </p>
    </section>

    <section class="pb-16">
      <SectionHeader
        title="Three demos, three sync lanes"
        subtitle="Each demo deliberately rides a different xNet channel — ephemeral presence, the signed change log, and structured live queries."
        align="center"
      />
      <div class="mt-8 grid gap-4 sm:grid-cols-3">
        {
          demos.map((demo) => (
            <a
              href={demo.href}
              class="group rounded-xl border border-border bg-surface p-5 transition-all hover:border-indigo-500/50 hover:shadow-md"
            >
              <h3 class="font-semibold text-gray-900 dark:text-white group-hover:text-indigo-600 dark:group-hover:text-indigo-400">
                {demo.title} →
              </h3>
              <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">{demo.blurb}</p>
            </a>
          ))
        }
      </div>
    </section>

    <section class="pb-24">
      <div class="rounded-xl border border-border bg-surface p-6 sm:p-8">
        <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Build one yourself</h2>
        <p class="mt-2 max-w-2xl text-gray-600 dark:text-gray-400">
          The collab todo is a single file. Copy
          <a
            class="text-indigo-600 dark:text-indigo-400 hover:underline"
            href="https://github.com/crs48/xNet/tree/main/examples/minimal-app">examples/minimal-app</a
          >, run <code class="rounded bg-gray-100 dark:bg-gray-800 px-1.5 py-0.5 text-sm">npm install && npm run dev</code>,
          and you have a synced multiplayer app — instant identity, typed schemas, live queries,
          no backend code. Then read the
          <a class="text-indigo-600 dark:text-indigo-400 hover:underline" href="/react">React guide</a>
          for the full hook surface.
        </p>
      </div>
    </section>
  </main>
  <Footer />

  <script>
    // Mint a per-visitor room so the paired frames share state with each
    // other but not with every other visitor of this page.
    const room = `site-${Math.random().toString(36).slice(2, 8)}`
    document.querySelectorAll<HTMLIFrameElement>('[data-demo-frame]').forEach((frame) => {
      frame.src = `/play/#/todo/${room}`
    })
  </script>

  <style is:global>
    /* Dual-theme Shiki (one-light / one-dark-pro — the same palettes the
       landing page's code blocks use). Shiki emits the light colors inline
       plus --shiki-dark variables; the site toggles dark via a `.dark`
       class on <html> (tailwind darkMode: 'class'), so activate the dark
       variables under it. */
    .demo-code .astro-code {
      margin: 0;
      padding: 1rem 1.25rem;
      overflow-x: auto;
      background-color: var(--lp-code-bg) !important;
    }
    .dark .demo-code .astro-code,
    .dark .demo-code .astro-code span {
      color: var(--shiki-dark) !important;
    }
  </style>
</Base>
