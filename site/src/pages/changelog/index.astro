---
import Base from '../../layouts/Base.astro'
import Nav from '../../components/sections/Nav.astro'
import Footer from '../../components/sections/Footer.astro'
import Gallery from '../../components/changelog/Gallery.astro'
import { entries, updated } from '../../data/changelog'
import { loadPrGallery } from '../../lib/changelog-gallery'

const repo = 'https://github.com/crs48/xNet'
const editUrl = `${repo}/blob/main/site/src/data/changelog.ts`

const tagColor: Record<string, string> = {
  app: 'bg-emerald-500/15 text-emerald-700 dark:text-emerald-300',
  crm: 'bg-sky-500/15 text-sky-700 dark:text-sky-300',
  finance: 'bg-green-500/15 text-green-700 dark:text-green-300',
  tasks: 'bg-amber-500/15 text-amber-700 dark:text-amber-300',
  ai: 'bg-violet-500/15 text-violet-700 dark:text-violet-300',
  plugins: 'bg-indigo-500/15 text-indigo-700 dark:text-indigo-300',
  editor: 'bg-fuchsia-500/15 text-fuchsia-700 dark:text-fuchsia-300',
  sync: 'bg-cyan-500/15 text-cyan-700 dark:text-cyan-300',
  identity: 'bg-rose-500/15 text-rose-700 dark:text-rose-300',
  platform: 'bg-purple-500/15 text-purple-700 dark:text-purple-300',
  performance: 'bg-orange-500/15 text-orange-700 dark:text-orange-300',
  devtools: 'bg-slate-500/15 text-slate-700 dark:text-slate-300',
  ci: 'bg-teal-500/15 text-teal-700 dark:text-teal-300'
}

// Tags actually used, in the colour-map's order — drives the filter chips.
const usedTags = Object.keys(tagColor).filter((t) => entries.some((e) => e.tags.includes(t as never)))

// Resolve each entry's auto-gallery from its PR's durable diff manifest at
// build time (exploration 0196). Build-time, fail-open: a 404 / offline fetch
// yields null and the entry falls back to its curated hero/images.
const galleries = await Promise.all(entries.map((e) => (e.pr ? loadPrGallery(e.pr) : null)))

// Normalise per-entry media once, so the template stays declarative.
const view = entries.map((entry, i) => {
  const gallery = galleries[i]
  const comparisons = (gallery?.images ?? [])
    .filter((im) => im.before)
    .map((im) => ({ before: im.before as string, after: im.src, alt: im.alt }))
  const autoThumbs = (gallery?.images ?? [])
    .filter((im) => !im.before)
    .map((im) => ({ src: im.src, alt: im.alt }))
  const curatedThumbs = (entry.images ?? []).map((im) => ({
    src: im.src,
    alt: im.alt,
    caption: im.caption
  }))
  const thumbs = [...autoThumbs, ...curatedThumbs]
  const video = entry.video
    ? { mp4: entry.video.src, poster: entry.video.poster, alt: entry.video.alt }
    : gallery?.videos?.[0]
  const galleryLink =
    gallery && entry.pr ? { prUrl: gallery.prUrl, count: gallery.count, pr: entry.pr } : undefined
  const dataText = [entry.title, entry.summary, ...entry.highlights].join(' ').toLowerCase()
  return { entry, comparisons, thumbs, video, galleryLink, dataText }
})
---

<Base
  title="xNet Changelog — What's New"
  description={`Everything that's shipped in xNet, newest first. ${entries.length} releases, updated ${updated}. Subscribe via RSS or the JSON feed.`}
>
  <Nav />

  <main class="py-24 lg:py-32">
    <div class="mx-auto max-w-3xl px-6">
      <!-- Hero -->
      <div class="mb-10 text-center">
        <h1 class="mb-4 text-4xl font-bold text-gray-800 dark:text-white sm:text-5xl">What's New</h1>
        <p class="mx-auto max-w-xl text-lg leading-relaxed text-gray-500 dark:text-gray-400">
          Everything that's shipped in xNet, newest first.
        </p>
        <div class="mt-5 flex items-center justify-center gap-4 text-sm">
          <a href="/changelog.xml" class="text-indigo-400 hover:underline">RSS</a>
          <span class="text-gray-300 dark:text-gray-600">·</span>
          <a href="/changelog.json" class="text-indigo-400 hover:underline">JSON feed</a>
          <span class="text-gray-300 dark:text-gray-600">·</span>
          <a href={editUrl} target="_blank" rel="noopener noreferrer" class="text-indigo-400 hover:underline">Edit on GitHub</a>
        </div>
      </div>

      <!-- Controls: search + tag filter -->
      <div class="mb-10 space-y-3">
        <input
          id="cl-search"
          type="search"
          placeholder="Search the changelog…"
          aria-label="Search the changelog"
          class="w-full rounded-lg border border-border bg-surface/40 px-4 py-2 text-sm text-gray-700 placeholder:text-gray-400 focus:border-indigo-500/50 focus:outline-none dark:text-gray-200"
        />
        <div id="cl-filters" role="group" aria-label="Filter by category" class="flex flex-wrap gap-1.5">
          <button type="button" class="cl-filter" data-tag="all" aria-pressed="true">All</button>
          {usedTags.map((tag) => (
            <button type="button" class="cl-filter" data-tag={tag} aria-pressed="false">{tag}</button>
          ))}
        </div>
        <p id="cl-empty" hidden class="text-center text-sm text-gray-400">No entries match.</p>
      </div>

      <!-- Timeline -->
      <div class="relative">
        <div class="absolute left-2 top-2 bottom-2 w-px bg-gradient-to-b from-emerald-500/40 via-indigo-500/25 to-transparent"></div>

        <div class="space-y-12">
          {view.map(({ entry, comparisons, thumbs, video, galleryLink, dataText }, i) => (
            <article
              id={entry.id}
              class="cl-entry animate-on-scroll relative pl-10 scroll-mt-24"
              data-tags={entry.tags.join(' ')}
              data-text={dataText}
            >
              <div class="absolute left-0 top-1.5 h-[17px] w-[17px] rounded-full bg-indigo-400 ring-4 ring-white dark:ring-[#0a0a0f]"></div>

              <div class="mb-2 flex flex-wrap items-center gap-x-3 gap-y-1">
                <time class="text-xs font-semibold uppercase tracking-wider text-gray-400 dark:text-gray-500">{entry.date}</time>
                {entry.pr && (
                  <a
                    href={`${repo}/pull/${entry.pr}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-xs text-gray-400 hover:text-indigo-400 hover:underline"
                  >#{entry.pr}</a>
                )}
                {entry.author && (
                  <a
                    href={`https://github.com/${entry.author.login}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center gap-1.5 text-xs text-gray-400 hover:text-indigo-400"
                    title={`By ${entry.author.name ?? entry.author.login}`}
                  >
                    <img
                      src={`https://github.com/${entry.author.login}.png?size=40`}
                      alt=""
                      width="18"
                      height="18"
                      loading="lazy"
                      class="rounded-full"
                    />
                    {entry.author.name ?? entry.author.login}
                  </a>
                )}
              </div>

              <h2 class="group mb-2 flex items-center gap-2 text-2xl font-bold text-gray-900 dark:text-white">
                <a href={`#${entry.id}`} class="hover:text-indigo-400">{entry.title}</a>
                <button
                  type="button"
                  class="cl-copy opacity-0 transition-opacity group-hover:opacity-100 focus:opacity-100"
                  data-anchor={entry.id}
                  aria-label="Copy link to this entry"
                  title="Copy link"
                >
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" /></svg>
                </button>
              </h2>

              <p class="mb-4 text-gray-600 dark:text-gray-300">{entry.summary}</p>

              {entry.hero && (
                <img
                  src={entry.hero.src}
                  alt={entry.hero.alt}
                  loading={i === 0 ? 'eager' : 'lazy'}
                  fetchpriority={i === 0 ? 'high' : undefined}
                  class="mb-4 w-full rounded-xl border border-border"
                />
              )}

              <Gallery
                entryId={entry.id}
                comparisons={comparisons}
                thumbs={thumbs}
                video={video}
                galleryLink={galleryLink}
              />

              <ul class="mb-4 grid gap-1.5">
                {entry.highlights.map((h) => (
                  <li class="flex items-start gap-2 text-sm text-gray-600 dark:text-gray-300">
                    <svg class="mt-0.5 h-4 w-4 shrink-0 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    <span>{h}</span>
                  </li>
                ))}
              </ul>

              <div class="flex flex-wrap gap-1.5">
                {entry.tags.map((tag) => (
                  <span class={`rounded-full px-2 py-0.5 text-xs font-medium ${tagColor[tag] ?? 'bg-gray-500/15 text-gray-600 dark:text-gray-300'}`}>{tag}</span>
                ))}
              </div>
            </article>
          ))}
        </div>
      </div>

      <p class="mt-16 text-center text-xs text-gray-400 dark:text-gray-500">Updated {updated}</p>
    </div>
  </main>

  <Footer />

  <!-- Lightbox (single, reused) -->
  <dialog id="cl-lightbox" class="cl-lightbox" aria-label="Screenshot viewer">
    <button type="button" class="cl-lb-close" data-lb="close" aria-label="Close">✕</button>
    <button type="button" class="cl-lb-nav cl-lb-prev" data-lb="prev" aria-label="Previous">‹</button>
    <img class="cl-lb-img" alt="" />
    <button type="button" class="cl-lb-nav cl-lb-next" data-lb="next" aria-label="Next">›</button>
    <p class="cl-lb-cap" aria-live="polite"></p>
  </dialog>
</Base>

<style>
  /* Filter chips */
  .cl-filter {
    border: 1px solid var(--lp-border);
    border-radius: 9999px;
    padding: 0.15rem 0.7rem;
    font-size: 0.75rem;
    color: #6b7280;
    background: transparent;
    cursor: pointer;
    transition: all 0.15s;
  }
  .cl-filter:hover {
    color: #4f46e5;
  }
  .cl-filter[aria-pressed='true'] {
    background: #4f46e5;
    border-color: #4f46e5;
    color: #fff;
  }
  .cl-copy {
    color: #9ca3af;
    background: transparent;
    border: none;
    cursor: pointer;
  }
  .cl-copy:hover {
    color: #4f46e5;
  }
  .cl-copy.copied {
    color: #10b981;
  }

  /* Lightbox */
  .cl-lightbox {
    border: none;
    background: transparent;
    max-width: 100vw;
    max-height: 100vh;
    width: 100%;
    height: 100%;
    padding: 0;
  }
  .cl-lightbox::backdrop {
    background: rgba(0, 0, 0, 0.85);
  }
  .cl-lb-img {
    position: absolute;
    inset: 5% 8%;
    margin: auto;
    max-width: 84%;
    max-height: 84%;
    object-fit: contain;
    border-radius: 0.5rem;
  }
  .cl-lb-close,
  .cl-lb-nav {
    position: absolute;
    z-index: 1;
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
    border: none;
    cursor: pointer;
    border-radius: 9999px;
  }
  .cl-lb-close {
    top: 1rem;
    right: 1rem;
    width: 2.25rem;
    height: 2.25rem;
    font-size: 1rem;
  }
  .cl-lb-nav {
    top: 50%;
    transform: translateY(-50%);
    width: 2.75rem;
    height: 2.75rem;
    font-size: 1.75rem;
    line-height: 1;
  }
  .cl-lb-prev {
    left: 1rem;
  }
  .cl-lb-next {
    right: 1rem;
  }
  .cl-lb-close:hover,
  .cl-lb-nav:hover {
    background: rgba(255, 255, 255, 0.25);
  }
  .cl-lb-cap {
    position: absolute;
    bottom: 1.25rem;
    left: 0;
    right: 0;
    text-align: center;
    color: #e5e7eb;
    font-size: 0.85rem;
  }
</style>

<script>
  // ── Tag filter + search ────────────────────────────────────────────────
  const search = document.getElementById('cl-search') as HTMLInputElement | null
  const filterRow = document.getElementById('cl-filters')
  const empty = document.getElementById('cl-empty')
  const articles = Array.from(document.querySelectorAll<HTMLElement>('article.cl-entry'))
  let activeTag = 'all'

  function apply() {
    const q = (search?.value ?? '').trim().toLowerCase()
    let shown = 0
    for (const a of articles) {
      const tags = (a.dataset.tags ?? '').split(' ')
      const text = a.dataset.text ?? ''
      const matchTag = activeTag === 'all' || tags.includes(activeTag)
      const matchText = q === '' || text.includes(q)
      const show = matchTag && matchText
      a.hidden = !show
      if (show) shown++
    }
    if (empty) empty.hidden = shown > 0
  }

  filterRow?.querySelectorAll<HTMLButtonElement>('.cl-filter').forEach((chip) => {
    chip.addEventListener('click', () => {
      activeTag = chip.dataset.tag ?? 'all'
      filterRow.querySelectorAll('.cl-filter').forEach((c) => c.setAttribute('aria-pressed', 'false'))
      chip.setAttribute('aria-pressed', 'true')
      const url = new URL(location.href)
      if (activeTag === 'all') url.searchParams.delete('tag')
      else url.searchParams.set('tag', activeTag)
      history.replaceState(null, '', url)
      apply()
    })
  })
  search?.addEventListener('input', apply)

  // Pre-activate a tag from ?tag= on load (shareable filtered views).
  const initial = new URLSearchParams(location.search).get('tag')
  if (initial) {
    const chip = filterRow?.querySelector<HTMLButtonElement>(`.cl-filter[data-tag="${initial}"]`)
    chip?.click()
  }

  // ── Copy-link buttons ──────────────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.cl-copy').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const url = `${location.origin}/changelog#${btn.dataset.anchor}`
      try {
        await navigator.clipboard.writeText(url)
        btn.classList.add('copied')
        btn.setAttribute('aria-label', 'Link copied!')
        setTimeout(() => {
          btn.classList.remove('copied')
          btn.setAttribute('aria-label', 'Copy link to this entry')
        }, 1800)
      } catch {
        /* clipboard unavailable — no-op */
      }
    })
  })

  // ── Before/after sliders ───────────────────────────────────────────────
  document.querySelectorAll<HTMLElement>('.cl-cmp').forEach((cmp) => {
    const range = cmp.querySelector<HTMLInputElement>('.cl-cmp-range')
    const set = (v: number) => cmp.style.setProperty('--cl-pos', `${v}%`)
    set(50)
    range?.addEventListener('input', () => set(Number(range.value)))
  })

  // ── Lightbox ───────────────────────────────────────────────────────────
  const lb = document.getElementById('cl-lightbox') as HTMLDialogElement | null
  const lbImg = lb?.querySelector<HTMLImageElement>('.cl-lb-img')
  const lbCap = lb?.querySelector<HTMLParagraphElement>('.cl-lb-cap')
  let group: { src: string; alt: string }[] = []
  let idx = 0
  let opener: HTMLElement | null = null

  function show(n: number) {
    if (!group.length || !lbImg || !lbCap) return
    idx = (n + group.length) % group.length
    lbImg.src = group[idx].src
    lbImg.alt = group[idx].alt
    lbCap.textContent = `${group[idx].alt} · ${idx + 1} / ${group.length}`
  }

  document.querySelectorAll<HTMLButtonElement>('.cl-thumb').forEach((thumb) => {
    thumb.addEventListener('click', () => {
      const id = thumb.dataset.group
      group = Array.from(document.querySelectorAll<HTMLButtonElement>(`.cl-thumb[data-group="${id}"]`)).map(
        (t) => ({ src: t.dataset.full ?? '', alt: t.dataset.alt ?? '' })
      )
      opener = thumb
      const start = group.findIndex((g) => g.src === thumb.dataset.full)
      show(start < 0 ? 0 : start)
      lb?.showModal()
    })
  })

  lb?.addEventListener('click', (e) => {
    const action = (e.target as HTMLElement).closest<HTMLElement>('[data-lb]')?.dataset.lb
    if (action === 'close') lb.close()
    else if (action === 'prev') show(idx - 1)
    else if (action === 'next') show(idx + 1)
    else if (e.target === lb) lb.close() // backdrop click
  })
  lb?.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowLeft') show(idx - 1)
    else if (e.key === 'ArrowRight') show(idx + 1)
  })
  lb?.addEventListener('close', () => opener?.focus())
</script>
