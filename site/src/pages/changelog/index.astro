---
import Base from '../../layouts/Base.astro'
import Nav from '../../components/sections/Nav.astro'
import Footer from '../../components/sections/Footer.astro'
import Gallery from '../../components/changelog/Gallery.astro'
import { entries, updated } from '../../data/changelog'
import { loadPrGallery } from '../../lib/changelog-gallery'

const repo = 'https://github.com/crs48/xNet'
const editUrl = `${repo}/blob/main/site/src/data/changelog.ts`

// Time-of-day label for an entry's merge instant, in UTC so the rendered string
// is deterministic across build environments (the page is statically built).
// Returns null when the entry has no resolved merge time (renders date-only).
function mergeTimeUTC(iso?: string): string | null {
  if (!iso) return null
  const d = new Date(iso)
  if (Number.isNaN(d.getTime())) return null
  const hh = String(d.getUTCHours()).padStart(2, '0')
  const mm = String(d.getUTCMinutes()).padStart(2, '0')
  return `${hh}:${mm} UTC`
}

const tagColor: Record<string, string> = {
  app: 'bg-emerald-500/15 text-emerald-700 dark:text-emerald-300',
  crm: 'bg-sky-500/15 text-sky-700 dark:text-sky-300',
  finance: 'bg-green-500/15 text-green-700 dark:text-green-300',
  tasks: 'bg-amber-500/15 text-amber-700 dark:text-amber-300',
  ai: 'bg-violet-500/15 text-violet-700 dark:text-violet-300',
  plugins: 'bg-indigo-500/15 text-indigo-700 dark:text-indigo-300',
  editor: 'bg-fuchsia-500/15 text-fuchsia-700 dark:text-fuchsia-300',
  sync: 'bg-cyan-500/15 text-cyan-700 dark:text-cyan-300',
  identity: 'bg-rose-500/15 text-rose-700 dark:text-rose-300',
  platform: 'bg-purple-500/15 text-purple-700 dark:text-purple-300',
  performance: 'bg-orange-500/15 text-orange-700 dark:text-orange-300',
  devtools: 'bg-slate-500/15 text-slate-700 dark:text-slate-300',
  ci: 'bg-teal-500/15 text-teal-700 dark:text-teal-300'
}

// Tags actually used, in the colour-map's order — drives the filter chips.
const usedTags = Object.keys(tagColor).filter((t) => entries.some((e) => e.tags.includes(t as never)))

// Resolve each entry's auto-gallery from its PR's durable diff manifest at
// build time (exploration 0196). Build-time, fail-open: a 404 / offline fetch
// yields null and the entry falls back to its curated hero/images.
const galleries = await Promise.all(entries.map((e) => (e.pr ? loadPrGallery(e.pr) : null)))

// Normalise per-entry media into one ordered list of gallery items (changed
// surfaces first, as before/after comparisons; then new + curated images).
const view = entries.map((entry, i) => {
  const gallery = galleries[i]
  const items = [
    ...(gallery?.images ?? [])
      .filter((im) => im.before)
      .map((im) => ({
        type: 'cmp' as const,
        after: im.src,
        before: im.before as string,
        diff: im.diff,
        alt: im.alt
      })),
    ...(gallery?.images ?? [])
      .filter((im) => !im.before)
      .map((im) => ({ type: 'img' as const, after: im.src, alt: im.alt })),
    ...(entry.images ?? []).map((im) => ({
      type: 'img' as const,
      after: im.src,
      alt: im.alt,
      caption: im.caption
    }))
  ]
  const video = entry.video
    ? { mp4: entry.video.src, poster: entry.video.poster, alt: entry.video.alt }
    : gallery?.videos?.[0]
  const galleryLink =
    gallery && entry.pr ? { prUrl: gallery.prUrl, count: gallery.count, pr: entry.pr } : undefined
  const dataText = [entry.title, entry.summary, ...entry.highlights].join(' ').toLowerCase()
  const mergeTime = mergeTimeUTC(entry.mergedAt)
  // Everyone who contributed; fall back to the legacy single author.
  const contributors = entry.authors?.length
    ? entry.authors
    : entry.author
      ? [entry.author]
      : []
  return { entry, items, video, galleryLink, dataText, contributors, mergeTime }
})
---

<Base
  title="xNet Changelog — What's New"
  description={`Everything that's shipped in xNet, newest first. ${entries.length} releases, updated ${updated}. Subscribe via RSS or the JSON feed.`}
>
  <Nav />

  <main class="py-24 lg:py-32">
    <div class="mx-auto max-w-3xl px-6">
      <!-- Hero -->
      <div class="mb-10 text-center">
        <h1 class="mb-4 text-4xl font-bold text-gray-800 dark:text-white sm:text-5xl">What's New</h1>
        <p class="mx-auto max-w-xl text-lg leading-relaxed text-gray-500 dark:text-gray-400">
          Everything that's shipped in xNet, newest first.
        </p>
        <div class="mt-5 flex items-center justify-center gap-4 text-sm">
          <a href="/changelog.xml" class="text-indigo-400 hover:underline">RSS</a>
          <span class="text-gray-300 dark:text-gray-600">·</span>
          <a href="/changelog.json" class="text-indigo-400 hover:underline">JSON feed</a>
          <span class="text-gray-300 dark:text-gray-600">·</span>
          <a href={editUrl} target="_blank" rel="noopener noreferrer" class="text-indigo-400 hover:underline">Edit on GitHub</a>
        </div>
      </div>

      <!-- Controls: search + tag filter -->
      <div id="cl-controls" class="mb-10 scroll-mt-24 space-y-3">
        <input
          id="cl-search"
          type="search"
          placeholder="Search the changelog…"
          aria-label="Search the changelog"
          class="w-full rounded-lg border border-border bg-surface/40 px-4 py-2 text-sm text-gray-700 placeholder:text-gray-400 focus:border-indigo-500/50 focus:outline-none dark:text-gray-200"
        />
        <div id="cl-filters" role="group" aria-label="Filter by category" class="flex flex-wrap gap-1.5">
          <button type="button" class="cl-filter" data-tag="all" aria-pressed="true">All</button>
          {usedTags.map((tag) => (
            <button type="button" class="cl-filter" data-tag={tag} aria-pressed="false">{tag}</button>
          ))}
        </div>
        <p id="cl-empty" hidden class="text-center text-sm text-gray-400">No entries match.</p>
      </div>

      <!-- Timeline -->
      <div class="relative">
        <div class="absolute left-2 top-2 bottom-2 w-px bg-gradient-to-b from-emerald-500/40 via-indigo-500/25 to-transparent"></div>

        <div class="space-y-12">
          {view.map(({ entry, items, video, galleryLink, dataText, contributors, mergeTime }, i) => (
            <article
              id={entry.id}
              class="cl-entry relative pl-10 scroll-mt-24"
              data-tags={entry.tags.join(' ')}
              data-text={dataText}
            >
              <div class="absolute left-0 top-1.5 h-[17px] w-[17px] rounded-full bg-indigo-400 ring-4 ring-white dark:ring-[#0a0a0f]"></div>

              <div class="mb-2 flex flex-wrap items-center gap-x-3 gap-y-1">
                <time
                  datetime={entry.mergedAt}
                  title={entry.mergedAt ? `Merged ${entry.mergedAt}` : undefined}
                  class="text-xs font-semibold uppercase tracking-wider text-gray-400 dark:text-gray-500"
                >{entry.date}{mergeTime && <span class="text-gray-300 dark:text-gray-600"> · {mergeTime}</span>}</time>
                {entry.pr && (
                  <a
                    href={`${repo}/pull/${entry.pr}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-xs text-gray-400 hover:text-indigo-400 hover:underline"
                  >#{entry.pr}</a>
                )}
                {contributors.map((c) => (
                  <a
                    href={`https://github.com/${c.login}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center gap-1.5 text-xs text-gray-400 hover:text-indigo-400"
                    title={`By ${c.name ?? c.login}`}
                  >
                    <img
                      src={`https://github.com/${c.login}.png?size=40`}
                      alt=""
                      width="18"
                      height="18"
                      loading="lazy"
                      class="rounded-full"
                    />
                    {c.name ?? c.login}
                  </a>
                ))}
              </div>

              <h2 class="group mb-2 flex items-center gap-2 text-2xl font-bold text-gray-900 dark:text-white">
                <a href={`#${entry.id}`} class="hover:text-indigo-400">{entry.title}</a>
                <button
                  type="button"
                  class="cl-copy opacity-0 transition-opacity group-hover:opacity-100 focus:opacity-100"
                  data-anchor={entry.id}
                  aria-label="Copy link to this entry"
                  title="Copy link"
                >
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" /></svg>
                </button>
              </h2>

              <p class="mb-4 text-gray-600 dark:text-gray-300">{entry.summary}</p>

              {entry.hero && (
                <img
                  src={entry.hero.src}
                  alt={entry.hero.alt}
                  loading={i === 0 ? 'eager' : 'lazy'}
                  fetchpriority={i === 0 ? 'high' : undefined}
                  class="mb-4 w-full rounded-xl border border-border"
                />
              )}

              <Gallery entryId={entry.id} items={items} video={video} galleryLink={galleryLink} />

              {entry.pr && items.length === 0 && !video && (
                <a
                  href={`${repo}/pull/${entry.pr}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mb-4 inline-flex items-center gap-1 text-sm text-indigo-400 hover:underline"
                >View PR #{entry.pr} →</a>
              )}

              <ul class="mb-4 grid gap-1.5">
                {entry.highlights.map((h) => (
                  <li class="flex items-start gap-2 text-sm text-gray-600 dark:text-gray-300">
                    <svg class="mt-0.5 h-4 w-4 shrink-0 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    <span>{h}</span>
                  </li>
                ))}
              </ul>

              <div class="flex flex-wrap gap-1.5">
                {entry.tags.map((tag) => (
                  <span class={`rounded-full px-2 py-0.5 text-xs font-medium ${tagColor[tag] ?? 'bg-gray-500/15 text-gray-600 dark:text-gray-300'}`}>{tag}</span>
                ))}
              </div>
            </article>
          ))}
        </div>
      </div>

      <!-- Pager (populated by the script; hidden when everything fits one page) -->
      <nav id="cl-pager" hidden class="mt-12 flex flex-wrap items-center justify-center gap-1.5" aria-label="Changelog pages"></nav>

      <p class="mt-16 text-center text-xs text-gray-400 dark:text-gray-500">Updated {updated}</p>
    </div>
  </main>

  <Footer />

  <!-- Lightbox (single, reused). For a comparison: after by default, before on
       hover, diff while pressed — same as the row preview, just bigger. -->
  <dialog id="cl-lightbox" class="cl-lightbox" aria-label="Screenshot viewer">
    <button type="button" class="cl-lb-close" data-lb="close" aria-label="Close">✕</button>
    <button type="button" class="cl-lb-nav cl-lb-prev" data-lb="prev" aria-label="Previous">‹</button>
    <div class="cl-lb-stage" id="cl-lb-stage">
      <img class="cl-lb-after" alt="" />
      <img class="cl-lb-before" alt="" aria-hidden="true" />
      <img class="cl-lb-diff" alt="" aria-hidden="true" />
      <span class="cl-lb-badge" aria-hidden="true">
        <span class="b-after">After</span>
        <span class="b-before">Before</span>
        <span class="b-diff">Diff</span>
      </span>
    </div>
    <button type="button" class="cl-lb-nav cl-lb-next" data-lb="next" aria-label="Next">›</button>
    <p class="cl-lb-cap" aria-live="polite"></p>
  </dialog>
</Base>

<style>
  /* Filter chips */
  .cl-filter {
    border: 1px solid var(--lp-border);
    border-radius: 9999px;
    padding: 0.15rem 0.7rem;
    font-size: 0.75rem;
    color: #6b7280;
    background: transparent;
    cursor: pointer;
    transition: all 0.15s;
  }
  .cl-filter:hover {
    color: #4f46e5;
  }
  .cl-filter[aria-pressed='true'] {
    background: #4f46e5;
    border-color: #4f46e5;
    color: #fff;
  }
  /* Pager buttons — created by the script, so :global keeps the scoped-style
     hash from excluding them. Same chip language as the filters. */
  :global(.cl-page) {
    border: 1px solid var(--lp-border);
    border-radius: 9999px;
    padding: 0.25rem 0.75rem;
    font-size: 0.8rem;
    color: #6b7280;
    background: transparent;
    cursor: pointer;
    transition: all 0.15s;
  }
  :global(.cl-page:hover:not(:disabled)) {
    color: #4f46e5;
  }
  :global(.cl-page[aria-current='page']) {
    background: #4f46e5;
    border-color: #4f46e5;
    color: #fff;
  }
  :global(.cl-page:disabled) {
    opacity: 0.4;
    cursor: default;
  }
  .cl-copy {
    color: #9ca3af;
    background: transparent;
    border: none;
    cursor: pointer;
  }
  .cl-copy:hover {
    color: #4f46e5;
  }
  .cl-copy.copied {
    color: #10b981;
  }

  /* Lightbox */
  .cl-lightbox {
    border: none;
    background: transparent;
    max-width: 100vw;
    max-height: 100vh;
    width: 100%;
    height: 100%;
    padding: 0;
  }
  .cl-lightbox::backdrop {
    background: rgba(0, 0, 0, 0.85);
  }
  .cl-lb-stage {
    position: absolute;
    inset: 5% 7% 12%;
    margin: auto;
  }
  .cl-lb-after,
  .cl-lb-before,
  .cl-lb-diff {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .cl-lb-before,
  .cl-lb-diff {
    opacity: 0;
  }
  .cl-lb-stage.is-cmp:hover .cl-lb-before {
    opacity: 1;
  }
  .cl-lb-stage.is-holding .cl-lb-diff {
    opacity: 1;
  }
  .cl-lb-badge {
    position: absolute;
    top: 0.6rem;
    left: 0.6rem;
    padding: 0.15rem 0.55rem;
    border-radius: 0.3rem;
    background: rgba(0, 0, 0, 0.7);
    color: #fff;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    pointer-events: none;
    display: none;
  }
  .cl-lb-stage.is-cmp .cl-lb-badge {
    display: inline-block;
  }
  .cl-lb-badge .b-before,
  .cl-lb-badge .b-diff {
    display: none;
  }
  .cl-lb-stage.is-cmp:hover .b-after {
    display: none;
  }
  .cl-lb-stage.is-cmp:hover .b-before {
    display: inline;
  }
  .cl-lb-stage.is-holding .b-after,
  .cl-lb-stage.is-holding .b-before {
    display: none;
  }
  .cl-lb-stage.is-holding .b-diff {
    display: inline;
  }
  .cl-lb-stage.is-cmp.has-diff {
    cursor: pointer;
  }
  .cl-lb-close,
  .cl-lb-nav {
    position: absolute;
    z-index: 1;
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
    border: none;
    cursor: pointer;
    border-radius: 9999px;
  }
  .cl-lb-close {
    top: 1rem;
    right: 1rem;
    width: 2.25rem;
    height: 2.25rem;
    font-size: 1rem;
  }
  .cl-lb-nav {
    top: 50%;
    transform: translateY(-50%);
    width: 2.75rem;
    height: 2.75rem;
    font-size: 1.75rem;
    line-height: 1;
  }
  .cl-lb-prev {
    left: 1rem;
  }
  .cl-lb-next {
    right: 1rem;
  }
  .cl-lb-close:hover,
  .cl-lb-nav:hover {
    background: rgba(255, 255, 255, 0.25);
  }
  .cl-lb-cap {
    position: absolute;
    bottom: 1.25rem;
    left: 0;
    right: 0;
    text-align: center;
    color: #e5e7eb;
    font-size: 0.85rem;
  }
</style>

<script>
  // ── Tag filter + search + pagination ───────────────────────────────────
  const search = document.getElementById('cl-search') as HTMLInputElement | null
  const filterRow = document.getElementById('cl-filters')
  const empty = document.getElementById('cl-empty')
  const pager = document.getElementById('cl-pager')
  const articles = Array.from(document.querySelectorAll<HTMLElement>('article.cl-entry'))
  let activeTag = 'all'

  const PAGE_SIZE = 50
  let page = 1

  // Entries matching the active tag + search, in timeline order.
  function matched(): HTMLElement[] {
    const q = (search?.value ?? '').trim().toLowerCase()
    return articles.filter((a) => {
      const tags = (a.dataset.tags ?? '').split(' ')
      const text = a.dataset.text ?? ''
      return (activeTag === 'all' || tags.includes(activeTag)) && (q === '' || text.includes(q))
    })
  }

  function apply() {
    const hits = matched()
    const totalPages = Math.max(1, Math.ceil(hits.length / PAGE_SIZE))
    page = Math.min(Math.max(1, page), totalPages)
    const visible = new Set(hits.slice((page - 1) * PAGE_SIZE, page * PAGE_SIZE))
    for (const a of articles) a.hidden = !visible.has(a)
    if (empty) empty.hidden = hits.length > 0
    renderPager(totalPages)
    markOverflowingRows()
  }

  function renderPager(totalPages: number) {
    if (!pager) return
    pager.hidden = totalPages <= 1
    pager.replaceChildren()
    if (totalPages <= 1) return
    const add = (label: string, target: number | null, opts: { current?: boolean; aria?: string } = {}) => {
      const b = document.createElement('button')
      b.type = 'button'
      b.className = 'cl-page'
      b.textContent = label
      if (opts.aria) b.setAttribute('aria-label', opts.aria)
      if (opts.current) b.setAttribute('aria-current', 'page')
      b.disabled = target === null
      if (target !== null) b.addEventListener('click', () => setPage(target))
      pager.appendChild(b)
    }
    add('‹ Prev', page > 1 ? page - 1 : null, { aria: 'Previous page' })
    for (let n = 1; n <= totalPages; n++)
      add(String(n), n === page ? null : n, { current: n === page, aria: `Page ${n}` })
    add('Next ›', page < totalPages ? page + 1 : null, { aria: 'Next page' })
  }

  function setPage(n: number, scroll = true) {
    page = n
    const url = new URL(location.href)
    if (page === 1) url.searchParams.delete('page')
    else url.searchParams.set('page', String(page))
    history.replaceState(null, '', url)
    apply()
    if (scroll) document.getElementById('cl-controls')?.scrollIntoView()
  }

  filterRow?.querySelectorAll<HTMLButtonElement>('.cl-filter').forEach((chip) => {
    chip.addEventListener('click', () => {
      activeTag = chip.dataset.tag ?? 'all'
      filterRow.querySelectorAll('.cl-filter').forEach((c) => c.setAttribute('aria-pressed', 'false'))
      chip.setAttribute('aria-pressed', 'true')
      page = 1
      const url = new URL(location.href)
      if (activeTag === 'all') url.searchParams.delete('tag')
      else url.searchParams.set('tag', activeTag)
      url.searchParams.delete('page')
      history.replaceState(null, '', url)
      apply()
    })
  })
  search?.addEventListener('input', () => setPage(1, false))

  // A #entry deep link (copy-link buttons, RSS) may live past page 1 — jump to
  // the page that contains it, then restore the browser's anchor scroll.
  function jumpToHash(): boolean {
    if (!location.hash) return false
    const target = document.getElementById(decodeURIComponent(location.hash.slice(1)))
    if (!target?.classList.contains('cl-entry')) return false
    const i = matched().indexOf(target)
    if (i < 0) return false
    page = Math.floor(i / PAGE_SIZE) + 1
    apply()
    target.scrollIntoView()
    return true
  }
  window.addEventListener('hashchange', jumpToHash)

  // Pre-activate a tag from ?tag= on load (shareable filtered views).
  const params = new URLSearchParams(location.search)
  const initial = params.get('tag')
  if (initial) {
    const chip = filterRow?.querySelector<HTMLButtonElement>(`.cl-filter[data-tag="${initial}"]`)
    chip?.click()
  }
  // Then ?page= (chip click resets to 1), then let a #hash override both.
  const initialPage = Number.parseInt(params.get('page') ?? '', 10)
  if (Number.isFinite(initialPage) && initialPage > 1) page = initialPage
  if (!jumpToHash()) apply()

  // ── Copy-link buttons ──────────────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.cl-copy').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const url = `${location.origin}/changelog#${btn.dataset.anchor}`
      try {
        await navigator.clipboard.writeText(url)
        btn.classList.add('copied')
        btn.setAttribute('aria-label', 'Link copied!')
        setTimeout(() => {
          btn.classList.remove('copied')
          btn.setAttribute('aria-label', 'Copy link to this entry')
        }, 1800)
      } catch {
        /* clipboard unavailable — no-op */
      }
    })
  })

  // ── Gallery row + lightbox ─────────────────────────────────────────────
  // Hover→before and (CSS) is on the items already. JS handles press-hold→diff
  // (in the row and the lightbox) and the click-to-enlarge lightbox itself.
  interface Item {
    type: string
    after: string
    before: string
    diff: string
    alt: string
  }
  const lb = document.getElementById('cl-lightbox') as HTMLDialogElement | null
  const stage = document.getElementById('cl-lb-stage')
  const lbAfter = lb?.querySelector<HTMLImageElement>('.cl-lb-after')
  const lbBefore = lb?.querySelector<HTMLImageElement>('.cl-lb-before')
  const lbDiff = lb?.querySelector<HTMLImageElement>('.cl-lb-diff')
  const lbCap = lb?.querySelector<HTMLParagraphElement>('.cl-lb-cap')
  let group: Item[] = []
  let idx = 0
  let opener: HTMLElement | null = null

  const itemOf = (el: HTMLElement): Item => ({
    type: el.dataset.type === 'cmp' ? 'cmp' : 'img',
    after: el.dataset.after ?? '',
    before: el.dataset.before ?? '',
    diff: el.dataset.diff ?? '',
    alt: el.dataset.alt ?? ''
  })

  function show(n: number) {
    if (!group.length || !stage) return
    idx = (n + group.length) % group.length
    const it = group[idx]
    stage.classList.toggle('is-cmp', it.type === 'cmp')
    stage.classList.toggle('has-diff', Boolean(it.diff))
    stage.classList.remove('is-holding')
    if (lbAfter) {
      lbAfter.src = it.after
      lbAfter.alt = it.alt
    }
    if (lbBefore) lbBefore.src = it.before
    if (lbDiff) lbDiff.src = it.diff
    if (lbCap) lbCap.textContent = `${it.alt} · ${idx + 1} / ${group.length}`
  }

  function openFrom(el: HTMLElement) {
    const id = el.dataset.group
    const els = Array.from(document.querySelectorAll<HTMLElement>(`.cl-item[data-group="${id}"]`))
    group = els.map(itemOf)
    opener = el
    show(Math.max(0, els.indexOf(el)))
    lb?.showModal()
  }

  // Row items: click/Enter → lightbox. Press-and-hold a comparison → its diff
  // in place (and the ensuing click is suppressed so it doesn't also open).
  document.querySelectorAll<HTMLElement>('.cl-item').forEach((el) => {
    const hasDiff = Boolean(el.dataset.diff)
    let timer = 0
    let held = false
    let suppressClick = false

    el.addEventListener('pointerdown', () => {
      if (!hasDiff) return
      held = false
      timer = window.setTimeout(() => {
        held = true
        el.classList.add('is-holding')
      }, 200)
    })
    const endHold = () => {
      if (!hasDiff) return
      clearTimeout(timer)
      if (held) {
        el.classList.remove('is-holding')
        suppressClick = true
        held = false
      }
    }
    el.addEventListener('pointerup', endHold)
    el.addEventListener('pointerleave', endHold)
    el.addEventListener('pointercancel', endHold)
    el.addEventListener('click', () => {
      if (suppressClick) {
        suppressClick = false
        return
      }
      openFrom(el)
    })
  })

  // Lightbox stage: hover→before is CSS; press-and-hold→diff here.
  stage?.addEventListener('pointerdown', () => {
    if (stage.classList.contains('has-diff')) stage.classList.add('is-holding')
  })
  window.addEventListener('pointerup', () => stage?.classList.remove('is-holding'))

  // Trailing fade only when the row actually overflows. Hidden rows measure 0,
  // so re-check from apply() whenever pagination/filtering reveals entries.
  function markOverflowingRows() {
    document.querySelectorAll<HTMLElement>('.cl-row').forEach((row) => {
      if (row.scrollWidth > row.clientWidth + 4) row.classList.add('cl-row--overflow')
    })
  }

  lb?.addEventListener('click', (e) => {
    const action = (e.target as HTMLElement).closest<HTMLElement>('[data-lb]')?.dataset.lb
    if (action === 'close') lb.close()
    else if (action === 'prev') show(idx - 1)
    else if (action === 'next') show(idx + 1)
    else if (e.target === lb) lb.close() // backdrop click
  })
  lb?.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowLeft') show(idx - 1)
    else if (e.key === 'ArrowRight') show(idx + 1)
  })
  lb?.addEventListener('close', () => opener?.focus())
</script>
