---

<Base
  title="How xNet Compares — Local-First Landscape"
  description="See how xNet compares to other local-first frameworks, productivity apps, and decentralized protocols. Detailed comparison tables for developers and users."
>
  <Nav />

  <main class="py-24 lg:py-32">
    <div class="mx-auto max-w-7xl px-6">
      <!-- Hero -->
      <div class="text-center mb-20">
        <h1 class="text-4xl font-bold text-gray-800 dark:text-white sm:text-5xl mb-6">
          The Local-First Landscape
        </h1>
        <p class="mx-auto max-w-2xl text-lg text-gray-500 dark:text-gray-400 leading-relaxed">
          We're building xNet because we believe in a future where users own their data.
          We're not alone — here are the projects pushing this vision forward.
          We encourage you to explore them all.
        </p>
      </div>

      <!-- Quick Summary Cards -->
      <div class="grid gap-6 sm:grid-cols-3 mb-20">
        <div class="rounded-xl border border-indigo-500/20 bg-indigo-500/[0.03] p-6 text-center">
          <div class="text-3xl font-bold text-indigo-400 mb-2">{infraProjects.length}</div>
          <div class="text-sm text-gray-500">Developer Frameworks</div>
        </div>
        <div class="rounded-xl border border-purple-500/20 bg-purple-500/[0.03] p-6 text-center">
          <div class="text-3xl font-bold text-purple-400 mb-2">{protocolProjects.length}</div>
          <div class="text-sm text-gray-500">P2P Protocols</div>
        </div>
        <div class="rounded-xl border border-emerald-500/20 bg-emerald-500/[0.03] p-6 text-center">
          <div class="text-3xl font-bold text-emerald-400 mb-2">{productivityApps.length}</div>
          <div class="text-sm text-gray-500">Productivity Apps</div>
        </div>
      </div>

      <!-- Table 1: Developer Frameworks -->
      <section class="mb-20">
        <div class="mb-8">
          <h2 class="text-2xl font-bold text-gray-800 dark:text-white mb-3">
            Developer Frameworks & Data Tools
          </h2>
          <p class="text-gray-500 dark:text-gray-400 max-w-3xl">
            What you'd use to build a local-first app today. Each has different tradeoffs around
            sync architecture, schema systems, and infrastructure requirements.
          </p>
        </div>
        <div class="overflow-x-auto rounded-xl border border-border">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-border bg-surface/30 dark:bg-surface/50">
                <th class="sticky left-0 z-10 bg-surface/80 dark:bg-surface/90 backdrop-blur-sm px-4 py-3 text-left font-semibold text-gray-600 dark:text-gray-300 min-w-[100px]">Project</th>
                {infraColumns.map(col => (
                  <th class="px-4 py-3 text-left font-medium text-gray-500 whitespace-nowrap">{col.label}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {infraProjects.map((project) => (
                <tr class={`border-b border-border/50 ${project.highlight ? 'bg-indigo-500/[0.04]' : 'hover:bg-surface/30'} transition-colors`}>
                  <td class={`sticky left-0 z-10 ${project.highlight ? 'bg-indigo-500/[0.06]' : 'bg-code-bg'} backdrop-blur-sm px-4 py-3 font-medium whitespace-nowrap`}>
                    <a href={project.url} target="_blank" rel="noopener noreferrer" class={`hover:underline ${project.highlight ? 'text-indigo-400' : 'text-gray-600 dark:text-gray-300 hover:text-indigo-400'}`}>
                      {project.name}
                    </a>
                  </td>
                  {infraColumns.map(col => {
                    const val = (project as any)[col.key]
                    const isBoolean = typeof val === 'boolean'
                    const isDash = val === '—'
                    return (
                      <td class={`px-4 py-3 whitespace-nowrap ${isDash ? 'text-gray-700' : 'text-gray-500 dark:text-gray-400'}`}>
                        {isBoolean ? (
                          val ? (
                            <span class="text-emerald-400">Yes</span>
                          ) : (
                            <span class="text-gray-600">No</span>
                          )
                        ) : val}
                      </td>
                    )
                  })}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="mt-3 text-xs text-gray-600">** Convex runtime is proprietary; client SDKs are open source. All other projects are fully open source.</p>
      </section>

      <!-- Table 2: Protocols -->
      <section class="mb-20">
        <div class="mb-8">
          <h2 class="text-2xl font-bold text-gray-800 dark:text-white mb-3">
            Protocols & P2P Infrastructure
          </h2>
          <p class="text-gray-500 dark:text-gray-400 max-w-3xl">
            The broader ecosystem of decentralized data. Different scopes, different goals —
            all pushing toward user-owned data.
          </p>
        </div>
        <div class="overflow-x-auto rounded-xl border border-border">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-border bg-surface/30 dark:bg-surface/50">
                <th class="sticky left-0 z-10 bg-surface/80 dark:bg-surface/90 backdrop-blur-sm px-4 py-3 text-left font-semibold text-gray-600 dark:text-gray-300 min-w-[130px]">Project</th>
                {protocolColumns.map(col => (
                  <th class="px-4 py-3 text-left font-medium text-gray-500 whitespace-nowrap">{col.label}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {protocolProjects.map((project) => (
                <tr class={`border-b border-border/50 ${project.highlight ? 'bg-indigo-500/[0.04]' : 'hover:bg-surface/30'} transition-colors`}>
                  <td class={`sticky left-0 z-10 ${project.highlight ? 'bg-indigo-500/[0.06]' : 'bg-code-bg'} backdrop-blur-sm px-4 py-3 font-medium whitespace-nowrap`}>
                    <a href={project.url} target="_blank" rel="noopener noreferrer" class={`hover:underline ${project.highlight ? 'text-indigo-400' : 'text-gray-600 dark:text-gray-300 hover:text-indigo-400'}`}>
                      {project.name}
                    </a>
                  </td>
                  {protocolColumns.map(col => (
                    <td class="px-4 py-3 text-gray-500 dark:text-gray-400 whitespace-nowrap">{(project as any)[col.key]}</td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <!-- Table 3: Productivity Apps -->
      <section class="mb-20">
        <div class="mb-8">
          <h2 class="text-2xl font-bold text-gray-800 dark:text-white mb-3">
            Productivity Apps
          </h2>
          <p class="text-gray-500 dark:text-gray-400 max-w-3xl">
            How xNet's built-in app compares to the tools you might already use.
            Different philosophies — from cloud-first SaaS to local-first open source.
          </p>
        </div>
        <div class="overflow-x-auto rounded-xl border border-border">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-border bg-surface/30 dark:bg-surface/50">
                <th class="sticky left-0 z-10 bg-surface/80 dark:bg-surface/90 backdrop-blur-sm px-4 py-3 text-left font-semibold text-gray-600 dark:text-gray-300 min-w-[110px]">App</th>
                {productivityColumns.map(col => (
                  <th class="px-4 py-3 text-left font-medium text-gray-500 whitespace-nowrap">{col.label}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {productivityApps.map((app) => (
                <tr class={`border-b border-border/50 ${app.highlight ? 'bg-indigo-500/[0.04]' : 'hover:bg-surface/30'} transition-colors`}>
                  <td class={`sticky left-0 z-10 ${app.highlight ? 'bg-indigo-500/[0.06]' : 'bg-code-bg'} backdrop-blur-sm px-4 py-3 font-medium whitespace-nowrap`}>
                    <a href={app.url} target="_blank" rel="noopener noreferrer" class={`hover:underline ${app.highlight ? 'text-indigo-400' : 'text-gray-600 dark:text-gray-300 hover:text-indigo-400'}`}>
                      {app.name}
                    </a>
                  </td>
                  {productivityColumns.map(col => {
                    const val = (app as any)[col.key]
                    const isBoolean = typeof val === 'boolean'
                    const isNo = val === 'No'
                    return (
                      <td class={`px-4 py-3 whitespace-nowrap ${isNo ? 'text-gray-700' : 'text-gray-500 dark:text-gray-400'}`}>
                        {isBoolean ? (
                          val ? (
                            <span class="text-emerald-400">Yes</span>
                          ) : (
                            <span class="text-gray-600">No</span>
                          )
                        ) : val}
                      </td>
                    )
                  })}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <!-- Where xNet fits -->
      <section class="max-w-4xl mx-auto">
        <div class="rounded-xl border border-indigo-500/20 bg-indigo-500/[0.03] p-8 sm:p-10">
          <h2 class="text-2xl font-bold text-gray-800 dark:text-white mb-4 text-center">
            Where xNet Fits
          </h2>
          <p class="text-gray-500 dark:text-gray-400 leading-relaxed text-center mb-8">
            xNet combines <strong class="text-gray-600 dark:text-gray-300">TypeScript-inferred schemas</strong>,
            a <strong class="text-gray-600 dark:text-gray-300">dual CRDT strategy</strong> (Yjs for rich text + Lamport LWW for structured data),
            <strong class="text-gray-600 dark:text-gray-300">React hooks</strong>,
            a <strong class="text-gray-600 dark:text-gray-300">four-layer plugin system</strong>,
            and <strong class="text-gray-600 dark:text-gray-300">true P2P sync</strong> — all in one framework.
          </p>

          <div class="grid gap-4 sm:grid-cols-2 text-sm">
            <div class="rounded-lg border border-border bg-surface/30 p-4">
              <p class="text-gray-500 dark:text-gray-400">
                <strong class="text-indigo-400">Building a React app?</strong><br />
                Want local-first with minimal boilerplate? Start here.
              </p>
            </div>
