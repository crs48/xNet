---
// Original art for the internals post (exploration 0248). The essay's thesis is
// the Luddite one inverted: the power loom was a black box the weaver wasn't
// allowed to own or understand; xNet is a loom you can open, read, and keep. So
// the hero is a loom — taut vertical warp threads, a woven band of weft crossing
// through, and the cosmic-X riding the shuttle as the single brightest thread in
// the cloth (the recurring "X as the brightest node" motif, indigo here to match
// the protocol/decentralization tag). All inline SVG, no external assets, so the
// page ships nothing third-party (Self-Audit parity with posts #1–#6).
interface Props {
  title: string
  deck: string
  date: string
  readingMinutes: number
  tags: string[]
}
const { title, deck, date, readingMinutes, tags } = Astro.props

// Warp: taut vertical threads spanning the frame, faint and parallel.
const warp = Array.from({ length: 33 }, (_, i) => ({
  x: 20 + i * 31,
  o: 0.16 + ((i * 7) % 5) * 0.05
}))

// Weft: horizontal threads woven through the central band. Each is drawn as a
// run of short dashes to suggest passing over and under the warp.
const weftRows = [150, 168, 186, 204, 222]
---

<section class="relative overflow-hidden border-b border-border bg-surface/20 dark:bg-[#070710]">
  <svg
    class="pointer-events-none absolute inset-0 h-full w-full"
    viewBox="0 0 1040 360"
    preserveAspectRatio="xMidYMid slice"
    aria-hidden="true"
  >
    <defs>
      <linearGradient id="lhsky" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#080813" />
        <stop offset="60%" stop-color="#0b0b18" />
        <stop offset="100%" stop-color="#0d0d1c" />
      </linearGradient>
      <radialGradient id="lhglow" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#a5b4fc" stop-opacity="0.9" />
        <stop offset="45%" stop-color="#6366f1" stop-opacity="0.35" />
        <stop offset="100%" stop-color="#6366f1" stop-opacity="0" />
      </radialGradient>
      <linearGradient id="lhx" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#fde68a" />
        <stop offset="100%" stop-color="#818cf8" />
      </linearGradient>
    </defs>

    <rect width="1040" height="360" fill="url(#lhsky)" />

    <!-- warp: the taut vertical threads of the loom -->
    <g stroke="#6366f1" stroke-width="1.1">
      {warp.map((t) => <line x1={t.x} y1="36" x2={t.x} y2="330" opacity={t.o} />)}
    </g>

    <!-- the glow behind the shuttle, riding high over the forming cloth -->
    <g transform="translate(548 104)">
      <circle cx="0" cy="0" r="132" fill="url(#lhglow)" />
    </g>

    <!-- weft: horizontal threads woven through, brighter where lit -->
    <g stroke="#a5b4fc" stroke-width="2" stroke-linecap="round" fill="none">
      {
        weftRows.map((y, r) => (
          <line
            x1="120"
            y1={y}
            x2="980"
            y2={y}
            stroke-dasharray="14 9"
            opacity={0.28 + (r % 2) * 0.22}
          />
        ))
      }
    </g>

    <!-- finished cloth gathering at the base, denser weave -->
    <g stroke="#818cf8" stroke-width="1.4" opacity="0.4">
      <line x1="120" y1="276" x2="980" y2="276" />
      <line x1="120" y1="290" x2="980" y2="290" stroke-dasharray="8 6" />
      <line x1="120" y1="304" x2="980" y2="304" stroke-dasharray="8 6" />
    </g>

    <!-- the cosmic-X: the shuttle, the single brightest thread in the weave -->
    <g transform="translate(548 104)">
      <g
        stroke="url(#lhx)"
        stroke-width="5.5"
        stroke-linecap="round"
        transform="translate(-12 -14)"
      >
        <line x1="0" y1="0" x2="24" y2="28" />
        <line x1="24" y1="0" x2="0" y2="28" />
      </g>
    </g>
  </svg>

  <div class="relative mx-auto max-w-3xl px-6 pb-14 pt-44 lg:pt-52">
    <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-indigo-200/80">
      <time datetime={date}>{date}</time>
      <span aria-hidden="true">·</span>
      <span>{readingMinutes} min read</span>
      {
        tags.map((tag) => (
          <span class="rounded-full border border-indigo-400/30 bg-indigo-500/10 px-2 py-0.5 font-mono lowercase text-indigo-200">
            {tag}
          </span>
        ))
      }
    </div>
    <h1 class="mt-4 text-4xl font-bold tracking-tight text-white drop-shadow lg:text-5xl">
      {title}
    </h1>
    <p class="mt-4 max-w-2xl text-lg leading-relaxed text-gray-300">{deck}</p>
  </div>
</section>
