---
// Decorative art for blog post #10 (exploration 0267), extracted so the same
// inline SVG backs both the post hero and the blog-index preview card (no
// external assets — Self-Audit parity). The scene is the essay's title drawn
// literally: on the left, a walled garden — high brick, clipped topiary showing
// above the top, a barred gate with no handle on the outside. On the right, an
// open workshop — a pegboard of hanging tools, a workbench with parts laid out
// mid-repair, and the cosmic-X glowing overhead as the work lamp. A dotted
// footpath runs from the gate to the bench: the walk from renting to making.
interface Props {
  /** Override the wrapper classes; defaults to full-bleed for hero use. */
  class?: string
}
const { class: className = 'pointer-events-none absolute inset-0 h-full w-full' } =
  Astro.props

// Brick courses for the garden wall (y of each mortar line).
const courses = [148, 176, 204, 232, 260, 288]
// The footpath from the gate out to the workbench.
const path = [
  [368, 306],
  [420, 298],
  [478, 296],
  [538, 300],
  [598, 296],
  [652, 292]
]
  .map(([x, y]) => `${x},${y}`)
  .join(' ')
---

<svg
  class={className}
  viewBox="0 0 1040 340"
  preserveAspectRatio="xMidYMid slice"
  aria-hidden="true"
>
  <defs>
    <linearGradient id="workshopbg" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#0a1122" />
      <stop offset="55%" stop-color="#0d1526" />
      <stop offset="100%" stop-color="#080d1a" />
    </linearGradient>
    <radialGradient id="lampglow" cx="50%" cy="50%" r="50%">
      <stop offset="0%" stop-color="#7dd3fc" stop-opacity="0.95" />
      <stop offset="45%" stop-color="#38bdf8" stop-opacity="0.38" />
      <stop offset="100%" stop-color="#38bdf8" stop-opacity="0" />
    </radialGradient>
    <linearGradient id="lampx" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#e0f2fe" />
      <stop offset="100%" stop-color="#38bdf8" />
    </linearGradient>
    <linearGradient id="benchglow" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#38bdf8" stop-opacity="0.14" />
      <stop offset="100%" stop-color="#38bdf8" stop-opacity="0" />
    </linearGradient>
  </defs>

  <rect width="1040" height="340" fill="url(#workshopbg)" />

  <!-- a scatter of faint stars over both halves -->
  <g fill="#7dd3fc" opacity="0.45">
    <circle cx="120" cy="52" r="1.2" />
    <circle cx="298" cy="38" r="1" />
    <circle cx="472" cy="60" r="1.4" />
    <circle cx="618" cy="34" r="1" />
    <circle cx="964" cy="72" r="1.2" />
    <circle cx="1006" cy="180" r="1" />
  </g>

  <!-- ground line shared by garden and workshop -->
  <line x1="0" y1="312" x2="1040" y2="312" stroke="#1e293b" stroke-width="1.6" opacity="0.9" />

  <!-- ============ left: the walled garden ============ -->
  <g>
    <!-- topiary showing above the wall: clipped, uniform, just out of reach -->
    <g fill="#123047" stroke="#1e5068" stroke-width="1.3">
      <circle cx="70" cy="120" r="22" />
      <circle cx="130" cy="112" r="26" />
      <circle cx="196" cy="118" r="21" />
      <circle cx="254" cy="110" r="25" />
      <circle cx="312" cy="120" r="20" />
    </g>

    <!-- the wall itself: brick courses with staggered joints -->
    <rect x="16" y="136" width="330" height="176" fill="#0e1b30" stroke="#27435c" stroke-width="1.6" />
    <g stroke="#22374d" stroke-width="1.1" opacity="0.85">
      {courses.map((y) => <line x1="16" y1={y} x2="346" y2={y} />)}
      <!-- staggered vertical joints, alternating offsets per course -->
      <g opacity="0.7">
        <line x1="76" y1="136" x2="76" y2="148" /><line x1="156" y1="136" x2="156" y2="148" /><line x1="236" y1="136" x2="236" y2="148" /><line x1="316" y1="136" x2="316" y2="148" />
        <line x1="116" y1="148" x2="116" y2="176" /><line x1="196" y1="148" x2="196" y2="176" /><line x1="276" y1="148" x2="276" y2="176" />
        <line x1="76" y1="176" x2="76" y2="204" /><line x1="156" y1="176" x2="156" y2="204" /><line x1="236" y1="176" x2="236" y2="204" /><line x1="316" y1="176" x2="316" y2="204" />
        <line x1="116" y1="204" x2="116" y2="232" /><line x1="196" y1="204" x2="196" y2="232" /><line x1="276" y1="204" x2="276" y2="232" />
        <line x1="76" y1="232" x2="76" y2="260" /><line x1="156" y1="232" x2="156" y2="260" /><line x1="236" y1="232" x2="236" y2="260" /><line x1="316" y1="232" x2="316" y2="260" />
        <line x1="116" y1="260" x2="116" y2="288" /><line x1="196" y1="260" x2="196" y2="288" /><line x1="276" y1="260" x2="276" y2="288" />
      </g>
    </g>

    <!-- the gate: arched, barred, and with no handle on this side -->
    <g>
      <path
        d="M 348 312 L 348 214 Q 380 186 412 214 L 412 312 Z"
        fill="#0a1526"
        stroke="#27435c"
        stroke-width="1.8"
      />
      <g stroke="#1e5068" stroke-width="2" stroke-linecap="round" opacity="0.9">
        <line x1="362" y1="208" x2="362" y2="306" />
        <line x1="380" y1="200" x2="380" y2="306" />
        <line x1="398" y1="208" x2="398" y2="306" />
      </g>
      <!-- the keyhole: someone else keeps the key -->
      <circle cx="380" cy="256" r="4.5" fill="none" stroke="#38bdf8" stroke-width="1.6" opacity="0.75" />
      <line x1="380" y1="260" x2="380" y2="268" stroke="#38bdf8" stroke-width="1.6" stroke-linecap="round" opacity="0.75" />
    </g>
  </g>

  <!-- the footpath: out of the garden, over to the bench -->
  <polyline
    points={path}
    fill="none"
    stroke="#7dd3fc"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    stroke-dasharray="1 8"
    opacity="0.7"
  />

  <!-- ============ right: the open workshop ============ -->
  <g>
    <!-- pegboard: a grid of holes, tools hung where their outlines are drawn -->
    <rect x="700" y="96" width="300" height="128" rx="6" fill="#0e1b30" stroke="#27435c" stroke-width="1.6" />
    <g fill="#22374d">
      {
        [0, 1, 2, 3].map((row) =>
          [0, 1, 2, 3, 4, 5, 6, 7, 8].map((col) => (
            <circle cx={722 + col * 32} cy={116 + row * 28} r="2" />
          ))
        )
      }
    </g>
    <!-- hung tools, drawn as simple silhouettes: spanner, hammer, screwdriver -->
    <g stroke="#7dd3fc" stroke-width="2" stroke-linecap="round" fill="none" opacity="0.85">
      <!-- spanner -->
      <line x1="738" y1="128" x2="738" y2="176" />
      <circle cx="738" cy="120" r="7" />
      <!-- hammer -->
      <line x1="806" y1="126" x2="806" y2="182" />
      <rect x="792" y="112" width="28" height="12" rx="3" fill="#123047" />
      <!-- screwdriver -->
      <line x1="872" y1="118" x2="872" y2="150" />
      <line x1="872" y1="150" x2="872" y2="178" stroke-width="3.2" />
      <!-- one empty outline: a tool out being used right now -->
      <g stroke-dasharray="2 4" opacity="0.55">
        <line x1="938" y1="128" x2="938" y2="176" />
        <circle cx="938" cy="120" r="7" />
      </g>
    </g>

    <!-- the bench, lit from above -->
    <rect x="668" y="238" width="356" height="52" fill="url(#benchglow)" />
    <rect x="676" y="252" width="340" height="10" rx="3" fill="#123047" stroke="#1e5068" stroke-width="1.4" />
    <g stroke="#1e5068" stroke-width="3" stroke-linecap="round">
      <line x1="700" y1="262" x2="700" y2="310" />
      <line x1="992" y1="262" x2="992" y2="310" />
    </g>
    <!-- parts on the bench: a thing mid-repair, opened rather than sealed -->
    <g stroke="#7dd3fc" stroke-width="1.6" fill="#0a1526" opacity="0.9">
      <rect x="742" y="234" width="40" height="18" rx="3" />
      <rect x="796" y="240" width="18" height="12" rx="2" />
      <circle cx="842" cy="246" r="6" />
      <g stroke-width="1.2" opacity="0.8">
        <line x1="864" y1="250" x2="884" y2="238" />
        <line x1="884" y1="238" x2="904" y2="248" />
      </g>
      <circle cx="922" cy="246" r="4" />
    </g>

    <!-- the work lamp: the cosmic-X, glowing over the bench -->
    <g transform="translate(848 58)">
      <circle cx="0" cy="0" r="38" fill="url(#lampglow)" />
      <g stroke="url(#lampx)" stroke-width="5.5" stroke-linecap="round" transform="translate(-11 -11)">
        <line x1="0" y1="0" x2="22" y2="22" />
        <line x1="22" y1="0" x2="0" y2="22" />
      </g>
    </g>
  </g>
</svg>
