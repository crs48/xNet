---
// A small syntax-highlighted code figure for the (non-MDX) blog (exploration
// 0248). Reuses the site's own highlighting idiom — pre-tokenized HTML with
// `tok-*` spans coloured by the CSS variables in Base.astro, plus the global
// `.copy-btn` handler — so blog code matches the landing page's CodeBlock
// exactly, with no foreign Shiki theme and no extra client JS. Pass `code` as
// already-highlighted HTML (build it with the kw/ty/fn/st/nu/cm helpers in the
// page frontmatter). An optional `caption` carries the one-sentence,
// plain-English gloss the deep-dive post puts under every snippet.
interface Props {
  /** Pre-highlighted HTML (tok-* spans), entities already escaped. */
  code: string
  /** Optional file label shown in the title bar. */
  filename?: string
  /** Optional plain-English caption under the figure. */
  caption?: string
}
const { code, filename, caption } = Astro.props
---

<figure class="not-prose my-6">
  <div class="group relative min-w-0 overflow-hidden rounded-xl border border-border bg-code-bg">
    {
      filename && (
        <div class="border-b border-border px-4 py-2 font-mono text-xs text-gray-500">
          {filename}
        </div>
      )
    }
    <div class="relative">
      <pre class="lp-code overflow-x-auto p-5 font-mono text-sm leading-relaxed"><code set:html={code} /></pre>
      <button
        class="copy-btn absolute right-3 top-3 rounded-md border border-border bg-surface px-2 py-1 text-xs text-gray-500 opacity-0 transition-opacity hover:text-gray-700 group-hover:opacity-100 dark:hover:text-gray-300"
        aria-label="Copy code"
      >
        Copy
      </button>
    </div>
  </div>
  {
    caption && (
      <figcaption class="mt-2.5 text-sm leading-relaxed text-gray-500 dark:text-gray-400">
        {caption}
      </figcaption>
    )
  }
</figure>
