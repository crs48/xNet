---
// Decorative art for blog post #13 (exploration 0292), extracted so the same
// inline SVG backs both the post hero and the blog-index preview card (no
// external assets — Self-Audit parity). A two-pan balance, tipped: on one side
// a stack of brass kilogram weights — the things you can hold — and on the
// other the cosmic-X, glowing amber, weighing in with them rather than against
// them. Behind it, faint, the essay's other figure: history as a spiral.
interface Props {
  /** Override the wrapper classes; defaults to full-bleed for hero use. */
  class?: string
}
const { class: className = 'pointer-events-none absolute inset-0 h-full w-full' } =
  Astro.props

// Beam geometry: the pivot sits on the column; the beam tips toward the
// weights side (owned things have weight; rented things weigh nothing).
const pivotX = 520
const pivotY = 128
const beam = { x1: 300, y1: 152, x2: 740, y2: 108 }
// Pan drop-lines hang from the beam ends.
const leftPan = { x: beam.x1, y: beam.y1 + 74 }
const rightPan = { x: beam.x2, y: beam.y2 + 96 }
---

<svg
  class={className}
  viewBox="0 0 1040 340"
  preserveAspectRatio="xMidYMid slice"
  aria-hidden="true"
>
  <defs>
    <linearGradient id="wbg" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#14100a" />
      <stop offset="55%" stop-color="#120d07" />
      <stop offset="100%" stop-color="#0b0805" />
    </linearGradient>
    <radialGradient id="wglow" cx="50%" cy="50%" r="50%">
      <stop offset="0%" stop-color="#fbbf24" stop-opacity="0.9" />
      <stop offset="45%" stop-color="#f59e0b" stop-opacity="0.35" />
      <stop offset="100%" stop-color="#f59e0b" stop-opacity="0" />
    </radialGradient>
    <linearGradient id="wx" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#fde68a" />
      <stop offset="100%" stop-color="#f59e0b" />
    </linearGradient>
    <linearGradient id="brass" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#b45309" />
      <stop offset="100%" stop-color="#78350f" />
    </linearGradient>
  </defs>

  <rect width="1040" height="340" fill="url(#wbg)" />

  <!-- history as a spiral, faint, behind the balance: three widening turns -->
  <path
    d="M 520 150
       a 26 26 0 1 1 52 0
       a 52 50 0 1 1 -104 0
       a 88 84 0 1 1 176 0
       a 132 126 0 1 1 -264 0"
    fill="none"
    stroke="#3d3221"
    stroke-width="1.5"
    opacity="0.45"
  />

  <!-- ledger lines: the ground the scale stands on -->
  <g stroke="#39301f" stroke-width="1" opacity="0.4">
    <line x1="0" y1="262" x2="1040" y2="262" />
    <line x1="0" y1="294" x2="1040" y2="294" />
    <line x1="0" y1="326" x2="1040" y2="326" />
  </g>

  <!-- column and foot -->
  <line x1={pivotX} y1={pivotY} x2={pivotX} y2="252" stroke="#57431f" stroke-width="6" stroke-linecap="round" opacity="0.9" />
  <path d={`M ${pivotX - 46} 262 L ${pivotX} 240 L ${pivotX + 46} 262 Z`} fill="#2c2314" stroke="#57431f" stroke-width="1.5" />

  <!-- beam, tipped toward the weights -->
  <line
    x1={beam.x1}
    y1={beam.y1}
    x2={beam.x2}
    y2={beam.y2}
    stroke="#e7c98a"
    stroke-width="5"
    stroke-linecap="round"
    opacity="0.85"
  />
  <circle cx={pivotX} cy={pivotY} r="7" fill="#2c2314" stroke="#fbbf24" stroke-width="2" />

  <!-- left pan: the stack of brass weights, hanging lower -->
  <g opacity="0.95">
    <line x1={beam.x1} y1={beam.y1} x2={leftPan.x} y2={leftPan.y} stroke="#8a6a33" stroke-width="1.6" />
    <path d={`M ${leftPan.x - 58} ${leftPan.y} h 116 l -10 12 h -96 Z`} fill="#2c2314" stroke="#8a6a33" stroke-width="1.5" />
    <!-- three kilogram weights, largest at the bottom, ring handles on top -->
    <g transform={`translate(${leftPan.x} ${leftPan.y})`}>
      <path d="M -40 0 L -32 -30 h 64 l 8 30 Z" fill="url(#brass)" stroke="#d97706" stroke-width="1.4" />
      <path d="M -28 -30 L -22 -52 h 44 l 6 22 Z" fill="url(#brass)" stroke="#d97706" stroke-width="1.4" />
      <path d="M -17 -52 L -13 -68 h 26 l 4 16 Z" fill="url(#brass)" stroke="#d97706" stroke-width="1.4" />
      <path d="M -7 -68 a 7 7 0 0 1 14 0" fill="none" stroke="#fbbf24" stroke-width="2.4" stroke-linecap="round" />
    </g>
  </g>

  <!-- right pan: the cosmic-X, glowing amber, riding higher on the beam -->
  <g opacity="0.95">
    <line x1={beam.x2} y1={beam.y2} x2={rightPan.x} y2={rightPan.y} stroke="#8a6a33" stroke-width="1.6" />
    <path d={`M ${rightPan.x - 58} ${rightPan.y} h 116 l -10 12 h -96 Z`} fill="#2c2314" stroke="#8a6a33" stroke-width="1.5" />
    <g transform={`translate(${rightPan.x} ${rightPan.y - 34})`}>
      <circle cx="0" cy="0" r="38" fill="url(#wglow)" />
      <g stroke="url(#wx)" stroke-width="5.5" stroke-linecap="round" transform="translate(-10 -11)">
        <line x1="0" y1="0" x2="20" y2="22" />
        <line x1="20" y1="0" x2="0" y2="22" />
      </g>
    </g>
  </g>
</svg>
