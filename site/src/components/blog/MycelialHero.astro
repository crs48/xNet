---
// Original art for blog post #2 (exploration 0240). The underground twin of
// PirateHero: where the pirate hero looked UP at a sea of islands joined by
// dotted sea-lanes, this looks DOWN — a soil cross-section where the cosmic-X
// glows as one luminous node in a branching mycelial web. All inline SVG, no
// external assets, so the page ships nothing third-party (Self-Audit parity).
interface Props {
  title: string
  deck: string
  date: string
  readingMinutes: number
  tags: string[]
}
const { title, deck, date, readingMinutes, tags } = Astro.props

// Hub nodes in the underground web (where hyphae fuse / a root tip meets fungus).
// Hand-placed below the soil line (y≈150) so the composition reads as a network
// permeating the substrate. Node index 3 is the bright cosmic-X hub.
const nodes = [
  { x: 150, y: 250, r: 4 },
  { x: 300, y: 210, r: 5 },
  { x: 430, y: 285, r: 4 },
  { x: 545, y: 235, r: 9 }, // the cosmic-X hub
  { x: 690, y: 280, r: 5 },
  { x: 815, y: 215, r: 4 },
  { x: 930, y: 265, r: 5 }
]
// Hyphae fusing a subset of nodes — most threads pass through the central hub,
// the way a healthy network routes through many paths rather than one centre.
const hyphae = [
  [0, 1],
  [1, 3],
  [0, 3],
  [2, 3],
  [3, 4],
  [3, 5],
  [4, 6],
  [5, 6],
  [1, 2]
]
// Fine hair-like filaments radiating from each hub into the substrate.
const filaments = nodes.flatMap((n, i) =>
  [0, 1, 2].map((k) => {
    const angle = (i * 1.7 + k * 2.3) % (Math.PI * 2)
    const len = 18 + ((i + k) % 3) * 10
    return {
      x1: n.x,
      y1: n.y,
      x2: n.x + Math.cos(angle) * len,
      y2: n.y + Math.sin(angle) * len * 0.7
    }
  })
)
---

<section class="relative overflow-hidden border-b border-border bg-surface/20 dark:bg-[#06080a]">
  <svg
    class="pointer-events-none absolute inset-0 h-full w-full"
    viewBox="0 0 1040 340"
    preserveAspectRatio="xMidYMid slice"
    aria-hidden="true"
  >
    <defs>
      <linearGradient id="substrate" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#0a1410" />
        <stop offset="45%" stop-color="#0b1a14" />
        <stop offset="100%" stop-color="#06100c" />
      </linearGradient>
      <radialGradient id="myglow" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#34d399" stop-opacity="0.9" />
        <stop offset="100%" stop-color="#34d399" stop-opacity="0" />
      </radialGradient>
      <linearGradient id="myxflag" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#818cf8" />
        <stop offset="100%" stop-color="#34d399" />
      </linearGradient>
    </defs>

    <rect width="1040" height="340" fill="url(#substrate)" />

    <!-- forest floor: a thin canopy strip up top with trunks descending into roots -->
    <g stroke="#1f3a2e" stroke-width="2" fill="none" opacity="0.8">
      <line x1="0" y1="120" x2="1040" y2="120" />
    </g>
    <g fill="#13241c">
      <rect x="190" y="60" width="8" height="60" rx="2" />
      <rect x="520" y="48" width="10" height="72" rx="2" />
      <rect x="780" y="66" width="7" height="54" rx="2" />
      <!-- canopy blobs -->
      <ellipse cx="194" cy="56" rx="40" ry="22" />
      <ellipse cx="525" cy="44" rx="52" ry="28" />
      <ellipse cx="783" cy="62" rx="34" ry="20" />
    </g>
    <!-- roots reaching down from the trunks toward the web -->
    <g stroke="#15281e" stroke-width="2.5" fill="none" stroke-linecap="round" opacity="0.9">
      <path d="M194 120 C 190 150, 170 180, 150 250" />
      <path d="M525 120 C 528 150, 540 190, 545 235" />
      <path d="M783 120 C 786 150, 800 185, 815 215" />
    </g>

    <!-- fine filaments radiating into the substrate -->
    <g stroke="#2f6f53" stroke-width="0.8" opacity="0.5">
      {filaments.map((f) => <line x1={f.x1} y1={f.y1} x2={f.x2} y2={f.y2} />)}
    </g>

    <!-- hyphae: the load-bearing threads between hubs -->
    <g stroke="#3fae7d" stroke-width="1.4" stroke-dasharray="2 5" fill="none" opacity="0.85">
      {
        hyphae.map(([a, b]) => (
          <line x1={nodes[a].x} y1={nodes[a].y} x2={nodes[b].x} y2={nodes[b].y} />
        ))
      }
    </g>

    <!-- hub nodes -->
    <g>
      {
        nodes.map((n, i) =>
          i === 3 ? null : (
            <circle cx={n.x} cy={n.y} r={n.r} fill="#5eead4" opacity="0.85" />
          )
        )
      }
    </g>

    <!-- the cosmic-X, glowing as the brightest node in the web -->
    <g transform={`translate(${nodes[3].x} ${nodes[3].y})`}>
      <circle cx="0" cy="0" r="46" fill="url(#myglow)" opacity="0.7" />
      <g stroke="url(#myxflag)" stroke-width="5" stroke-linecap="round" transform="translate(-11 -13)">
        <line x1="0" y1="0" x2="22" y2="26" />
        <line x1="22" y1="0" x2="0" y2="26" />
      </g>
    </g>
  </svg>

  <div class="relative mx-auto max-w-3xl px-6 pb-14 pt-44 lg:pt-52">
    <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-emerald-200/80">
      <time datetime={date}>{date}</time>
      <span aria-hidden="true">·</span>
      <span>{readingMinutes} min read</span>
      {
        tags.map((tag) => (
          <span class="rounded-full border border-emerald-400/30 bg-emerald-500/10 px-2 py-0.5 font-mono lowercase text-emerald-200">
            {tag}
          </span>
        ))
      }
    </div>
    <h1 class="mt-4 text-4xl font-bold tracking-tight text-white drop-shadow lg:text-5xl">
      {title}
    </h1>
    <p class="mt-4 max-w-2xl text-lg leading-relaxed text-gray-300">{deck}</p>
  </div>
</section>
