---
// Decorative art for blog post #17 (exploration 0354), extracted so the same
// inline SVG backs both the post hero and the blog-index preview card (no
// external assets — the series' "loads nothing third-party" promise holds
// literally). The essay's argument in one frame: on the left, a palimpsest —
// faint amber underwriting running vertically (the pages were rotated when
// they were reused), with a ghost of an Archimedean circle diagram, struck
// through by the bold violet lines of the overwriting. On the right, the
// alternative: a signed change log, where both layers survive side by side —
// nothing scraped, every block keeping its signature — ending at the
// cosmic-X, still legible. The knife saves nothing here.
interface Props {
  /** Override the wrapper classes; defaults to full-bleed for hero use. */
  class?: string
}
const { class: className = 'pointer-events-none absolute inset-0 h-full w-full' } =
  Astro.props

// --- left page: the palimpsest ---
// Underwriting: short vertical strokes in loose columns (the erased text,
// perpendicular to the prayers because the reused pages were turned 90°).
const underCols = [120, 160, 200, 240, 280, 320, 360] as const
// Overwriting: bold horizontal lines (the prayer book), with ragged ends.
const overLines = [
  [96, 64, 300],
  [96, 96, 268],
  [96, 128, 312],
  [96, 160, 240],
  [96, 192, 296],
  [96, 224, 258],
  [96, 256, 306]
] as const

// --- right page: the log ---
// A chain of signed blocks; each keeps BOTH layers (an amber under-stroke and
// a violet over-stroke) — accretion instead of erasure.
const blocks = [560, 634, 708, 782, 856] as const
const blockY = 176
---

<svg
  class={className}
  viewBox="0 0 1040 340"
  preserveAspectRatio="xMidYMid slice"
  aria-hidden="true"
>
  <defs>
    <linearGradient id="ppbg" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#100c1d" />
      <stop offset="55%" stop-color="#0c0917" />
      <stop offset="100%" stop-color="#080611" />
    </linearGradient>
    <radialGradient id="ppglow" cx="50%" cy="50%" r="50%">
      <stop offset="0%" stop-color="#fbbf24" stop-opacity="0.85" />
      <stop offset="45%" stop-color="#f59e0b" stop-opacity="0.3" />
      <stop offset="100%" stop-color="#f59e0b" stop-opacity="0" />
    </radialGradient>
    <linearGradient id="ppx" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#fde68a" />
      <stop offset="100%" stop-color="#f59e0b" />
    </linearGradient>
  </defs>

  <rect width="1040" height="340" fill="url(#ppbg)" />

  <!-- the left page: parchment edge -->
  <rect
    x="72"
    y="36"
    width="352"
    height="252"
    rx="10"
    fill="none"
    stroke="#5b4a8f"
    stroke-width="1.2"
    opacity="0.45"
  />

  <!-- underwriting: the erased mathematics, vertical, barely there -->
  <g stroke="#f59e0b" stroke-width="1.4" stroke-linecap="round" opacity="0.28">
    {
      underCols.map((x, i) => (
        <g>
          <line x1={x} y1={58 + (i % 3) * 8} x2={x} y2={104 + (i % 2) * 10} />
          <line x1={x} y1={126 + (i % 2) * 6} x2={x} y2={168 + (i % 3) * 8} />
          <line x1={x} y1={190 + (i % 3) * 6} x2={x} y2={236 + (i % 2) * 12} />
          <line x1={x} y1={252} x2={x} y2={268 + (i % 2) * 6} />
        </g>
      ))
    }
  </g>
  <!-- the ghost of a diagram: Archimedes' circles, almost scraped away -->
  <g fill="none" stroke="#f59e0b" opacity="0.22">
    <circle cx="248" cy="162" r="58" stroke-width="1.3" />
    <circle cx="248" cy="162" r="34" stroke-width="1" stroke-dasharray="6 5" />
    <path d="M 202 198 L 248 104 L 294 198 Z" stroke-width="1" />
  </g>

  <!-- overwriting: the prayer book, bold, horizontal, on top -->
  <g stroke="#a78bfa" stroke-width="5" stroke-linecap="round" opacity="0.6">
    {overLines.map(([x, y, len]) => <line x1={x} y1={y} x2={x + len} y2={y} />)}
  </g>

  <!-- the knife: one clean diagonal scrape across the page -->
  <line
    x1="106"
    y1="276"
    x2="398"
    y2="52"
    stroke="#e2e8f0"
    stroke-width="1"
    opacity="0.28"
    stroke-dasharray="2 7"
  />

  <!-- the right page: the log — both layers kept, nothing scraped -->
  <g>
    {
      blocks.map((x, i) => (
        <g opacity={0.45 + i * 0.12}>
          <rect
            x={x - 15}
            y={blockY - 15}
            width="30"
            height="30"
            rx="6"
            fill="none"
            stroke="#a78bfa"
            stroke-width="1.5"
          />
          {/* the underwriting survives inside every block… */}
          <line
            x1={x - 6}
            y1={blockY - 7}
            x2={x - 6}
            y2={blockY + 7}
            stroke="#f59e0b"
            stroke-width="1.6"
            stroke-linecap="round"
            opacity="0.8"
          />
          {/* …alongside the overwriting */}
          <line
            x1={x + 0}
            y1={blockY + 2}
            x2={x + 8}
            y2={blockY + 2}
            stroke="#a78bfa"
            stroke-width="2.2"
            stroke-linecap="round"
          />
          {/* the parent-hash link to the next block */}
          <line
            x1={x + 15}
            y1={blockY}
            x2={x + 59}
            y2={blockY}
            stroke="#5b4a8f"
            stroke-width="1.4"
            stroke-dasharray="5 4"
          />
        </g>
      ))
    }
  </g>

  <!-- the last link arrives at the core: still legible, still signed -->
  <g transform={`translate(${blocks[blocks.length - 1] + 92} ${blockY})`}>
    <circle cx="0" cy="0" r="42" fill="url(#ppglow)" />
    <g stroke="url(#ppx)" stroke-width="5.5" stroke-linecap="round" transform="translate(-11 -12)">
      <line x1="0" y1="0" x2="22" y2="24" />
      <line x1="22" y1="0" x2="0" y2="24" />
    </g>
  </g>
</svg>
