---
/**
 * One word that rolls through a short list — inline, baseline-aligned, so it sits
 * inside a sentence. Used for a single emphasis word in the hero subhead.
 *
 * Accessibility: the canonical first word is exposed to assistive tech; the
 * animated copies are aria-hidden. Under prefers-reduced-motion only the first
 * word renders (no roll). Adapted from performative-ui's WordRoll (MIT) —
 * github.com/vorpus/performativeUI. See src/components/ui/README.md.
 */
interface Props {
  words: string[]
  /** Seconds each word stays before rolling. */
  hold?: number
  class?: string
}
const { words, hold = 2, class: cls = '' } = Astro.props
const cycle = Math.max(1, words.length) * hold
---

<span class={`word-roll ${cls}`} style={`--wr-cycle:${cycle}s`}>
  {
    words.map((w, i) => (
      <span
        class="word-roll__item"
        style={`animation-delay:${i * hold}s`}
        aria-hidden={i === 0 ? undefined : 'true'}
      >
        {w}
      </span>
    ))
  }
</span>

<style>
  .word-roll {
    display: inline-grid;
    overflow: hidden;
    height: 1.15em;
    vertical-align: bottom;
  }
  .word-roll__item {
    grid-area: 1 / 1;
    white-space: nowrap;
    opacity: 0;
    transform: translateY(100%);
    animation: wr-roll var(--wr-cycle) linear infinite;
  }
  @keyframes wr-roll {
    0% {
      opacity: 0;
      transform: translateY(100%);
    }
    6% {
      opacity: 1;
      transform: translateY(0);
    }
    28% {
      opacity: 1;
      transform: translateY(0);
    }
    34% {
      opacity: 0;
      transform: translateY(-100%);
    }
    100% {
      opacity: 0;
      transform: translateY(-100%);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .word-roll {
      height: auto;
    }
    .word-roll__item {
      animation: none;
      opacity: 1;
      transform: none;
    }
    .word-roll__item:not(:first-of-type) {
      display: none;
    }
  }
</style>
