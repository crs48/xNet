---
/**
 * Animated count-up number. Counts 0 → `value` once when scrolled into view,
 * then settles on the exact value. Renders the *final* formatted value in the
 * HTML, so no-JS and reduced-motion users always see the true number (and there
 * is no layout shift). Drop it inside existing card markup as an inline span.
 *
 * Visual technique adapted from performative-ui's StatCounter (MIT) —
 * github.com/vorpus/performativeUI. See src/components/ui/README.md.
 */
interface Props {
  value: number
  /** plain: 1,234 · usd: $1,234 · compact: 48.2K · gb: 1.2 TB / 940 GB */
  format?: 'plain' | 'usd' | 'compact' | 'gb'
  prefix?: string
  suffix?: string
  durationMs?: number
  class?: string
}
const {
  value,
  format = 'plain',
  prefix = '',
  suffix = '',
  durationMs = 1200,
  class: cls = ''
} = Astro.props

const compact = (n: number) =>
  new Intl.NumberFormat('en-US', { notation: 'compact', maximumFractionDigits: 1 }).format(n)

function fmt(n: number): string {
  if (format === 'usd') return `$${Math.round(n).toLocaleString('en-US')}`
  if (format === 'compact') return compact(n)
  if (format === 'gb') return n >= 1024 ? `${(n / 1024).toFixed(1)} TB` : `${compact(n)} GB`
  return Math.round(n).toLocaleString('en-US')
}
---

<span
  class={`stat-counter tabular-nums ${cls}`}
  data-target={value}
  data-format={format}
  data-prefix={prefix}
  data-suffix={suffix}
  data-duration={durationMs}>{prefix}{fmt(value)}{suffix}</span>

<script>
  import { prefersReducedMotion, observeOnce, easeOutCubic } from '../../lib/motion'

  const els = Array.from(document.querySelectorAll<HTMLElement>('.stat-counter'))
  if (els.length && !prefersReducedMotion()) {
    const compact = (n: number) =>
      new Intl.NumberFormat('en-US', { notation: 'compact', maximumFractionDigits: 1 }).format(n)
    const fmt = (n: number, format: string) => {
      if (format === 'usd') return `$${Math.round(n).toLocaleString('en-US')}`
      if (format === 'compact') return compact(n)
      if (format === 'gb') return n >= 1024 ? `${(n / 1024).toFixed(1)} TB` : `${compact(n)} GB`
      return Math.round(n).toLocaleString('en-US')
    }
    const paint = (el: HTMLElement, n: number) => {
      el.textContent = `${el.dataset.prefix ?? ''}${fmt(n, el.dataset.format ?? 'plain')}${el.dataset.suffix ?? ''}`
    }
    // Reset to 0 up front so the count-up reads cleanly even for counters that
    // are already in view on load.
    els.forEach((el) => paint(el, 0))
    observeOnce(els, (node) => {
      const el = node as HTMLElement
      const target = Number(el.dataset.target ?? 0)
      const dur = Number(el.dataset.duration ?? 1200)
      const t0 = performance.now()
      const tick = (now: number) => {
        const p = Math.min(1, (now - t0) / dur)
        if (p < 1) {
          paint(el, easeOutCubic(p) * target)
          requestAnimationFrame(tick)
        } else {
          paint(el, target) // exact final value
        }
      }
      requestAnimationFrame(tick)
    })
  }
</script>
