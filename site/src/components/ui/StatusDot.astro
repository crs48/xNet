---
/**
 * StatusDot — an *honest* status indicator. The colour/label come from the real
 * published status (`data/status.json`, server-rendered); pass `liveUrl` to also
 * refresh from the control plane's live `/status.json` on the client. Green only
 * when it's actually green — the inverse of the "always green" trope.
 *
 * Adapted from performative-ui's StatusDot (MIT) — github.com/vorpus/performativeUI.
 * See src/components/ui/README.md.
 */
import { STATUS_COLORS, STATUS_LABELS, type ComponentStatus } from '../../data/status'

interface Props {
  status: ComponentStatus
  label?: string
  liveUrl?: string
  class?: string
}
const { status, label, liveUrl, class: cls = '' } = Astro.props
const color = STATUS_COLORS[status]
const text = label ?? STATUS_LABELS[status]
---

<span class={`inline-flex items-center gap-1.5 ${cls}`} data-status-dot data-live-url={liveUrl}>
  <span class="relative flex h-2 w-2">
    {
      status === 'operational' && (
        <span
          class="absolute inline-flex h-full w-full animate-ping rounded-full opacity-60"
          style={`background:${color}`}
          data-dot-ping
        />
      )
    }
    <span class="relative inline-flex h-2 w-2 rounded-full" style={`background:${color}`} data-dot-core></span>
  </span>
  <span data-status-label>{text}</span>
</span>

<script>
  import { STATUS_COLORS, STATUS_LABELS } from '../../data/status'

  document.querySelectorAll<HTMLElement>('[data-status-dot][data-live-url]').forEach(async (el) => {
    const url = el.dataset.liveUrl
    if (!url) return
    try {
      const res = await fetch(url, { headers: { accept: 'application/json' } })
      if (!res.ok) return
      const data = (await res.json()) as { overall: keyof typeof STATUS_COLORS }
      const color = STATUS_COLORS[data.overall] ?? STATUS_COLORS['not-configured']
      el.querySelectorAll<HTMLElement>('[data-dot-core], [data-dot-ping]').forEach((d) => {
        d.style.background = color
      })
      const label = el.querySelector('[data-status-label]')
      if (label) label.textContent = STATUS_LABELS[data.overall] ?? data.overall
    } catch {
      // keep the server-rendered snapshot
    }
  })
</script>
