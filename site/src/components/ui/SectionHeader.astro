---
interface Props {
  title: string
  subtitle?: string
  align?: 'left' | 'center'
}

const { title, subtitle, align = 'left' } = Astro.props
const alignClass = align === 'center' ? 'text-center' : ''
---

<div class={`${alignClass}`}>
  <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
    <span class="bg-gradient-to-br from-white to-gray-400 bg-clip-text text-transparent">
      {title}
    </span>
  </h2>
  {subtitle && (
    <p class={`mt-3 text-lg text-gray-400 ${align === 'center' ? 'mx-auto max-w-2xl' : 'max-w-2xl'}`}>
      {subtitle}
    </p>
  )}
</div>
