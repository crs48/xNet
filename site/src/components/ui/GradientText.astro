---
interface Props {
  as?: 'span' | 'h1' | 'h2' | 'h3'
  gradient?: string
  class?: string
}

const { as: Tag = 'span', gradient = 'from-white via-gray-200 to-indigo-400', class: className = '' } = Astro.props
---

<Tag class={`bg-gradient-to-br ${gradient} bg-clip-text text-transparent ${className}`}>
  <slot />
</Tag>
