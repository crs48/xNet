---
/**
 * LogoRow — a quiet row of wordmarks for the standards xNet is built on. The
 * honest inversion of the "trusted by logos you've heard of" trope: these are
 * real, verifiable building blocks, shown as restrained monospace wordmarks
 * (we don't ship third-party logos). Muted by default, tinting on hover.
 *
 * Adapted from performative-ui's LogoRow (MIT) — github.com/vorpus/performativeUI.
 * See src/components/ui/README.md.
 */
interface Props {
  items: string[]
  title?: string
  class?: string
}
const { items, title, class: cls = '' } = Astro.props
---

<div class={cls}>
  {
    title && (
      <p class="mb-6 text-center text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">
        {title}
      </p>
    )
  }
  <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
    {
      items.map((it) => (
        <span class="font-mono text-sm text-gray-400 opacity-70 transition-all hover:text-indigo-500 hover:opacity-100 dark:text-gray-500 dark:hover:text-indigo-400">
          {it}
        </span>
      ))
    }
  </div>
</div>
