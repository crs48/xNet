---
import SectionHeader from '../ui/SectionHeader.astro'

const examples = [
  {
    title: 'Collaborative Document Editor',
    description: 'Rich text with Yjs CRDTs. Character-level merging. Real-time cursors. Like Notion, but data never leaves your devices.',
    color: 'indigo',
    code: `const { doc } = useNode(PageSchema, id)
// Plug into TipTap, ProseMirror, etc.
<Editor doc={doc} />`,
  },
  {
    title: 'Local-First Database',
    description: '15 property types, relations, views, filters. Like Airtable, with real-time P2P sync and offline support.',
    color: 'emerald',
    code: `const schema = defineSchema({
  name: 'Contact',
  properties: {
    name: text({ required: true }),
    email: text({ format: 'email' }),
    company: relation({ target: CompanySchema }),
  }
})`,
  },
  {
    title: 'Personal Knowledge Garden',
    description: 'Infinite canvas, linked notes, backlinks. Like Obsidian with structured data and cross-device sync.',
    color: 'amber',
    code: `const { data: notes } = useQuery(NoteSchema, {
  where: { linkedTo: currentNoteId },
  orderBy: { updatedAt: 'desc' }
})`,
  },
  {
    title: 'Team Workspace',
    description: 'Schemas, views, and real-time collaboration. Like Linear, with P2P sync and no monthly per-seat fees.',
    color: 'pink',
    code: `const { data: tasks } = useQuery(TaskSchema, {
  where: { assignee: myDid, status: 'active' },
  orderBy: { priority: 'desc' }
})`,
  },
  {
    title: 'AI-Augmented Tools',
    description: 'AI agents read/write via MCP protocol. Same type-safe API. Same schemas. AI as a collaborative peer.',
    color: 'purple',
    code: `// AI connects via MCP server
// Same typed operations as React hooks
await mcp.create(TaskSchema, {
  title: ai.suggestedTitle,
  status: 'review'
})`,
  },
  {
    title: 'Media-Rich Apps',
    description: 'Content-addressed blob storage with BLAKE3 hashes. Upload images, files, and attachments — auto-compressed, deduplicated, and P2P synced between devices.',
    color: 'blue',
    code: `import { useImageUpload } from '@xnet/editor'

const upload = useImageUpload()
// Auto-compresses, generates CID
const ref = await upload(file)
// { cid: 'cid:blake3:a1b2...', name, size }
// Syncs to peers via blob-sync protocol`,
  },
]

const colorMap: Record<string, { border: string, bg: string, text: string, dot: string }> = {
  indigo: { border: 'border-indigo-500/20', bg: 'bg-indigo-500/[0.03]', text: 'text-indigo-400', dot: 'bg-indigo-500' },
  emerald: { border: 'border-emerald-500/20', bg: 'bg-emerald-500/[0.03]', text: 'text-emerald-400', dot: 'bg-emerald-500' },
  amber: { border: 'border-amber-500/20', bg: 'bg-amber-500/[0.03]', text: 'text-amber-400', dot: 'bg-amber-500' },
  pink: { border: 'border-pink-500/20', bg: 'bg-pink-500/[0.03]', text: 'text-pink-400', dot: 'bg-pink-500' },
  purple: { border: 'border-purple-500/20', bg: 'bg-purple-500/[0.03]', text: 'text-purple-400', dot: 'bg-purple-500' },
  blue: { border: 'border-blue-500/20', bg: 'bg-blue-500/[0.03]', text: 'text-blue-400', dot: 'bg-blue-500' },
}
---

<section id="build" class="py-24 lg:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <SectionHeader
      title="What you can build"
      subtitle="xNet gives you the data primitives. You decide what to make."
      align="center"
    />

    <div class="mt-16 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {examples.map((ex) => {
        const c = colorMap[ex.color]
        return (
          <div class={`animate-on-scroll min-w-0 rounded-xl border ${c.border} ${c.bg} p-6 transition-all duration-300 hover:border-opacity-40`}>
            <div class="flex items-center gap-2 mb-3">
              <span class={`h-2 w-2 rounded-full ${c.dot}`}></span>
              <h3 class={`font-semibold ${c.text}`}>{ex.title}</h3>
            </div>
            <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed">{ex.description}</p>
            <div class="group/code relative mt-4 overflow-hidden rounded-lg border border-border bg-code-bg">
              <pre class="overflow-x-auto p-3 font-mono text-xs leading-relaxed text-gray-500"><code>{ex.code}</code></pre>
              <button class="copy-btn absolute right-2 top-2 rounded border border-border bg-surface px-1.5 py-0.5 text-[10px] text-gray-500 opacity-0 transition-opacity hover:text-gray-700 dark:hover:text-gray-300 group-hover/code:opacity-100" aria-label="Copy code">Copy</button>
            </div>
          </div>
        )
      })}
    </div>
  </div>
</section>
