---
import SectionHeader from '../ui/SectionHeader.astro'

const stats = [
  {
    value: '1M x',
    label: 'less energy per read',
    detail: 'Local SSD vs cloud round-trip',
    color: 'emerald',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>',
  },
  {
    value: '99.9%',
    label: 'less data transferred',
    detail: 'CRDT deltas vs REST re-fetching',
    color: 'indigo',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 17h8m0 0V9m0 8l-8-8-4 4-6-6"/>',
  },
  {
    value: '$0',
    label: 'egress cost per GB',
    detail: 'vs $0.05–$0.12/GB cloud egress',
    color: 'amber',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>',
  },
  {
    value: 'Zero',
    label: 'wasted poll requests',
    detail: '60–90% of cloud polls return nothing',
    color: 'pink',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/>',
  },
]

const colorMap: Record<string, { text: string; glow: string; border: string; bg: string; iconBg: string }> = {
  emerald: { text: 'text-emerald-400', glow: 'shadow-emerald-500/20', border: 'border-emerald-500/20', bg: 'bg-emerald-500/[0.03]', iconBg: 'bg-emerald-500/10' },
  indigo: { text: 'text-indigo-400', glow: 'shadow-indigo-500/20', border: 'border-indigo-500/20', bg: 'bg-indigo-500/[0.03]', iconBg: 'bg-indigo-500/10' },
  amber: { text: 'text-amber-400', glow: 'shadow-amber-500/20', border: 'border-amber-500/20', bg: 'bg-amber-500/[0.03]', iconBg: 'bg-amber-500/10' },
  pink: { text: 'text-pink-400', glow: 'shadow-pink-500/20', border: 'border-pink-500/20', bg: 'bg-pink-500/[0.03]', iconBg: 'bg-pink-500/10' },
}
---

<section class="py-24 lg:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center animate-on-scroll">
      <!-- Leaf icon -->
      <div class="mx-auto mb-6 flex h-12 w-12 items-center justify-center rounded-full bg-emerald-500/10 ring-1 ring-emerald-500/20">
        <svg class="h-6 w-6 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>
        </svg>
      </div>
    </div>

    <SectionHeader
      title="Better for the planet"
      subtitle="Every byte that crosses a network costs energy. Local-first keeps data where it's used — and eliminates most of the waste."
      align="center"
    />

    <div class="mt-16 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {stats.map((stat) => {
        const c = colorMap[stat.color]
        return (
          <div class={`animate-on-scroll group rounded-xl border ${c.border} ${c.bg} p-6 text-center transition-all duration-300 hover:shadow-lg ${c.glow}`}>
            <div class={`mx-auto mb-4 flex h-10 w-10 items-center justify-center rounded-lg ${c.iconBg}`}>
              <svg class={`h-5 w-5 ${c.text}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <Fragment set:html={stat.icon} />
              </svg>
            </div>
            <div class={`text-3xl font-bold tracking-tight ${c.text} sm:text-4xl`}>{stat.value}</div>
            <div class="mt-2 text-sm font-medium text-gray-700 dark:text-gray-200">{stat.label}</div>
            <div class="mt-2 text-xs leading-relaxed text-gray-500 dark:text-gray-400">{stat.detail}</div>
          </div>
        )
      })}
    </div>

    <!-- Footnote -->
    <div class="mx-auto mt-12 max-w-2xl animate-on-scroll">
      <div class="rounded-lg border border-border bg-surface px-5 py-4">
        <div class="flex items-start gap-3">
          <svg class="mt-0.5 h-4 w-4 shrink-0 text-emerald-400/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <p class="text-sm leading-relaxed text-gray-500 dark:text-gray-400">
            Data centers consume ~460 TWh/year — 1.3% of global electricity. If just 10% of SaaS went local-first, we'd save the equivalent of
            <span class="font-medium text-emerald-400">Portugal's annual electricity consumption</span>.
            <span class="text-gray-600 dark:text-gray-500"> — IEA 2024, Aslan et al. 2017, Andrae & Edler 2015</span>
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
