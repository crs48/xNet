---
import Badge from '../ui/Badge.astro'
---

<section class="relative overflow-hidden">
  <!-- Grid background -->
  <div class="absolute inset-0 bg-[linear-gradient(rgba(79,70,229,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(79,70,229,0.03)_1px,transparent_1px)] bg-[size:64px_64px]"></div>
  <!-- Radial glow -->
  <div class="absolute left-1/2 top-0 -translate-x-1/2 h-[600px] w-[800px] rounded-full bg-indigo-500/[0.07] blur-[120px]"></div>

  <div class="relative mx-auto max-w-6xl px-6 py-32 lg:py-40">
    <div class="text-center">
      <div class="flex justify-center mb-8">
        <Badge>
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-indigo-400 opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-indigo-500"></span>
          </span>
          Pre-release &mdash; Help us build this
        </Badge>
      </div>

      <h1 class="text-5xl font-extrabold leading-[1.1] tracking-tight sm:text-6xl lg:text-7xl">
        <span class="bg-gradient-to-br from-gray-900 via-gray-700 to-indigo-600 dark:from-white dark:via-gray-100 dark:to-indigo-400 bg-clip-text text-transparent">
          Three hooks.<br />Zero backend.
        </span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-gray-500 dark:text-gray-400 sm:text-xl">
        Build local-first apps with React and TypeScript.
        Your data lives on the device, syncs peer-to-peer, and works offline.
        <span class="text-gray-600 dark:text-gray-300">No servers to deploy. No auth to configure. No vendor to depend on.</span>
      </p>

      <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a
          href="#get-started"
          class="rounded-lg bg-indigo-600 px-6 py-3 font-semibold text-white shadow-lg shadow-indigo-500/25 hover:bg-indigo-500 hover:shadow-indigo-500/40 transition-all"
        >
          Get Started
        </a>
        <a
          href="https://github.com/crs48/xNet"
          class="flex items-center gap-2 rounded-lg border border-border px-6 py-3 font-semibold text-gray-700 dark:text-gray-200 hover:border-indigo-500/50 hover:bg-surface transition-all"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          View on GitHub
        </a>
        <a
          href="https://github.com/crs48/xNet/stargazers"
          class="flex items-center gap-1.5 rounded-lg border border-border px-4 py-3 font-semibold text-gray-700 dark:text-gray-200 hover:border-yellow-500/50 hover:bg-surface transition-all"
          aria-label="Star xNet on GitHub"
        >
          <svg class="h-5 w-5 text-yellow-500" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .587l3.668 7.568 8.332 1.151-6.064 5.828 1.48 8.279L12 19.771l-7.416 3.642 1.48-8.279L0 9.306l8.332-1.151z"/></svg>
          <span>Star</span>
          <span class="star-count ml-0.5 rounded bg-gray-100 dark:bg-gray-800 px-1.5 py-0.5 text-xs font-medium text-gray-600 dark:text-gray-400" data-repo="crs48/xNet"></span>
        </a>
      </div>

      <!-- GitHub star count -->
      <script>
        async function fetchStarCount() {
          const el = document.querySelector('.star-count[data-repo]') as HTMLElement | null
          if (!el) return
          const repo = el.dataset.repo
          try {
            const res = await fetch(`https://api.github.com/repos/${repo}`)
            if (!res.ok) return
            const data = await res.json()
            const count = data.stargazers_count
            if (typeof count === 'number') {
              el.textContent = count >= 1000 ? `${(count / 1000).toFixed(1)}k` : String(count)
            }
          } catch { /* silent fail */ }
        }
        fetchStarCount()
      </script>

      <!-- Install command -->
      <div class="mt-8 flex justify-center">
        <div class="group relative inline-flex items-center gap-3 rounded-lg border border-border bg-surface/30 dark:bg-surface/50 px-5 py-2.5 font-mono text-sm text-gray-500 dark:text-gray-400">
          <span class="text-indigo-400">$</span>
          <span>pnpm add @xnet/react @xnet/data</span>
          <button
            class="copy-btn rounded border border-border px-1.5 py-0.5 text-xs text-gray-600 hover:text-gray-900 dark:hover:text-gray-300 transition-colors"
            data-copy="pnpm add @xnet/react @xnet/data"
            aria-label="Copy install command"
          >
            Copy
          </button>
        </div>
      </div>
    </div>
  </div>
</section>
