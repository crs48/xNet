---
import SectionHeader from '../ui/SectionHeader.astro'
import CodeBlock from '../ui/CodeBlock.astro'
---

<section id="get-started" class="relative border-t border-border/50 bg-surface/20 py-24 lg:py-32">
  <!-- Subtle glow -->
  <div class="absolute left-1/2 bottom-0 -translate-x-1/2 h-[400px] w-[600px] rounded-full bg-indigo-500/[0.05] blur-[120px]"></div>

  <div class="relative mx-auto max-w-6xl px-6">
    <SectionHeader
      title="Start building in 60 seconds"
      subtitle="Open source. MIT licensed. TypeScript all the way."
      align="center"
    />

    <div class="mx-auto mt-12 max-w-2xl space-y-6">
      <!-- Step 1 -->
      <div class="animate-on-scroll">
        <div class="mb-2 flex items-center gap-2">
          <span class="flex h-6 w-6 items-center justify-center rounded-full bg-indigo-500/10 text-xs font-bold text-indigo-400">1</span>
          <span class="text-sm font-medium text-gray-300">Install the packages</span>
        </div>
        <CodeBlock filename="terminal">
<span class="text-gray-500">$</span> pnpm add @xnet/react @xnet/data
        </CodeBlock>
      </div>

      <!-- Step 2 -->
      <div class="animate-on-scroll">
        <div class="mb-2 flex items-center gap-2">
          <span class="flex h-6 w-6 items-center justify-center rounded-full bg-indigo-500/10 text-xs font-bold text-indigo-400">2</span>
          <span class="text-sm font-medium text-gray-300">Define a schema</span>
        </div>
        <CodeBlock filename="schema.ts">
<span class="text-indigo-400">import</span> {'{'} defineSchema, text, select {'}'} <span class="text-indigo-400">from</span> <span class="text-emerald-400">'@xnet/data'</span>

<span class="text-indigo-400">export const</span> TaskSchema = <span class="text-yellow-300">defineSchema</span>({'{'}
  name: <span class="text-emerald-400">'Task'</span>,
  namespace: <span class="text-emerald-400">'xnet://your-did/'</span>,
  properties: {'{'}
    title:  <span class="text-yellow-300">text</span>({'{'} required: <span class="text-orange-400">true</span> {'}'}),
    status: <span class="text-yellow-300">select</span>({'{'} options: [<span class="text-emerald-400">'todo'</span>, <span class="text-emerald-400">'doing'</span>, <span class="text-emerald-400">'done'</span>] {'}'})
  {'}'}
{'}'})
        </CodeBlock>
      </div>

      <!-- Step 3 -->
      <div class="animate-on-scroll">
        <div class="mb-2 flex items-center gap-2">
          <span class="flex h-6 w-6 items-center justify-center rounded-full bg-indigo-500/10 text-xs font-bold text-indigo-400">3</span>
          <span class="text-sm font-medium text-gray-300">Use it in your components</span>
        </div>
        <div class="group relative overflow-hidden rounded-xl border border-border bg-[#0a0a0f]">
          <div class="flex items-center border-b border-border bg-surface/50 px-4 py-2">
            <div class="flex items-center gap-1.5 mr-3">
              <span class="h-2.5 w-2.5 rounded-full bg-[#ff5f57]"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-[#febc2e]"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-[#28c840]"></span>
            </div>
            <span class="text-xs font-mono text-gray-500">App.tsx</span>
          </div>
          <pre class="overflow-x-auto p-5 font-mono text-sm leading-relaxed text-gray-300"><code set:html={`<span class="text-indigo-400">import</span> { useQuery, useMutate } <span class="text-indigo-400">from</span> <span class="text-emerald-400">'@xnet/react'</span>
<span class="text-indigo-400">import</span> { TaskSchema } <span class="text-indigo-400">from</span> <span class="text-emerald-400">'./schema'</span>

<span class="text-indigo-400">function</span> <span class="text-yellow-300">App</span>() {
  <span class="text-indigo-400">const</span> { data: tasks } = <span class="text-yellow-300">useQuery</span>(TaskSchema)
  <span class="text-indigo-400">const</span> { create } = <span class="text-yellow-300">useMutate</span>()

  <span class="text-indigo-400">return</span> (
    &lt;div&gt;
      &lt;button onClick={() =&gt; <span class="text-yellow-300">create</span>(TaskSchema, {
        title: <span class="text-emerald-400">'New task'</span>, status: <span class="text-emerald-400">'todo'</span>
      })}&gt;Add&lt;/button&gt;
      {tasks.<span class="text-yellow-300">map</span>(t =&gt; &lt;li key={t.id}&gt;{t.title}&lt;/li&gt;)}
    &lt;/div&gt;
  )
}
<span class="text-gray-500">// That's it. Sync, storage, crypto — all handled.</span>`} /></code></pre>
        </div>
      </div>
    </div>

    <!-- Run the full monorepo -->
    <div class="mx-auto mt-12 max-w-2xl animate-on-scroll">
      <div class="rounded-xl border border-border bg-surface/50 p-5 text-center">
        <p class="text-sm text-gray-400 mb-3">Or clone the full monorepo to explore the Electron app, canvas, editor, and devtools:</p>
        <pre class="inline-block rounded-lg border border-border bg-[#0a0a0f] px-4 py-2.5 font-mono text-sm text-gray-400">git clone https://github.com/crs48/xNet.git && cd xNet && pnpm install && pnpm dev</pre>
      </div>
    </div>

    <p class="mt-8 text-center text-sm text-gray-600">
      Requires Node.js 22+ and pnpm. See the
      <a href="https://github.com/crs48/xNet" class="text-indigo-400/70 hover:text-indigo-400 hover:underline">README</a> for full documentation.
    </p>
  </div>
</section>
