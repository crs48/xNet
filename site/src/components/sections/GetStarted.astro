---
import SectionHeader from '../ui/SectionHeader.astro'
import CodeBlock from '../ui/CodeBlock.astro'

const kw = (s: string) => `<span class="text-indigo-400">${s}</span>`
const fn = (s: string) => `<span class="text-yellow-300">${s}</span>`
const str = (s: string) => `<span class="text-emerald-400">${s}</span>`
const num = (s: string) => `<span class="text-orange-400">${s}</span>`
const cm = (s: string) => `<span class="text-gray-500">${s}</span>`
const dim = (s: string) => `<span class="text-gray-500">${s}</span>`

const installCode = `${dim('$')} pnpm add @xnet/react @xnet/data`

const schemaCode = [
  `${kw('import')} { defineSchema, text, select } ${kw('from')} ${str("'@xnet/data'")}`,
  ``,
  `${kw('export const')} TaskSchema = ${fn('defineSchema')}({`,
  `  name: ${str("'Task'")},`,
  `  namespace: ${str("'xnet://your-did/'")},`,
  `  properties: {`,
  `    title: ${fn('text')}({ required: ${num('true')} }),`,
  `    status: ${fn('select')}({`,
  `      options: [${str("'todo'")}, ${str("'doing'")}, ${str("'done'")}]`,
  `    })`,
  `  }`,
  `})`,
].join('\n')

const appCode = [
  `${kw('import')} { useQuery, useMutate } ${kw('from')} ${str("'@xnet/react'")}`,
  `${kw('import')} { TaskSchema } ${kw('from')} ${str("'./schema'")}`,
  ``,
  `${kw('function')} ${fn('App')}() {`,
  `  ${kw('const')} { data: tasks } = ${fn('useQuery')}(TaskSchema)`,
  `  ${kw('const')} { create } = ${fn('useMutate')}()`,
  ``,
  `  ${kw('return')} (`,
  `    &lt;div&gt;`,
  `      &lt;button onClick={() =&gt; ${fn('create')}(TaskSchema, {`,
  `        title: ${str("'New task'")},`,
  `        status: ${str("'todo'")}`,
  `      })}&gt;Add&lt;/button&gt;`,
  `      {tasks.${fn('map')}(t =&gt; &lt;li key={t.id}&gt;{t.title}&lt;/li&gt;)}`,
  `    &lt;/div&gt;`,
  `  )`,
  `}`,
  `${cm('// That\'s it. Sync, storage, crypto — all handled.')}`,
].join('\n')

const cloneCode = `${dim('$')} git clone https://github.com/crs48/xNet.git &amp;&amp; cd xNet &amp;&amp; pnpm install &amp;&amp; pnpm dev`
---

<section id="get-started" class="relative border-t border-border/50 bg-surface/10 dark:bg-surface/20 py-24 lg:py-32">
  <!-- Subtle glow -->
  <div class="absolute left-1/2 bottom-0 -translate-x-1/2 h-[400px] w-[600px] rounded-full bg-indigo-500/[0.05] blur-[120px]"></div>

  <div class="relative mx-auto max-w-6xl px-6">
    <SectionHeader
      title="Start building in 60 seconds"
      subtitle="Open source. MIT licensed. TypeScript all the way."
      align="center"
    />

    <div class="mx-auto mt-12 max-w-2xl space-y-6">
      <!-- Step 1 -->
      <div class="animate-on-scroll">
        <div class="mb-2 flex items-center gap-2">
          <span class="flex h-6 w-6 items-center justify-center rounded-full bg-indigo-500/10 text-xs font-bold text-indigo-400">1</span>
          <span class="text-sm font-medium text-gray-600 dark:text-gray-300">Install the packages</span>
        </div>
        <CodeBlock filename="terminal" code={installCode} />
      </div>

      <!-- Step 2 -->
      <div class="animate-on-scroll">
        <div class="mb-2 flex items-center gap-2">
          <span class="flex h-6 w-6 items-center justify-center rounded-full bg-indigo-500/10 text-xs font-bold text-indigo-400">2</span>
          <span class="text-sm font-medium text-gray-600 dark:text-gray-300">Define a schema</span>
        </div>
        <CodeBlock filename="schema.ts" code={schemaCode} />
      </div>

      <!-- Step 3 -->
      <div class="animate-on-scroll">
        <div class="mb-2 flex items-center gap-2">
          <span class="flex h-6 w-6 items-center justify-center rounded-full bg-indigo-500/10 text-xs font-bold text-indigo-400">3</span>
          <span class="text-sm font-medium text-gray-600 dark:text-gray-300">Use it in your components</span>
        </div>
        <CodeBlock filename="App.tsx" code={appCode} />
      </div>
    </div>

    <!-- Run the full monorepo -->
    <div class="mx-auto mt-12 max-w-2xl animate-on-scroll">
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-3 text-center">Or clone the full monorepo to explore the Electron app, canvas, editor, and devtools:</p>
      <CodeBlock filename="terminal" code={cloneCode} />
    </div>

    <div class="mt-8 flex justify-center gap-4">
      <a href={`${import.meta.env.BASE_URL}/docs/quickstart/`} class="rounded-lg bg-indigo-500 px-5 py-2.5 text-sm font-medium text-white hover:bg-indigo-400 transition-colors">
        Read the Docs
      </a>
      <a href="https://github.com/crs48/xNet" class="rounded-lg border border-border px-5 py-2.5 text-sm font-medium text-gray-600 dark:text-gray-300 hover:border-indigo-500/50 hover:bg-surface transition-all">
        View on GitHub
      </a>
    </div>
    <p class="mt-4 text-center text-sm text-gray-600">
      Requires Node.js 22+ and pnpm.
    </p>
  </div>
</section>
