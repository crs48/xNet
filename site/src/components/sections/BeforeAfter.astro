---
import SectionHeader from '../ui/SectionHeader.astro'
---

<section class="border-y border-border/50 bg-surface/20 py-24 lg:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <SectionHeader
      title="A fundamentally simpler architecture"
      subtitle="Stop managing infrastructure. Start building products."
      align="center"
    />

    <div class="mx-auto mt-16 grid max-w-5xl gap-8 md:grid-cols-2">
      <!-- Traditional -->
      <div class="animate-on-scroll rounded-xl border border-border bg-[#0a0a0f] p-6 sm:p-8">
        <div class="text-sm font-medium text-gray-500 mb-6">Traditional Architecture</div>
        <div class="space-y-3 font-mono text-sm">
          <div class="flex items-center gap-3">
            <div class="h-9 rounded-lg border border-border bg-surface px-3 py-2 text-gray-400 flex-1 text-center">React App</div>
          </div>
          <div class="flex justify-center text-gray-600">&darr;</div>
          <div class="flex items-center gap-2">
            <div class="h-9 rounded-lg border border-gray-700/50 bg-gray-800/30 px-2 py-2 text-gray-500 flex-1 text-center text-xs">API Layer</div>
            <div class="h-9 rounded-lg border border-gray-700/50 bg-gray-800/30 px-2 py-2 text-gray-500 flex-1 text-center text-xs">Auth</div>
          </div>
          <div class="flex justify-center text-gray-600">&darr;</div>
          <div class="flex items-center gap-2">
            <div class="h-9 rounded-lg border border-gray-700/50 bg-gray-800/30 px-2 py-2 text-gray-500 flex-1 text-center text-xs">Database</div>
            <div class="h-9 rounded-lg border border-gray-700/50 bg-gray-800/30 px-2 py-2 text-gray-500 flex-1 text-center text-xs">Cache</div>
            <div class="h-9 rounded-lg border border-gray-700/50 bg-gray-800/30 px-2 py-2 text-gray-500 flex-1 text-center text-xs">WS Server</div>
          </div>
          <div class="flex justify-center text-gray-600">&darr;</div>
          <div class="flex items-center gap-2">
            <div class="h-9 rounded-lg border border-gray-700/50 bg-gray-800/30 px-2 py-2 text-gray-500 flex-1 text-center text-xs">CDN</div>
            <div class="h-9 rounded-lg border border-gray-700/50 bg-gray-800/30 px-2 py-2 text-gray-500 flex-1 text-center text-xs">Queue</div>
            <div class="h-9 rounded-lg border border-gray-700/50 bg-gray-800/30 px-2 py-2 text-gray-500 flex-1 text-center text-xs">Hosting</div>
          </div>
        </div>
        <div class="mt-6 flex flex-wrap gap-2 border-t border-border pt-4">
          <span class="rounded bg-red-500/10 px-2 py-0.5 text-xs text-red-400/70">6+ services</span>
          <span class="rounded bg-red-500/10 px-2 py-0.5 text-xs text-red-400/70">3+ vendors</span>
          <span class="rounded bg-red-500/10 px-2 py-0.5 text-xs text-red-400/70">Monthly bills</span>
          <span class="rounded bg-red-500/10 px-2 py-0.5 text-xs text-red-400/70">No offline</span>
        </div>
      </div>

      <!-- xNet -->
      <div class="animate-on-scroll rounded-xl border border-indigo-500/30 bg-indigo-500/[0.03] p-6 sm:p-8">
        <div class="text-sm font-medium text-indigo-400 mb-6">xNet Architecture</div>
        <div class="space-y-3 font-mono text-sm">
          <div class="flex items-center gap-3">
            <div class="h-9 rounded-lg border border-indigo-500/30 bg-indigo-500/10 px-3 py-2 text-indigo-300 flex-1 text-center">React App</div>
          </div>
          <div class="flex justify-center text-indigo-500/50">&darr;</div>
          <div class="flex items-center gap-3">
            <div class="h-9 rounded-lg border border-indigo-500/30 bg-indigo-500/10 px-3 py-2 text-indigo-300 flex-1 text-center">@xnet/react hooks</div>
          </div>
          <div class="flex justify-center text-indigo-500/50">&darr;</div>
          <div class="flex items-center gap-2">
            <div class="h-9 rounded-lg border border-indigo-500/20 bg-indigo-500/5 px-2 py-2 text-indigo-400/70 flex-1 text-center text-xs">Local Store</div>
            <div class="h-9 rounded-lg border border-indigo-500/20 bg-indigo-500/5 px-2 py-2 text-indigo-400/70 flex-1 text-center text-xs">P2P Sync</div>
          </div>
          <div class="flex h-[88px] items-center justify-center">
            <div class="text-center">
              <div class="text-2xl text-indigo-400/40">&#10024;</div>
              <div class="text-xs text-gray-600 mt-1">That's the whole stack</div>
            </div>
          </div>
        </div>
        <div class="mt-6 flex flex-wrap gap-2 border-t border-indigo-500/10 pt-4">
          <span class="rounded bg-emerald-500/10 px-2 py-0.5 text-xs text-emerald-400/70">2 packages</span>
          <span class="rounded bg-emerald-500/10 px-2 py-0.5 text-xs text-emerald-400/70">0 vendors</span>
          <span class="rounded bg-emerald-500/10 px-2 py-0.5 text-xs text-emerald-400/70">$0/month</span>
          <span class="rounded bg-emerald-500/10 px-2 py-0.5 text-xs text-emerald-400/70">Offline-first</span>
        </div>
      </div>
    </div>
  </div>
</section>
