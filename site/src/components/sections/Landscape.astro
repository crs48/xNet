---

<section id="landscape" class="py-24 lg:py-32">
  <div class="mx-auto max-w-7xl px-6">
    <SectionHeader
      title="The local-first landscape"
      subtitle="We're building xNet because we believe in a future where users own their data. We're not alone — here are the projects pushing this vision forward. We encourage you to explore them all."
      align="center"
    />

    <!-- Table 1: Data Infrastructure -->
    <div class="mt-16 animate-on-scroll">
      <h3 class="text-lg font-semibold text-gray-200 mb-2">Developer Frameworks & Data Tools</h3>
      <p class="text-sm text-gray-500 mb-6">What you'd use to build a local-first app today. Each has different tradeoffs.</p>
      <div class="overflow-x-auto rounded-xl border border-border">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-border bg-surface/50">
              <th class="sticky left-0 z-10 bg-surface/90 backdrop-blur-sm px-4 py-3 text-left font-semibold text-gray-300 min-w-[100px]">Project</th>
              {infraColumns.map(col => (
                <th class="px-4 py-3 text-left font-medium text-gray-500 whitespace-nowrap">{col.label}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {infraProjects.map((project) => (
              <tr class={`border-b border-border/50 ${project.highlight ? 'bg-indigo-500/[0.04]' : 'hover:bg-surface/30'} transition-colors`}>
                <td class={`sticky left-0 z-10 ${project.highlight ? 'bg-indigo-500/[0.06]' : 'bg-[#0a0a0f]'} backdrop-blur-sm px-4 py-3 font-medium whitespace-nowrap`}>
                  <a href={project.url} target="_blank" rel="noopener noreferrer" class={`hover:underline ${project.highlight ? 'text-indigo-400' : 'text-gray-300 hover:text-indigo-400'}`}>
                    {project.name}
                  </a>
                </td>
                {infraColumns.map(col => {
                  const val = (project as any)[col.key]
                  const isBoolean = typeof val === 'boolean'
                  const isDash = val === '—'
                  return (
                    <td class={`px-4 py-3 whitespace-nowrap ${isDash ? 'text-gray-700' : 'text-gray-400'}`}>
                      {isBoolean ? (
                        val ? (
                          <span class="text-emerald-400">Yes</span>
                        ) : (
                          <span class="text-gray-600">No</span>
                        )
                      ) : val}
                    </td>
                  )
                })}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="mt-2 text-xs text-gray-600">** Convex runtime is proprietary; client SDKs are open source. All other projects are fully open source.</p>
    </div>

    <!-- Table 2: Protocols & P2P Infrastructure -->
    <div class="mt-16 animate-on-scroll">
      <h3 class="text-lg font-semibold text-gray-200 mb-2">Protocols & P2P Infrastructure</h3>
      <p class="text-sm text-gray-500 mb-6">The broader ecosystem of decentralized data. Different scopes, different goals — all pushing toward user-owned data.</p>
      <div class="overflow-x-auto rounded-xl border border-border">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-border bg-surface/50">
              <th class="sticky left-0 z-10 bg-surface/90 backdrop-blur-sm px-4 py-3 text-left font-semibold text-gray-300 min-w-[130px]">Project</th>
              {protocolColumns.map(col => (
                <th class="px-4 py-3 text-left font-medium text-gray-500 whitespace-nowrap">{col.label}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {protocolProjects.map((project) => (
              <tr class={`border-b border-border/50 ${project.highlight ? 'bg-indigo-500/[0.04]' : 'hover:bg-surface/30'} transition-colors`}>
                <td class={`sticky left-0 z-10 ${project.highlight ? 'bg-indigo-500/[0.06]' : 'bg-[#0a0a0f]'} backdrop-blur-sm px-4 py-3 font-medium whitespace-nowrap`}>
                  <a href={project.url} target="_blank" rel="noopener noreferrer" class={`hover:underline ${project.highlight ? 'text-indigo-400' : 'text-gray-300 hover:text-indigo-400'}`}>
                    {project.name}
                  </a>
                </td>
                {protocolColumns.map(col => (
                  <td class="px-4 py-3 text-gray-400 whitespace-nowrap">{(project as any)[col.key]}</td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Table 3: Productivity Apps -->
    <div class="mt-16 animate-on-scroll">
      <h3 class="text-lg font-semibold text-gray-200 mb-2">Productivity Apps</h3>
      <p class="text-sm text-gray-500 mb-6">How xNet's built-in app compares to the tools you might already use. Different philosophies — from cloud-first SaaS to local-first open source.</p>
      <div class="overflow-x-auto rounded-xl border border-border">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-border bg-surface/50">
              <th class="sticky left-0 z-10 bg-surface/90 backdrop-blur-sm px-4 py-3 text-left font-semibold text-gray-300 min-w-[110px]">App</th>
              {productivityColumns.map(col => (
                <th class="px-4 py-3 text-left font-medium text-gray-500 whitespace-nowrap">{col.label}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {productivityApps.map((app) => (
              <tr class={`border-b border-border/50 ${app.highlight ? 'bg-indigo-500/[0.04]' : 'hover:bg-surface/30'} transition-colors`}>
                <td class={`sticky left-0 z-10 ${app.highlight ? 'bg-indigo-500/[0.06]' : 'bg-[#0a0a0f]'} backdrop-blur-sm px-4 py-3 font-medium whitespace-nowrap`}>
                  <a href={app.url} target="_blank" rel="noopener noreferrer" class={`hover:underline ${app.highlight ? 'text-indigo-400' : 'text-gray-300 hover:text-indigo-400'}`}>
                    {app.name}
                  </a>
                </td>
                {productivityColumns.map(col => {
                  const val = (app as any)[col.key]
                  const isBoolean = typeof val === 'boolean'
                  const isNo = val === 'No'
                  return (
                    <td class={`px-4 py-3 whitespace-nowrap ${isNo ? 'text-gray-700' : 'text-gray-400'}`}>
                      {isBoolean ? (
                        val ? (
                          <span class="text-emerald-400">Yes</span>
                        ) : (
                          <span class="text-gray-600">No</span>
                        )
                      ) : val}
                    </td>
                  )
                })}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Where xNet fits -->
    <div class="mx-auto mt-12 max-w-3xl animate-on-scroll">
      <div class="rounded-xl border border-border bg-surface/50 p-6 sm:p-8 text-center">
        <h3 class="font-semibold text-gray-200 mb-3">Where xNet fits</h3>
        <p class="text-sm text-gray-400 leading-relaxed">
          xNet combines <strong class="text-gray-300">TypeScript-inferred schemas</strong>,
          a <strong class="text-gray-300">dual CRDT strategy</strong> (Yjs for rich text + Lamport LWW for structured data),
          <strong class="text-gray-300">React hooks</strong>,
          a <strong class="text-gray-300">four-layer plugin system</strong>,
          and <strong class="text-gray-300">true P2P sync</strong> — all in one framework.
        </p>
        <div class="mt-6 space-y-2 text-sm text-gray-500">
          <p>Building a React app and want local-first with minimal boilerplate? <strong class="text-indigo-400">Start here.</strong></p>
          <p>Need a social protocol? Check out <a href="https://atproto.com" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-indigo-400 underline decoration-gray-700 hover:decoration-indigo-400">AT Protocol</a> or <a href="https://nostr.com" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-indigo-400 underline decoration-gray-700 hover:decoration-indigo-400">Nostr</a>.</p>
          <p>Need low-level P2P networking? Check out <a href="https://iroh.computer" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-indigo-400 underline decoration-gray-700 hover:decoration-indigo-400">Iroh</a> or <a href="https://holepunch.to" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-indigo-400 underline decoration-gray-700 hover:decoration-indigo-400">Hypercore</a>.</p>
          <p>Want a production knowledge base today? Check out <a href="https://anytype.io" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-indigo-400 underline decoration-gray-700 hover:decoration-indigo-400">Anytype</a>.</p>
        </div>
      </div>
    </div>
  </div>
</section>
