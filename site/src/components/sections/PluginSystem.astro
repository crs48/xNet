---
import SectionHeader from '../ui/SectionHeader.astro'
import CodeBlock from '../ui/CodeBlock.astro'

const kw = (s: string) => `<span class="text-indigo-400">${s}</span>`
const fn = (s: string) => `<span class="text-yellow-300">${s}</span>`
const str = (s: string) => `<span class="text-emerald-400">${s}</span>`
const num = (s: string) => `<span class="text-orange-400">${s}</span>`

const pluginCode = [
  `${kw('import')} { definePlugin } ${kw('from')} ${str("'@xnet/sdk'")}`,
  ``,
  `${kw('export default')} ${fn('definePlugin')}({`,
  `  name: ${str("'word-count'")},`,
  `  setup(ctx) {`,
  `    ctx.${fn('registerView')}({`,
  `      name: ${str("'Word Count'")},`,
  `      component: () =&gt; {`,
  `        ${kw('const')} { doc } = ctx.${fn('useCurrentNode')}()`,
  `        ${kw('const')} words = doc?.getText()?.length ?? ${num('0')}`,
  `        ${kw('return')} &lt;span&gt;{words} words&lt;/span&gt;`,
  `      }`,
  `    })`,
  `  }`,
  `})`,
].join('\n')

const layers = [
  {
    num: '1',
    title: 'Scripts',
    description: 'Single-file, AI-generatable. Think "formulas for your data pipeline." Run anywhere.',
    platforms: 'Web, Desktop, Mobile',
    color: 'emerald',
  },
  {
    num: '2',
    title: 'Extensions',
    description: 'Multi-file packages with custom views, editors, and schemas. The building blocks of apps.',
    platforms: 'Web, Desktop, Mobile',
    color: 'indigo',
  },
  {
    num: '3',
    title: 'Services',
    description: 'Background processes with full Node.js access. Heavy computation, custom protocols.',
    platforms: 'Desktop',
    color: 'amber',
  },
  {
    num: '4',
    title: 'Integrations',
    description: 'External connections via webhooks, MCP, and automation tools like N8N.',
    platforms: 'All platforms',
    color: 'pink',
  },
]

const colorMap: Record<string, { num: string, border: string }> = {
  emerald: { num: 'bg-emerald-500/10 text-emerald-400', border: 'border-emerald-500/20' },
  indigo: { num: 'bg-indigo-500/10 text-indigo-400', border: 'border-indigo-500/20' },
  amber: { num: 'bg-amber-500/10 text-amber-400', border: 'border-amber-500/20' },
  pink: { num: 'bg-pink-500/10 text-pink-400', border: 'border-pink-500/20' },
}
---

<section class="border-y border-border/50 bg-surface/10 dark:bg-surface/20 py-24 lg:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <SectionHeader
      title="Extend everything"
      subtitle="A four-layer plugin system inspired by VS Code, Figma, and Obsidian. The simplest plugin is one file. An AI can generate one in seconds."
    />

    <div class="mt-16 grid gap-4 sm:grid-cols-2">
      {layers.map((layer) => {
        const c = colorMap[layer.color]
        return (
          <div class={`animate-on-scroll rounded-xl border ${c.border} bg-surface p-6 transition-all duration-300 hover:border-opacity-60`}>
            <div class="flex items-center gap-3 mb-3">
              <span class={`flex h-7 w-7 items-center justify-center rounded-md ${c.num} text-xs font-bold`}>{layer.num}</span>
              <h4 class="font-semibold">{layer.title}</h4>
            </div>
            <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed">{layer.description}</p>
            <div class="mt-3">
              <span class="text-xs text-gray-600">{layer.platforms}</span>
            </div>
          </div>
        )
      })}
    </div>

    <!-- Quick example -->
    <div class="mx-auto mt-12 max-w-2xl animate-on-scroll">
      <CodeBlock filename="word-count-plugin.ts" code={pluginCode} />
    </div>
  </div>
</section>
