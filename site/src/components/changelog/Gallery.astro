---
/**
 * Changelog media gallery (exploration 0196). Zero runtime dependencies.
 *
 * All screenshots live in one horizontally-scrolling row (~2.5 previews wide,
 * with a fade on the trailing edge to hint there's more). Clicking a preview
 * opens the lightbox. A comparison preview — and the lightbox — shows the
 * "after" image by default, swaps to "before" on hover/focus, and shows the
 * "diff" while pressed (all instant, pure CSS; the press-hold + lightbox are
 * wired by the island script in changelog/index.astro). Interaction-flow
 * videos render as a click-to-play <video> below the row.
 */
interface Item {
  type: 'cmp' | 'img'
  after: string
  before?: string
  diff?: string
  alt: string
  caption?: string
}
interface Video {
  mp4: string
  poster: string
  alt: string
}
interface Props {
  entryId: string
  items?: Item[]
  video?: Video
  galleryLink?: { prUrl: string; count: number; pr: number }
}
const { entryId, items = [], video, galleryLink } = Astro.props
const hasMedia = items.length > 0 || Boolean(video)
---

{
  hasMedia && (
    <div class="cl-gallery mb-4 mt-1">
      {items.length > 0 && (
        <div class="cl-row" aria-label="Screenshots for this release">
          {items.map((it) => (
            <button
              type="button"
              class:list={['cl-item', it.type === 'cmp' && 'cl-item--cmp']}
              data-group={entryId}
              data-type={it.type}
              data-after={it.after}
              data-before={it.before}
              data-diff={it.diff}
              data-alt={it.alt}
              aria-label={
                it.type === 'cmp'
                  ? `Before and after: ${it.alt}. Click to enlarge; hover for before, press and hold for the diff.`
                  : `View screenshot: ${it.alt}`
              }
            >
              <span class="cl-item-media">
                <img class="cl-item-after" src={it.after} alt={it.alt} loading="lazy" />
                {it.before && (
                  <img class="cl-item-before" src={it.before} alt="" aria-hidden="true" loading="lazy" />
                )}
                {it.diff && (
                  <img class="cl-item-diff" src={it.diff} alt="" aria-hidden="true" loading="lazy" />
                )}
                {it.type === 'cmp' && (
                  <span class="cl-item-badge" aria-hidden="true">
                    <span class="b-after">After</span>
                    <span class="b-before">Before</span>
                    {it.diff && <span class="b-diff">Diff</span>}
                  </span>
                )}
                {it.caption && <span class="cl-item-cap">{it.caption}</span>}
              </span>
            </button>
          ))}
        </div>
      )}

      {video && (
        <figure class="cl-video-wrap">
          <video
            class="cl-video"
            poster={video.poster}
            controls
            muted
            loop
            playsinline
            preload="none"
            aria-label={video.alt}
          >
            <source src={video.mp4} type="video/mp4" />
          </video>
          <figcaption class="cl-media-cap">{video.alt}</figcaption>
        </figure>
      )}

      {galleryLink && (
        <a
          class="cl-gallery-link"
          href={galleryLink.prUrl}
          target="_blank"
          rel="noopener noreferrer"
        >
          View all {galleryLink.count} screenshot{galleryLink.count === 1 ? '' : 's'} on PR #
          {galleryLink.pr} →
        </a>
      )}
    </div>
  )
}

<style>
  .cl-gallery > * + * {
    margin-top: 0.75rem;
  }

  /* Horizontal preview row — ~2.5 items visible; a trailing fade (added by JS
     only when the row overflows) hints there's more to scroll. */
  .cl-row {
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    padding-bottom: 0.4rem;
    scroll-snap-type: x proximity;
    scrollbar-width: thin;
  }
  .cl-row.cl-row--overflow {
    -webkit-mask-image: linear-gradient(to right, #000 calc(100% - 3rem), transparent);
    mask-image: linear-gradient(to right, #000 calc(100% - 3rem), transparent);
  }
  .cl-item {
    flex: 0 0 auto;
    width: clamp(180px, 40%, 280px);
    scroll-snap-align: start;
    margin: 0;
    padding: 0;
    border: 1px solid var(--lp-border);
    border-radius: 0.5rem;
    overflow: hidden;
    background: none;
    cursor: pointer;
  }
  .cl-item:hover {
    border-color: #6366f1;
  }
  .cl-item:focus-visible {
    outline: 2px solid #6366f1;
    outline-offset: 2px;
  }
  .cl-item-media {
    position: relative;
    display: block;
    aspect-ratio: 16 / 10;
  }
  .cl-item-after,
  .cl-item-before,
  .cl-item-diff {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  /* after shown by default; no transition = instant swap */
  .cl-item-before,
  .cl-item-diff {
    opacity: 0;
  }
  .cl-item:hover .cl-item-before {
    opacity: 1;
  }
  .cl-item.is-holding .cl-item-diff {
    opacity: 1;
  }

  .cl-item-badge {
    position: absolute;
    top: 0.3rem;
    left: 0.3rem;
    padding: 0.08rem 0.4rem;
    border-radius: 0.25rem;
    background: rgba(0, 0, 0, 0.65);
    color: #fff;
    font-size: 0.55rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    pointer-events: none;
  }
  .cl-item-badge .b-before,
  .cl-item-badge .b-diff {
    display: none;
  }
  .cl-item:hover .b-after {
    display: none;
  }
  .cl-item:hover .b-before {
    display: inline;
  }
  .cl-item.is-holding .b-after,
  .cl-item.is-holding .b-before {
    display: none;
  }
  .cl-item.is-holding .b-diff {
    display: inline;
  }

  .cl-item-cap {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0.12rem 0.4rem;
    background: rgba(0, 0, 0, 0.55);
    color: #fff;
    font-size: 0.6rem;
    text-align: left;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    pointer-events: none;
  }

  .cl-video-wrap {
    margin: 0;
  }
  .cl-video {
    width: 100%;
    border: 1px solid var(--lp-border);
    border-radius: 0.5rem;
  }
  .cl-media-cap {
    padding: 0.35rem 0.5rem;
    font-size: 0.7rem;
    color: #9ca3af;
  }

  .cl-gallery-link {
    display: inline-block;
    font-size: 0.8rem;
    color: #6366f1;
  }
  .cl-gallery-link:hover {
    text-decoration: underline;
  }
</style>
