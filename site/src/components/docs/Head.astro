---
/**
 * Custom Starlight Head — injects Mermaid.js for rendering diagrams.
 * rehype-mermaid with strategy 'pre-mermaid' outputs <pre class="mermaid">
 * blocks that Mermaid.js picks up and renders client-side.
 *
 * Re-renders diagrams when the Starlight theme toggle is used.
 */
import type { Props } from '@astrojs/starlight/props'
import Default from '@astrojs/starlight/components/Head.astro'

// Cookieless analytics on the docs pages too (exploration 0210). Docs render
// through this Starlight head, not Base.astro, so the tag must be repeated here
// to honor the privacy policy's "how people use our documentation" wording.
// Off unless PUBLIC_ANALYTICS_DOMAIN is set at build time.
const analyticsDomain = import.meta.env.PUBLIC_ANALYTICS_DOMAIN
const analyticsSrc = import.meta.env.PUBLIC_ANALYTICS_SRC || 'https://plausible.io/js/script.js'
---

<Default {...Astro.props}><slot /></Default>

{analyticsDomain && <script is:inline defer data-domain={analyticsDomain} src={analyticsSrc} />}

<script>
  // Mermaid is only fetched on pages that actually contain a diagram: the
  // dynamic import() stays a separate Vite chunk, so the ~480 KB core bundle
  // is loaded on demand instead of by every docs page.
  const diagrams = () => document.querySelectorAll<HTMLElement>('pre.mermaid')

  if (diagrams().length > 0) void setup()

  async function setup() {
    // Stash each diagram's source before Mermaid replaces it with an <svg>,
    // so a theme toggle can re-render from the original markup.
    diagrams().forEach((el) => {
      if (el.textContent && !el.dataset.source) el.dataset.source = el.textContent
    })

    const { default: mermaid } = await import('mermaid')

    const darkVars = {
      primaryColor: '#6366f1',
      primaryTextColor: '#e5e7eb',
      primaryBorderColor: '#4b5563',
      lineColor: '#6b7280',
      secondaryColor: '#1e1e2e',
      tertiaryColor: '#12121a'
    }

    const lightVars = {
      primaryColor: '#4f46e5',
      primaryTextColor: '#1e1e2e',
      primaryBorderColor: '#9ca3af',
      lineColor: '#6b7280',
      secondaryColor: '#e8e8ff',
      tertiaryColor: '#f0f0f4'
    }

    const isLight = () => document.documentElement.dataset.theme === 'light'

    let drawing = false
    async function draw() {
      if (drawing) return
      drawing = true
      try {
        mermaid.initialize({
          startOnLoad: false,
          theme: isLight() ? 'default' : 'dark',
          themeVariables: isLight() ? lightVars : darkVars
        })
        const nodes = diagrams()
        // Reset elements to source text, then re-render
        for (const el of nodes) {
          if (el.dataset.source) {
            el.removeAttribute('data-processed')
            el.innerHTML = el.dataset.source
          }
        }
        await mermaid.run({ nodes })
      } finally {
        drawing = false
      }
    }

    await draw()

    // Re-render on theme change (Starlight sets data-theme on <html>)
    new MutationObserver(() => void draw()).observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['data-theme']
    })
  }
</script>
